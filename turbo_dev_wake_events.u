use lib.base.data.List takeEnd
use lib.unison_cloud_27_3_0.durable.OrderedTable
use lib.unison_json_1_3_5.Decoder
use lib.unison_json_1_3_5.core.Json
use lib.unison_json_1_3_5.core.Json.object

type turbo.domain.DevWakeEvent
  = DevWakeEvent
      UserId
      ChannelId
      DeviceId
      Text
      UserId
      DeviceId
      Text
      Text
      Text
      (Optional Text)
      Instant

turbo.domain.DevWakeEvent.doc =
  {{
  {type DevWakeEvent} stores one dev-visible wake-send attempt for an authenticated sender.

  It is intended to make hosted PushToTalk wake attempts visible in merged diagnostics even
  when the actual APNs send is still performed by an external bridge helper.
  }}

turbo.store.devWakeEvents.tables.recentByUser : Database -> OrderedTable UserId [DevWakeEvent]
turbo.store.devWakeEvents.tables.recentByUser db =
  OrderedTable.named db "turboDevWakeEventsRecentByUser_v1" Universal.ordering

turbo.store.devWakeEvents.listRecent : Database -> UserId -> '{Exception, Remote} [DevWakeEvent]
turbo.store.devWakeEvents.listRecent db userId = do
  match OrderedTable.tryRead (turbo.store.devWakeEvents.tables.recentByUser db) userId with
    Some events -> events
    None -> []

turbo.store.devWakeEvents.appendRecent :
  Database
  -> UserId
  -> ChannelId
  -> DeviceId
  -> Text
  -> UserId
  -> DeviceId
  -> Text
  -> Text
  -> Text
  -> Optional Text
  -> '{Exception, Storage, Remote} DevWakeEvent
turbo.store.devWakeEvents.appendRecent db senderUserId channelId senderDeviceId senderHandle targetUserId targetDeviceId startedAt result statusCode responseBody = do
  existing = turbo.store.devWakeEvents.listRecent db senderUserId ()
  event =
    DevWakeEvent
      senderUserId
      channelId
      senderDeviceId
      senderHandle
      targetUserId
      targetDeviceId
      startedAt
      result
      statusCode
      responseBody
      now!
  updated = takeEnd 50 (existing ++ [event])
  _ = OrderedTable.write (turbo.store.devWakeEvents.tables.recentByUser db) senderUserId updated
  event

turbo.store.devWakeEvents.clearRecent : Database -> '{Exception, Storage, Remote} Nat
turbo.store.devWakeEvents.clearRecent db = do
  use List foreach size
  rows = Stream.toList (OrderedTable.toStream (turbo.store.devWakeEvents.tables.recentByUser db))
  _ = foreach (turbo.store.devWakeEvents.internal.clearRow db) rows
  size rows

turbo.store.devWakeEvents.internal.clearRow : Database -> (UserId, [DevWakeEvent]) ->{Exception, Storage, Remote} ()
turbo.store.devWakeEvents.internal.clearRow db =
  cases
    (userId, _) -> OrderedTable.write (turbo.store.devWakeEvents.tables.recentByUser db) userId []

turbo.service.dev.wakeEvents.internal.eventJson : DevWakeEvent -> Json
turbo.service.dev.wakeEvents.internal.eventJson =
  cases
    DevWakeEvent senderUserId channelId senderDeviceId senderHandle targetUserId targetDeviceId startedAt result statusCode responseBody recordedAt ->
      object.empty
        |> object.addText "senderUserId" (UserId.toText senderUserId)
        |> object.addText "channelId" (ChannelId.toText channelId)
        |> object.addText "senderDeviceId" (DeviceId.toText senderDeviceId)
        |> object.addText "senderHandle" senderHandle
        |> object.addText "targetUserId" (UserId.toText targetUserId)
        |> object.addText "targetDeviceId" (DeviceId.toText targetDeviceId)
        |> object.addText "startedAt" startedAt
        |> object.addText "result" result
        |> object.addText "statusCode" statusCode
        |> object.addOptionalText "responseBody" responseBody
        |> object.addText "recordedAt" (Instant.toText recordedAt)

turbo.service.dev.uploadWakeEvent : Database -> '{Route, Exception, Storage, Remote} ()
turbo.service.dev.uploadWakeEvent db = do
  use Parser /
  use object empty
  noCapture POST (s "v1" / s "dev" / s "wake-events")
  match requireUser db () with
    Left err -> unauthorized.json (empty |> addText "error" err)
    Right currentUser ->
      currentUserId =
        (User userId _ _ _ _) = currentUser
        userId
      fields = decodeJson (Decoder.object Decoder.text)
      senderUserIdText = Map.get "senderUserId" fields
      match
        (
          senderUserIdText,
          Map.get "channelId" fields,
          Map.get "senderDeviceId" fields,
          Map.get "senderHandle" fields,
          Map.get "targetUserId" fields,
          Map.get "targetDeviceId" fields,
          Map.get "startedAt" fields,
          Map.get "result" fields,
          Map.get "statusCode" fields
        )
      with
        (Some senderUserIdText, Some channelIdText, Some senderDeviceIdText, Some senderHandle, Some targetUserIdText, Some targetDeviceIdText, Some startedAt, Some result, Some statusCode) ->
          if UserId.toText currentUserId != senderUserIdText then
            unauthorized.json (empty |> addText "error" "wake event sender does not match current user")
          else
            event =
              turbo.store.devWakeEvents.appendRecent
                db
                currentUserId
                (ChannelId.fromText channelIdText)
                (DeviceId.fromText senderDeviceIdText)
                senderHandle
                (UserId.fromText targetUserIdText)
                (DeviceId.fromText targetDeviceIdText)
                startedAt
                result
                statusCode
                (Map.get "responseBody" fields)
                ()
            ok.json (empty |> addText "status" "uploaded" |> object.add "event" (turbo.service.dev.wakeEvents.internal.eventJson event))
        _ ->
          badRequest.json
            (empty |> addText "error" "missing senderUserId, channelId, senderDeviceId, senderHandle, targetUserId, targetDeviceId, startedAt, result, or statusCode")

turbo.service.dev.recentWakeEvents : Database -> '{Route, Exception, Storage, Remote} ()
turbo.service.dev.recentWakeEvents db = do
  use Parser /
  use object empty
  noCapture GET (s "v1" / s "dev" / s "wake-events" / s "recent")
  match requireUser db () with
    Left err -> unauthorized.json (empty |> addText "error" err)
    Right currentUser ->
      currentUserId =
        (User userId _ _ _ _) = currentUser
        userId
      events = turbo.store.devWakeEvents.listRecent db currentUserId ()
      ok.json
        (empty
          |> addText "status" "ok"
          |> object.add "events" (Json.array (List.map turbo.service.dev.wakeEvents.internal.eventJson events)))

type turbo.service.dev.internal.ResetSummary
  = ResetSummary Nat Nat Nat Nat Nat Nat Nat Nat Nat Nat Nat Nat

turbo.service.dev.internal.performReset : Database -> '{Remote, Storage, Exception} ResetSummary
turbo.service.dev.internal.performReset db = do
  use List foreach size
  use OrderedTable toStream
  runtimeRows = Stream.toList (toStream (byChannel db))
  _ = foreach (deleteRuntimeRow db) runtimeRows
  presenceRows = Stream.toList (toStream (presence.tables.byDevice db))
  _ = foreach (deletePresenceRow db) presenceRows
  tokenRows = Stream.toList (toStream (tokens.tables.byChannelUserDevice db))
  _ = foreach (deleteTokenRow db) tokenRows
  inviteIdRows = Stream.toList (toStream (invites.tables.byId db))
  _ = foreach (deleteInviteIdRow db) inviteIdRows
  inviteFromRows = Stream.toList (toStream (byFromCreatedAt db))
  _ = foreach (deleteInviteFromRow db) inviteFromRows
  inviteToRows = Stream.toList (toStream (byToCreatedAt db))
  _ = foreach (deleteInviteToRow db) inviteToRows
  membershipRows = Stream.toList (toStream (byChannelUser db))
  _ = foreach (deleteMembershipRow db) membershipRows
  sessionRows = Stream.toList (toStream (sessions.tables.byDevice db))
  _ = foreach (deleteSessionRow db) sessionRows
  channelRows = Stream.toList (toStream (channels.tables.byId db))
  _ = foreach (deleteChannelRow db) channelRows
  participantRows = Stream.toList (toStream (byParticipantCreatedAt db))
  _ = foreach (deleteChannelParticipantRow db) participantRows
  userPairRows = Stream.toList (toStream (byUserPair db))
  _ = foreach (deleteChannelUserPairRow db) userPairRows
  wakeEventRowCount = turbo.store.devWakeEvents.clearRecent db ()
  ResetSummary
    (size runtimeRows)
    (size presenceRows)
    (size tokenRows)
    (size inviteIdRows)
    (size inviteFromRows)
    (size inviteToRows)
    (size membershipRows)
    (size sessionRows)
    0
    (size channelRows)
    (size userPairRows)
    wakeEventRowCount

turbo.service.dev.internal.resetSummaryJson : Text -> ResetSummary -> Json
turbo.service.dev.internal.resetSummaryJson status =
  cases
    ResetSummary runtimeCount presenceCount tokenCount inviteIdCount inviteFromCount inviteToCount membershipCount sessionCount socketCount channelCount userPairCount wakeEventRowCount ->
      object.empty
        |> addText "status" status
        |> addNat "clearedTransmitStates" runtimeCount
        |> addNat "clearedPresenceEntries" presenceCount
        |> addNat "clearedTokenEntries" tokenCount
        |> addNat "clearedInviteByIdEntries" inviteIdCount
        |> addNat "clearedInviteByFromEntries" inviteFromCount
        |> addNat "clearedInviteByToEntries" inviteToCount
        |> addNat "clearedMemberships" membershipCount
        |> addNat "clearedSessions" sessionCount
        |> addNat "clearedSockets" socketCount
        |> addNat "clearedChannels" channelCount
        |> addNat "clearedChannelUserPairEntries" userPairCount
        |> addNat "clearedWakeEventRows" wakeEventRowCount

turbo.service.dev.resetAll : Database -> '{Route, Remote, Storage, Exception} ()
turbo.service.dev.resetAll db = do
  use Parser /
  noCapture POST (s "v1" / s "dev" / s "reset-all")
  summary = performReset db ()
  ok.json (resetSummaryJson "reset-all" summary)

turbo.service.dev.resetState : Database -> '{Route, Remote, Storage, Exception} ()
turbo.service.dev.resetState db = do
  use Parser /
  noCapture POST (s "v1" / s "dev" / s "reset-state")
  summary = performReset db ()
  ok.json (resetSummaryJson "reset" summary)

turbo.service.routes.dev : Database -> '{Route, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.routes.dev db =
  use Route or
  or
    (seed db)
    (or
      (resetAll db)
      (or
        (resetState db)
        (or
          (uploadDiagnostics db)
          (or
            (latestDiagnostics db)
            (or
              (latestDiagnosticsForCurrentUser db)
              (or (runtimeInspection db) (or (uploadWakeEvent db) (recentWakeEvents db))))))))
