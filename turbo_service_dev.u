turbo.service.dev.seed.internal.defaultUsers.doc = {{

``turbo.service.dev.seed.internal.defaultUsers`` is the canonical list of dev users seeded into the Turbo backend for local development.

*Also see:* {turbo.service.dev.seed}

}}
turbo.service.dev.seed.internal.defaultUsers : [(Text, Text)]
turbo.service.dev.seed.internal.defaultUsers =
  [
    ("@turbo-ios", "Turbo iOS"),
    ("@avery", "Avery"),
    ("@blake", "Blake"),
    ("@casey", "Casey"),
    ("@devin", "Devin"),
    ("@elliot", "Elliot"),
