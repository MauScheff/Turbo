turbo.service.routes.tests.examples : '{IO, Exception} [Result]
turbo.service.routes.tests.examples =
  do
    test.verify do
      use cloud simple
      setup _ = Database.default()
      server db = service.http db ()
      healthStatus = 
        catch do simple setup server (clientStatusGet "/v1/health")
      configStatus = 
        catch do simple setup server (clientStatusGet "/v1/config")
      seedStatus = 
        catch do simple setup server (clientStatusPost "/v1/dev/seed")
      resetStatus = 
        catch do simple setup server (clientStatusPost "/v1/dev/reset-state")
      heartbeatStatus = 
        catch do
          simple setup server (clientStatusPost "/v1/presence/heartbeat")
      incomingInvitesStatus = 
        catch do simple setup server (clientStatusGet "/v1/invites/incoming")
      channelStateStatus = 
        catch do
          simple
            setup server (clientStatusGet "/v1/channels/example/state/device")
      ensureEqual healthStatus (Right 200)
      ensureEqual configStatus (Right 200)
      ensureEqual seedStatus (Right 200)
      ensureEqual resetStatus (Right 200)
      ensureEqual heartbeatStatus (Right 401)
      ensureEqual incomingInvitesStatus (Right 401)
      ensureEqual channelStateStatus (Right 401)

