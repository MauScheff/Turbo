turbo.service.invites.incoming :
  Database -> '{Route, Exception, Storage, Remote} ()
turbo.service.invites.incoming db =
  do
    use Parser /
    noCapture GET (s "v1" / s "invites" / s "incoming")
    currentUser = requireUser db ()
    currentUserId =
      (User userId _ _ _ _) = currentUser
      userId
    invites = listIncomingPending db currentUserId ()
    inviteJsons =
      List.map (invite -> inviteJson db currentUserId invite ()) invites
    ok.json (Json.array inviteJsons)

turbo.service.invites.incoming.doc : Doc
turbo.service.invites.incoming.doc =
  {{
  `` incoming db `` lists pending incoming requests for the current user,
  newest first.
  
  **Also see:** {outgoing}
  }}

turbo.service.invites.internal.directionText : UserId -> Invite -> Text
turbo.service.invites.internal.directionText currentUserId = cases
  Invite _ fromUserId _ _ _ _ _ _ ->
    if UserId.toText fromUserId Text.== UserId.toText currentUserId then
      "outgoing"
    else "incoming"

turbo.service.invites.internal.inviteJson :
  Database -> UserId -> Invite -> '{Exception, Remote} Json
turbo.service.invites.internal.inviteJson db currentUserId invite =
  do
    use users getById
    fromHandle =
      (Invite _ fromUserId _ _ _ _ _ _) = invite
      match getById db fromUserId () with
        Some (User _ handleText _ _ _) -> Some handleText
        None                           -> None
    toHandle =
      (Invite _ _ toUserId _ _ _ _ _) = invite
      match getById db toUserId () with
        Some (User _ handleText _ _ _) -> Some handleText
        None                           -> None
    (Invite inviteId fromUserId toUserId channelId status requestCount createdAt updatedAt) =
      invite
    statusText = match status with
      Pending                -> "pending"
      Connected              -> "connected"
      Declined               -> "declined"
      InviteStatus.Cancelled -> "cancelled"
    object.empty
      |> addText "inviteId" (InviteId.toText inviteId)
      |> addText "fromUserId" (UserId.toText fromUserId)
      |> addOptionalText "fromHandle" fromHandle
      |> addText "toUserId" (UserId.toText toUserId)
      |> addOptionalText "toHandle" toHandle
      |> addText "channelId" (ChannelId.toText channelId)
      |> addText "status" statusText
      |> addText "direction" (directionText currentUserId invite)
      |> addNat "requestCount" requestCount
      |> addText "createdAt" (Instant.toText createdAt)
      |> addOptionalText "updatedAt" (Optional.map Instant.toText updatedAt)

turbo.service.invites.outgoing :
