turbo.service.web db = Route.or (ws db) (service.http db)

turbo.service.web.doc : Doc
turbo.service.web.doc =
  {{
  `` web db `` combines Turbo's HTTP control plane with the websocket signaling
  endpoint.
  
  This is the shared route intended for both local serving and cloud
  deployment.
  
  **Also see:** {service.http}, {ws}
  }}

turbo.service.ws.doc : Doc
turbo.service.ws.doc =
  {{
  `` ws db `` serves Turbo's authenticated websocket signaling endpoint at
  `/v1/ws`.
  
  The websocket handshake uses the existing dev auth header plus a required
  `deviceId` query parameter. Each incoming text frame must be a serialized
  {type SignalEnvelope}.
  
  **Also see:** {web}
  }}



---- Anything below this line is ignored by Unison.


type turbo.domain.InviteIdTag = InviteIdTag

type turbo.domain.InviteId = TurboInviteId Text turbo.domain.InviteIdTag

type turbo.domain.InviteStatus
  = Pending
  | Connected
  | Declined
  | Cancelled

type turbo.domain.Invite
  = Invite
      turbo.domain.InviteId
      turbo.domain.UserId
      turbo.domain.UserId
      turbo.domain.ChannelId
      turbo.domain.InviteStatus
      Nat
      Instant
      (Optional Instant)

type turbo.domain.UserAvailability
  = Available
  | Busy turbo.domain.ChannelId
  | Offline

type turbo.domain.ChannelStateStatus
  = Idle
  | Requested
  | IncomingRequest
  | WaitingForPeer
  | Ready
  | SelfTransmitting
  | PeerTransmitting

turbo.domain.InviteId.toText.doc = {{

``InviteId.toText inviteId`` returns the raw text inside `inviteId`.

*Also see:* {turbo.domain.UserId.toText}

}}
turbo.domain.InviteId.toText : turbo.domain.InviteId -> Text
turbo.domain.InviteId.toText = cases
  TurboInviteId text _ -> text

turbo.domain.InviteId.fromText.doc = {{

``InviteId.fromText text`` wraps `text` as an invite id.

*Also see:* {turbo.domain.InviteId.toText}

}}
turbo.domain.InviteId.fromText : Text -> turbo.domain.InviteId
turbo.domain.InviteId.fromText text = TurboInviteId text InviteIdTag

test> turbo.domain.InviteId.toText.tests.examples = test.verify do
  labeled "roundtrips a simple invite id" do
    test.ensureEqual
      (turbo.domain.InviteId.toText (turbo.domain.InviteId.fromText "invite-1"))
      "invite-1"

test> turbo.domain.InviteId.toText.tests.props = test.verify do
  Each.repeat 100
  suffix = Nat.toText (Random.natIn 0 1000000)
  raw = "invite-" ++ suffix
  labeled "toText inverts fromText" do
    test.ensureEqual
      (turbo.domain.InviteId.toText (turbo.domain.InviteId.fromText raw))
      raw

turbo.store.presence.heartbeat.doc = {{

``turbo.store.presence.heartbeat db deviceId userId`` marks `deviceId` online without discarding its current active channel, if any.

This is used for app-level online/offline presence independent of channel join state.

*Also see:* {turbo.store.presence.upsert}, {turbo.store.users.availability}

}}
turbo.store.presence.heartbeat :
  Database
  -> turbo.domain.DeviceId
  -> turbo.domain.UserId
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} turbo.domain.DevicePresence
turbo.store.presence.heartbeat db deviceId userId = do
  existingChannelId = match turbo.store.presence.get db deviceId () with
    None -> None
    Some (DevicePresence _ _ _ currentChannelId _) -> currentChannelId
  turbo.store.presence.upsert db deviceId userId Online existingChannelId ()

turbo.store.presence.clearActiveChannel.doc = {{

``turbo.store.presence.clearActiveChannel db deviceId userId`` keeps `deviceId` online but clears any active channel binding.

*Also see:* {turbo.store.presence.heartbeat}, {turbo.store.presence.upsert}

}}
turbo.store.presence.clearActiveChannel :
  Database
  -> turbo.domain.DeviceId
  -> turbo.domain.UserId
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} turbo.domain.DevicePresence
turbo.store.presence.clearActiveChannel db deviceId userId =
  turbo.store.presence.upsert db deviceId userId Online None

turbo.store.users.availability.doc = {{

``turbo.store.users.availability db userId`` derives whether `userId` is online and available, already busy in another channel, or offline.

*Also see:* {turbo.store.presence.getForUser}

}}
turbo.store.users.availability :
  Database
  -> turbo.domain.UserId
  -> '{Exception, Remote} turbo.domain.UserAvailability
turbo.store.users.availability db userId = do
  match turbo.store.presence.getForUser db userId () with
    None -> turbo.domain.UserAvailability.Offline
    Some (DevicePresence _ _ status currentChannelId _) ->
      match status with
        turbo.domain.DevicePresenceStatus.Offline -> turbo.domain.UserAvailability.Offline
        turbo.domain.DevicePresenceStatus.Online ->
          match currentChannelId with
            None -> Available
            Some channelId -> Busy channelId

turbo.store.invites.createOrReuse.doc = {{

``turbo.store.invites.createOrReuse db fromUserId toUserId channelId`` creates a pending invite unless one already exists for the same sender, receiver, and channel.

If a pending invite already exists, it is reused and its `requestCount` is incremented.

*Also see:* {turbo.store.invites.pendingFromTo}, {turbo.store.invites.listIncomingPending}

}}
turbo.store.invites.createOrReuse :
  Database
  -> turbo.domain.UserId
  -> turbo.domain.UserId
  -> turbo.domain.ChannelId
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} turbo.domain.Invite
turbo.store.invites.createOrReuse db fromUserId toUserId channelId = do
  existing = turbo.store.invites.pendingFromTo db fromUserId toUserId channelId ()
  match existing with
    Some (Invite inviteId existingFromUserId existingToUserId existingChannelId status requestCount createdAt _) ->
      table = turbo.store.invites.tables.byId db
      byToCreatedAt = turbo.store.invites.tables.byToCreatedAt db
      byFromCreatedAt = turbo.store.invites.tables.byFromCreatedAt db
      updatedAt = now!
      updated =
        Invite
          inviteId
          existingFromUserId
          existingToUserId
          existingChannelId
          status
          (requestCount + 1)
          createdAt
          (Some updatedAt)
      _ = OrderedTable.write table inviteId updated
      _ = OrderedTable.write byToCreatedAt (existingToUserId, createdAt, inviteId) updated
      _ = OrderedTable.write byFromCreatedAt (existingFromUserId, createdAt, inviteId) updated
      updated
    None ->
      table = turbo.store.invites.tables.byId db
      byToCreatedAt = turbo.store.invites.tables.byToCreatedAt db
      byFromCreatedAt = turbo.store.invites.tables.byFromCreatedAt db
      now = now!
      transact (OrderedTable.database table) do
        inviteId = turbo.domain.InviteId.fromText (Random.bytes 20 |> Bytes.base32Hex)
        invite = Invite inviteId fromUserId toUserId channelId Pending 1 now None
        _ = OrderedTable.write.tx table inviteId invite
        _ = OrderedTable.write.tx byToCreatedAt (toUserId, now, inviteId) invite
        _ = OrderedTable.write.tx byFromCreatedAt (fromUserId, now, inviteId) invite
        invite

turbo.store.invites.getById.doc = {{

``turbo.store.invites.getById db inviteId`` looks up an invite by backend id.

*Also see:* {turbo.store.invites.createOrReuse}, {turbo.store.invites.markCancelled}

}}
turbo.store.invites.getById :
  Database
  -> turbo.domain.InviteId
  -> '{Exception, Remote} Optional turbo.domain.Invite
turbo.store.invites.getById db inviteId = do
  OrderedTable.tryRead (turbo.store.invites.tables.byId db) inviteId

turbo.store.invites.pendingFromTo.doc = {{

``turbo.store.invites.pendingFromTo db fromUserId toUserId channelId`` returns the current pending invite for that exact direction, if one exists.

*Also see:* {turbo.store.invites.pendingBetween}

}}
turbo.store.invites.pendingFromTo :
  Database
  -> turbo.domain.UserId
  -> turbo.domain.UserId
  -> turbo.domain.ChannelId
  -> '{Exception, Remote} Optional turbo.domain.Invite
turbo.store.invites.pendingFromTo db fromUserId toUserId channelId = do
  pendingInvites = turbo.store.invites.listOutgoingPending db fromUserId ()
  List.find
    (cases
      Invite _ candidateFromUserId candidateToUserId candidateChannelId _ _ _ _ ->
        sameFrom = (Text.==) (turbo.domain.UserId.toText candidateFromUserId) (turbo.domain.UserId.toText fromUserId)
        sameTo = (Text.==) (turbo.domain.UserId.toText candidateToUserId) (turbo.domain.UserId.toText toUserId)
        sameChannel = (Text.==) (turbo.domain.ChannelId.toText candidateChannelId) (turbo.domain.ChannelId.toText channelId)
        sameFrom && sameTo && sameChannel)
    pendingInvites

turbo.store.invites.pendingBetween.doc = {{

``turbo.store.invites.pendingBetween db userA userB channelId`` returns any pending invite between the two users for `channelId`, regardless of direction.

*Also see:* {turbo.store.invites.pendingFromTo}

}}
turbo.store.invites.pendingBetween :
  Database
  -> turbo.domain.UserId
  -> turbo.domain.UserId
  -> turbo.domain.ChannelId
  -> '{Exception, Remote} Optional turbo.domain.Invite
turbo.store.invites.pendingBetween db userA userB channelId = do
  match turbo.store.invites.pendingFromTo db userA userB channelId () with
    Some invite -> Some invite
    None -> turbo.store.invites.pendingFromTo db userB userA channelId ()

turbo.store.invites.listIncomingPending.doc = {{

``turbo.store.invites.listIncomingPending db userId`` returns pending inbound invites for `userId`, newest first.

*Also see:* {turbo.store.invites.listOutgoingPending}

}}
turbo.store.invites.listIncomingPending :
  Database
  -> turbo.domain.UserId
  -> '{Exception, Remote} [turbo.domain.Invite]
turbo.store.invites.listIncomingPending db userId = do
  rows =
    Stream.toList
      (Stream.filter
        (cases
          ((candidateToUserId, _, _), Invite _ _ _ _ status _ _ _) ->
            sameUser = (Text.==) (turbo.domain.UserId.toText candidateToUserId) (turbo.domain.UserId.toText userId)
            isPending = match status with
              Pending -> true
              _ -> false
            sameUser && isPending)
        (OrderedTable.toStream (turbo.store.invites.tables.byToCreatedAt db)))
  List.map (cases (_, invite) -> invite) (List.reverse rows)

turbo.store.invites.listOutgoingPending.doc = {{

``turbo.store.invites.listOutgoingPending db userId`` returns pending outbound invites for `userId`, newest first.

*Also see:* {turbo.store.invites.listIncomingPending}

}}
turbo.store.invites.listOutgoingPending :
  Database
  -> turbo.domain.UserId
  -> '{Exception, Remote} [turbo.domain.Invite]
turbo.store.invites.listOutgoingPending db userId = do
  rows =
    Stream.toList
      (Stream.filter
        (cases
          ((candidateFromUserId, _, _), Invite _ _ _ _ status _ _ _) ->
            sameUser = (Text.==) (turbo.domain.UserId.toText candidateFromUserId) (turbo.domain.UserId.toText userId)
            isPending = match status with
              Pending -> true
              _ -> false
            sameUser && isPending)
        (OrderedTable.toStream (turbo.store.invites.tables.byFromCreatedAt db)))
  List.map (cases (_, invite) -> invite) (List.reverse rows)

turbo.store.invites.markConnectedForChannel.doc = {{

``turbo.store.invites.markConnectedForChannel db userA userB channelId`` marks the pending invite between `userA` and `userB` for `channelId` as connected, if one exists.

*Also see:* {turbo.store.invites.markDeclined}, {turbo.store.invites.markCancelled}

}}
turbo.store.invites.markConnectedForChannel :
  Database
  -> turbo.domain.UserId
  -> turbo.domain.UserId
  -> turbo.domain.ChannelId
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} Optional turbo.domain.Invite
turbo.store.invites.markConnectedForChannel db userA userB channelId = do
  match turbo.store.invites.pendingBetween db userA userB channelId () with
    None -> None
    Some (Invite inviteId fromUserId toUserId inviteChannelId _ requestCount createdAt _) ->
      updatedAt = now!
      updated = Invite inviteId fromUserId toUserId inviteChannelId Connected requestCount createdAt (Some updatedAt)
      _ = OrderedTable.write (turbo.store.invites.tables.byId db) inviteId updated
      _ = OrderedTable.write (turbo.store.invites.tables.byToCreatedAt db) (toUserId, createdAt, inviteId) updated
      _ = OrderedTable.write (turbo.store.invites.tables.byFromCreatedAt db) (fromUserId, createdAt, inviteId) updated
      Some updated

turbo.store.invites.markDeclined.doc = {{

``turbo.store.invites.markDeclined db inviteId`` marks a pending invite as declined.

}}
turbo.store.invites.markDeclined :
  Database
  -> turbo.domain.InviteId
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} Optional turbo.domain.Invite
turbo.store.invites.markDeclined db inviteId =
  turbo.store.invites.internal.updateStatus db inviteId Declined

turbo.store.invites.markCancelled.doc = {{

``turbo.store.invites.markCancelled db inviteId`` marks a pending invite as cancelled by the sender.

}}
turbo.store.invites.markCancelled :
  Database
  -> turbo.domain.InviteId
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} Optional turbo.domain.Invite
turbo.store.invites.markCancelled db inviteId =
  turbo.store.invites.internal.updateStatus db inviteId Cancelled

turbo.store.invites.internal.updateStatus :
  Database
  -> turbo.domain.InviteId
  -> turbo.domain.InviteStatus
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} Optional turbo.domain.Invite
turbo.store.invites.internal.updateStatus db inviteId nextStatus = do
  table = turbo.store.invites.tables.byId db
  match OrderedTable.tryRead table inviteId with
    None -> None
    Some (Invite _ fromUserId toUserId channelId currentStatus requestCount createdAt _) ->
      updatedAt = now!
      status = match currentStatus with
        Pending -> nextStatus
        _ -> currentStatus
      updated = Invite inviteId fromUserId toUserId channelId status requestCount createdAt (Some updatedAt)
      _ = OrderedTable.write table inviteId updated
      _ = OrderedTable.write (turbo.store.invites.tables.byToCreatedAt db) (toUserId, createdAt, inviteId) updated
      _ = OrderedTable.write (turbo.store.invites.tables.byFromCreatedAt db) (fromUserId, createdAt, inviteId) updated
      Some updated

turbo.store.invites.tables.byId :
  Database
  -> OrderedTable turbo.domain.InviteId turbo.domain.Invite
turbo.store.invites.tables.byId db =
  OrderedTable.named db "turboInvitesById_v1" Universal.ordering

turbo.store.invites.tables.byToCreatedAt :
  Database
  -> OrderedTable (turbo.domain.UserId, Instant, turbo.domain.InviteId) turbo.domain.Invite
turbo.store.invites.tables.byToCreatedAt db =
  OrderedTable.named db "turboInvitesByToCreatedAt_v1" Universal.ordering

turbo.store.invites.tables.byFromCreatedAt :
  Database
  -> OrderedTable (turbo.domain.UserId, Instant, turbo.domain.InviteId) turbo.domain.Invite
turbo.store.invites.tables.byFromCreatedAt db =
  OrderedTable.named db "turboInvitesByFromCreatedAt_v1" Universal.ordering
