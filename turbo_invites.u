turbo.service.http.doc : Doc
turbo.service.http.doc =
  {{
  {{ docExample 1 do db -> service.http db }} combines Turbo's first HTTP
  control-plane routes.
  
  This initial slice covers dev auth, user lookup, device registration, and
  stable direct channel creation.
  }}

turbo.service.httpWithConfig :
  Text
  -> Boolean
  -> Database
  -> '{Route, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.httpWithConfig mode supportsWebSocket db =
  use Route or
  or
    health
    (or
      (service.config mode supportsWebSocket)
      (or
        (seed db)
        (or
          (resetState db)
          (or
            (service.presence.heartbeat db)
            (or
              (session db)
              (or
                (service.devices.register db)
                (or
                  (users.byHandle db)
                  (or
                    (presenceByHandle db)
                    (or
                      (invites.create db)
                      (or
                        (incoming db)
                        (or
                          (outgoing db)
                          (or
                            (invites.accept db)
                            (or
                              (decline db)
                              (or
                                (invites.cancel db)
                                (or
                                  (channels.direct db)
                                  (or
                                    (channels.join db)
                                    (or
                                      (leave db)
                                      (or
                                        (channels.state db)
                                        (or
                                          (ephemeralToken db)
                                          (or
                                            (channels.beginTransmit db)
                                            (or
                                              (channels.renewTransmit db)
                                              (or
                                                (channels.endTransmit db)
                                                (readiness db)))))))))))))))))))))))

turbo.service.httpWithConfig.doc : Doc
turbo.service.httpWithConfig.doc =
  {{
  {{
  docExample 3 do
    mode supportsWebSocket db -> httpWithConfig mode supportsWebSocket db }}
  combines Turbo's HTTP control-plane routes with a small runtime capability
  endpoint.
  
  The capability endpoint lets clients adapt cleanly between local HTTP-only
  development and cloud websocket-capable serving.
  
  **Also see:** {{ docLink (docEmbedTermLink do service.config) }}, {{
  docLink (docEmbedTermLink do service.http) }}
  }}

turbo.service.invites.accept :
  Database -> '{Route, Exception, Storage, Remote} ()
turbo.service.invites.accept db =
  do
    use Parser /
    use Text ==
    use UserId toText
    use object empty
    inviteIdText = route POST (s "v1" / s "invites" / Parser.text / s "accept")
    currentUser = requireUser db ()
    currentUserId =
      (User userId _ _ _ _) = currentUser
      userId
    inviteId = InviteId.fromText inviteIdText
    match invites.getById db inviteId () with
      None -> notFound.json (empty |> addText "error" "invite not found")
      Some invite ->
        (Invite _ _ toUserId _ status _ _ _) = invite
        if Boolean.not (toText toUserId == toText currentUserId) then
          unauthorized.json (empty |> addText "error" "not invite recipient")
        else
          inviteJson = internal.inviteJson db currentUserId invite ()
          ok.json
            (inviteJson
              |> addBoolean "accepted" true
              |> (addBoolean "pendingJoin" match status with
                   Pending -> true
                   _       -> false))

turbo.service.invites.accept.doc : Doc
turbo.service.invites.accept.doc =
  {{
  `` invites.accept db `` acknowledges an incoming invite for the current user.
  
  The invite remains pending until both peers have actually joined the channel;
  the join step is still authoritative for transitioning to connected state.
  
  **Also see:** {channels.join}, {invites.getById}
  }}

turbo.service.invites.cancel :
  Database -> '{Route, Exception, Storage, Remote, Random} ()
turbo.service.invites.cancel db =
  do
    use Parser /
    use Text ==
    use UserId toText
    use object empty
    inviteIdText = route POST (s "v1" / s "invites" / Parser.text / s "cancel")
    currentUser = requireUser db ()
    currentUserId =
      (User userId _ _ _ _) = currentUser
      userId
    inviteId = InviteId.fromText inviteIdText
    match invites.getById db inviteId () with
      None -> notFound.json (empty |> addText "error" "invite not found")
      Some invite ->
        (Invite _ fromUserId _ _ _ _ _ _) = invite
        if Boolean.not (toText fromUserId == toText currentUserId) then
          unauthorized.json (empty |> addText "error" "not invite sender")
        else
          match markCancelled db inviteId () with
            None -> notFound.json (empty |> addText "error" "invite not found")
            Some updated -> ok.json (inviteJson db currentUserId updated ())

turbo.service.invites.cancel.doc : Doc
turbo.service.invites.cancel.doc =
  {{
  `` invites.cancel db `` cancels an outgoing pending invite for the current
  user.
  
  **Also see:** {markCancelled}
  }}

turbo.service.invites.create :
  Database -> '{Route, Exception, Storage, Remote, Random} ()
turbo.service.invites.create db =
  do
    use Map get
    use Parser /
    use Text ==
    use UserId toText
    use object empty
    noCapture POST (s "v1" / s "invites")
    currentUser = requireUser db ()
    currentUserId =
      (User userId _ _ _ _) = currentUser
      userId
    fields = decodeJson (Decoder.object Decoder.text)
    resolvedOther = match get "otherUserId" fields with
      Some otherUserIdText -> Some (UserId.fromText otherUserIdText)
      None                 ->
        match get "otherHandle" fields with
          None             -> None
          Some otherHandle ->
            match getByHandle db otherHandle () with
              None                            -> None
              Some (User otherUserId _ _ _ _) -> Some otherUserId
    match resolvedOther with
      None ->
        badRequest.json
          (empty |> addText "error" "missing otherUserId or otherHandle")
      Some otherUserId ->
        if toText otherUserId == toText currentUserId then
          badRequest.json (empty |> addText "error" "cannot invite self")
        else
          channel = getOrCreateDirect db currentUserId otherUserId ()
          channelId =
            (DirectChannel channelId _ _ _) = channel
            channelId
          invite = createOrReuse db currentUserId otherUserId channelId ()
          availability = users.availability db otherUserId ()
          inviteJson = internal.inviteJson db currentUserId invite ()
          ok.json
            (inviteJson
              |> addText "targetAvailability" (availabilityText availability)
              |> (addBoolean "shouldAutoJoinPeer" match availability with
                   Available -> true
                   _         -> false))

turbo.service.invites.create.doc : Doc
turbo.service.invites.create.doc =
  {{
  `` invites.create db `` creates or reuses a pending direct invite.
  
  If the target user is online and idle, the response indicates that the peer
  should auto-join when it notices the incoming request.
  
  **Also see:** {createOrReuse}, {incoming}
