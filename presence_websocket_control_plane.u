turbo.service.ws.internal.executePresenceCommand :
  Database
  -> User
  -> Optional DeviceId
  -> PresenceCommandRequest
  -> '{Config, Exception, Http, Storage, Remote, Random} ControlCommandRouteResult
turbo.service.ws.internal.executePresenceCommand
  db
  currentUser
  websocketDeviceIdOpt = cases
    PresenceCommandRequest _ kind fields ->
      do match kind with
        PresenceHeartbeat ->
          turbo.service.presence.internal.heartbeatControlCommand
            db
            currentUser
            websocketDeviceIdOpt
            fields
            ()
        PresenceBackground ->
          turbo.service.presence.internal.backgroundControlCommand
            db
            currentUser
            websocketDeviceIdOpt
            fields
            ()
        PresenceOffline ->
          turbo.service.presence.internal.offlineControlCommand
            db
            currentUser
            websocketDeviceIdOpt
            fields
            ()

turbo.service.ws.internal.sendPresenceCommandResponse :
  Database
  -> User
  -> DeviceId
  -> WebSocket
  -> PresenceCommandRequest
  -> '{Config, Exception, Http, Storage, Remote, WebSockets, Random} ()
turbo.service.ws.internal.sendPresenceCommandResponse
  db
  currentUser
  currentDeviceId
  currentSocket
  request = do
    use WebSockets send
    (PresenceCommandRequest requestId kind _) = request
    result =
      turbo.service.ws.internal.executePresenceCommand
        db
        currentUser
        (Some currentDeviceId)
        request
        ()
    body =
      turbo.service.ws.internal.presenceCommandResponseJson
        requestId
        kind
        result
    send currentSocket (TextMessage (Json.toText body))

turbo.service.ws.internal.handleMessage :
  Database
  -> User
  -> DeviceId
  -> Text
  -> WebSocket
  -> websockets.Message
  -> '{Config, Exception, Http, Storage, Remote, WebSockets, Random} ()
turbo.service.ws.internal.handleMessage
  db currentUser currentDeviceId currentSessionId currentSocket = cases
  TextMessage text ->
    do
      currentUserId =
        (User userId _ _ _ _) = currentUser
        userId
      match turbo.service.ws.internal.controlCommandFrameFromText text with
        ParsedControlCommandFrame request ->
          turbo.service.ws.internal.sendControlCommandResponse
            db
            currentUser
            currentDeviceId
            currentSocket
            request
            ()
        InvalidControlCommandFrame err ->
          turbo.service.ws.internal.sendInvalidControlCommandResponse
            currentSocket
            err
            ()
        NotControlCommandFrame ->
          match turbo.service.ws.internal.presenceCommandFrameFromText text with
            ParsedPresenceCommandFrame request ->
              turbo.service.ws.internal.sendPresenceCommandResponse
                db
                currentUser
                currentDeviceId
                currentSocket
                request
                ()
            InvalidPresenceCommandFrame err ->
              turbo.service.ws.internal.sendInvalidControlCommandResponse
                currentSocket
                err
                ()
            NotPresenceCommandFrame ->
              turbo.service.ws.internal.handleSignalMessage
                db
                currentUserId
                currentDeviceId
                currentSessionId
                currentSocket
                text
                ()
  _ ->
    do
      WebSockets.send
        currentSocket
        (TextMessage
          (Json.toText
            (object.empty
              |> addText "error" "binary websocket messages are not supported")))
