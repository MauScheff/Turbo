turbo.service.channels.internal.sendPeerLeftNoticeIfPossible :
  Database
  -> ChannelId
  -> UserId
  -> DeviceId
  -> UserId
  -> Text
  -> '{Exception, Storage, Remote, WebSockets, Random} ()
turbo.service.channels.internal.sendPeerLeftNoticeIfPossible
  db
  channelId
  currentUserId
  currentDeviceId
  peerUserId
  leftAt =
  do
    use object empty
    peerDeviceIdOpt =
      turbo.service.channels.internal.peerSetupTargetDeviceId
        db
        peerUserId
        channelId
        ()
    match peerDeviceIdOpt with
      None -> ()
      Some peerDeviceId ->
        match turbo.store.sockets.lookup db peerDeviceId () with
          None -> ()
          Some peerSocket ->
            noticeJson =
              empty
                |> addText "status" "peer-left"
                |> addText "channelId" (ChannelId.toText channelId)
                |> addText "fromUserId" (UserId.toText currentUserId)
                |> addText "fromDeviceId" (DeviceId.toText currentDeviceId)
                |> addText "reason" "leave"
                |> addText "leftAt" leftAt
            _ =
              catch do
                WebSockets.send
                  peerSocket
                  (TextMessage (Json.toText noticeJson))
            ()

turbo.service.channels.internal.leaveControlCommand :
  Database
  -> User
  -> Text
  -> Map Text Text
  -> '{Config, Exception, Http, Storage, Remote, WebSockets, Random}
       ControlCommandRouteResult
turbo.service.channels.internal.leaveControlCommand
  db
  currentUser
  channelIdText
  fields =
  do
    use Map get
    use memberships remove
    currentUserId =
      (User userId _ _ _ _) = currentUser
      userId
    currentHandle =
      (User _ handleText _ _ _) = currentUser
      handleText
    currentDisplayName =
      (User _ _ displayName _ _) = currentUser
      displayName
    operationId = get "operationId" fields
    channelId = ChannelId.fromText channelIdText
    match get "deviceId" fields with
      None -> ControlCommandRouteBadRequest "missing deviceId"
      Some deviceIdText ->
        devTraffic = isWhitelistedDevHandle (Some currentHandle) ()
        deviceId = DeviceId.fromText deviceIdText
        targetKey = channelTargetKey channelId
        replayPlan =
          controlCommands.replayPlan
            db
            currentUserId
            deviceId
            operationId
            StalePresenceRepairFailed
            targetKey
            ()
        leftJson =
          object.empty
            |> addText "channelId" channelIdText
            |> addText "deviceId" deviceIdText
            |> addText "status" "left"
            |> addOptionalText "operationId" operationId
        match replayPlan with
          RejectControlCommand err -> ControlCommandRouteBadRequest err
          ReplayControlCommand -> ControlCommandRouteOk leftJson
          RunControlCommand ->
            leftAt = Instant.toText now!
            _ = runtime.endTransmit db channelId currentUserId deviceId ()
            _ = clearActiveChannel db deviceId currentUserId ()
            _ = remove db channelId currentUserId ()
            peerUserIdOpt =
              match OrderedTable.tryRead (channels.tables.byId db) channelId with
                Some channel@(DirectChannel _ _ _ _) ->
                  turbo.service.presence.internal.otherUserIdForDirectChannel
                    currentUserId
                    channel
                None -> None
            _ =
              match peerUserIdOpt with
                Some peerUserId ->
                  turbo.service.channels.internal.sendPeerLeftNoticeIfPossible
                    db
                    channelId
                    currentUserId
                    deviceId
                    peerUserId
                    leftAt
                    ()
                None -> ()
            _ =
              match peerUserIdOpt with
                Some peerUserId ->
                  sendLeavePushIfPossible
                    db
                    channelId
                    currentHandle
                    currentDisplayName
                    currentUserId
                    deviceId
                    peerUserId
                    leftAt
                    ()
                None -> ()
            _ =
              recordSucceeded
                db
                currentUserId
                deviceId
                operationId
                StalePresenceRepairFailed
                targetKey
                ()
            _ =
              internal.send
                "backend.channel.left"
                "backend"
                "notice"
                currentUserId
                (Some currentHandle)
                (Some deviceId)
                (Some channelId)
                peerUserIdOpt
                None
                None
                None
                None
                (Some "leave")
                None
                (Some "channel left")
                operationId
                devTraffic
                false
                ()
            ControlCommandRouteOk leftJson

turbo.service.ws.internal.executeControlCommand :
  Database
  -> User
  -> Optional DeviceId
  -> ControlCommandRequest
  -> '{Config, Exception, Http, Storage, Remote, WebSockets, Random}
       ControlCommandRouteResult
turbo.service.ws.internal.executeControlCommand
  db
  currentUser
  websocketDeviceIdOpt = cases
    ControlCommandRequest _ kind fields ->
      do match kind with
        NoConnectedSessionRepairNeeded -> createControlCommand db currentUser fields ()
        ConnectedSessionRepairSucceeded ->
          match Map.get "channelId" fields with
            None -> ControlCommandRouteBadRequest "missing channelId"
            Some channelIdText ->
              joinControlCommandWithConnectedDevice
                db
                currentUser
                websocketDeviceIdOpt
                channelIdText
                fields
                ()
        ConnectedSessionRepairFailed ->
          match Map.get "channelId" fields with
            None -> ControlCommandRouteBadRequest "missing channelId"
            Some channelIdText ->
              leaveControlCommand db currentUser channelIdText fields ()

turbo.service.ws.internal.sendControlCommandResponse :
  Database
  -> User
  -> DeviceId
  -> WebSocket
  -> ControlCommandRequest
  -> '{Config, Exception, Http, Storage, Remote, WebSockets, Random} ()
turbo.service.ws.internal.sendControlCommandResponse
  db
  currentUser
  currentDeviceId
  currentSocket
  request =
  do
    (ControlCommandRequest requestId kind _) = request
    result =
      turbo.service.ws.internal.executeControlCommand
        db
        currentUser
        (Some currentDeviceId)
        request
        ()
    body = websocketResponseJson requestId kind result
    WebSockets.send currentSocket (TextMessage (Json.toText body))
