turbo.service.dev.resetAll.doc = {{

``turbo.service.dev.resetAll db`` clears Turbo's entire dev world.

It first clears relationship and runtime state through the canonical store
mutations for every known user, so pending invites do not survive the reset via
stale secondary rows. It then removes the remaining dev runtime bookkeeping,
including the per-user channel projection.

Use this when you need a deterministic blank backend before a test run.

*Also see:* {turbo.service.dev.resetState}, {turbo.service.dev.seed}

}}
turbo.service.dev.resetAll :
  Database
  -> '{Route, Exception, Storage, Remote, Random} ()
turbo.service.dev.resetAll db = do
  use List map size
  use OrderedTable database toStream
  use OrderedTable.delete tx
  use Parser /
  use Stream toList
  noCapture POST (s "v1" / s "dev" / s "reset-all")

  userTable = store.users.tables.byId db
  users = map (cases (_, user) -> user) (toList (toStream userTable))
  resetSummaries =
    map
      (cases
        User userId _ _ _ _ -> turbo.service.dev.internal.resetUserState db userId ())
      users

  clearedOutgoingInvites =
    List.foldLeft
      (total summary ->
        match summary with
          ResetStateSummary cancelledOutgoing _ _ _ _ _ ->
            total + cancelledOutgoing)
      0
      resetSummaries

  declinedIncomingInvites =
    List.foldLeft
      (total summary ->
        match summary with
          ResetStateSummary _ declinedIncoming _ _ _ _ ->
            total + declinedIncoming)
      0
      resetSummaries

  runtimeTable = byChannel db
  runtimeKeys = map (cases (channelId, _) -> channelId) (toList (toStream runtimeTable))
  _ = transact (database runtimeTable) do List.foreach runtimeKeys key -> tx runtimeTable key

  presenceTable = presence.tables.byDevice db
  presenceKeys = map (cases (deviceId, _) -> deviceId) (toList (toStream presenceTable))
  _ = transact (database presenceTable) do List.foreach presenceKeys key -> tx presenceTable key

  tokenTable = byChannelUserDevice db
  tokenKeys = map (cases (key, _) -> key) (toList (toStream tokenTable))
  _ = transact (database tokenTable) do List.foreach tokenKeys key -> tx tokenTable key

  inviteById = invites.tables.byId db
  inviteByIdKeys = map (cases (inviteId, _) -> inviteId) (toList (toStream inviteById))
  inviteByTo = byToCreatedAt db
  inviteByToKeys = map (cases (key, _) -> key) (toList (toStream inviteByTo))
  inviteByFrom = byFromCreatedAt db
  inviteByFromKeys = map (cases (key, _) -> key) (toList (toStream inviteByFrom))

  remainingPendingInvites =
    size
      (Stream.toList
        (Stream.filter
          (cases
            (_, Invite _ _ _ _ Pending _ _ _) -> true
            _                                 -> false)
          (toStream inviteById)))

  sessionTable = sessions.tables.byDevice db
  sessions = map (cases (_, session) -> session) (toList (toStream sessionTable))
  _ List.foreach sessions session = SignalInbox.delete (inbox session)
  sessionKeys = map (cases (deviceId, _) -> deviceId) (toList (toStream sessionTable))
  _ = transact (database sessionTable) do List.foreach sessionKeys key -> tx sessionTable key

  socketTable = sockets.tables.byDevice db
  socketKeys = map (cases (deviceId, _) -> deviceId) (toList (toStream socketTable))
  _ = transact (database socketTable) do List.foreach socketKeys key -> tx socketTable key

  channelById = channels.tables.byId db
  channelByIdKeys = map (cases (channelId, _) -> channelId) (toList (toStream channelById))
  _ = transact (database channelById) do List.foreach channelByIdKeys key -> tx channelById key

  channelByPair = byUserPair db
  channelPairKeys = map (cases (pairKey, _) -> pairKey) (toList (toStream channelByPair))
  _ = transact (database channelByPair) do List.foreach channelPairKeys key -> tx channelByPair key

  channelByParticipant = channels.tables.byParticipantCreatedAt db
  channelParticipantKeys =
    map
      (cases (key, _) -> key)
      (toList (toStream channelByParticipant))
  _ =
    transact (database channelByParticipant) do
      List.foreach channelParticipantKeys key ->
        tx channelByParticipant key

  deviceTable = store.devices.tables.byId db
  deviceKeys = map (cases (deviceId, _) -> deviceId) (toList (toStream deviceTable))
  userKeys = map (cases (userId, _) -> userId) (toList (toStream userTable))

  userByHandle = store.users.tables.byHandle db
  userHandleKeys = map (cases (userHandleText, _) -> userHandleText) (toList (toStream userByHandle))
  userByCreatedAt = store.users.tables.byCreatedAt db
  userCreatedAtKeys = map (cases (key, _) -> key) (toList (toStream userByCreatedAt))

  ok.json
    (object.empty
      |> addText "status" "reset-all"
      |> addNat "cancelledOutgoingInvites" clearedOutgoingInvites
      |> addNat "declinedIncomingInvites" declinedIncomingInvites
      |> addNat "clearedTransmitStates" (size runtimeKeys)
      |> addNat "clearedPresenceEntries" (size presenceKeys)
      |> addNat "clearedTokenEntries" (size tokenKeys)
      |> addNat "clearedInvites" (size inviteByIdKeys)
      |> addNat "clearedSessions" (size sessionKeys)
      |> addNat "clearedSockets" (size socketKeys)
      |> addNat "clearedChannels" (size channelByIdKeys)
      |> addNat "clearedChannelParticipantEntries" (size channelParticipantKeys)
      |> addNat "clearedDevices" (size deviceKeys)
      |> addNat "clearedUsers" (size userKeys)
      |> addNat "remainingPendingInvites" remainingPendingInvites
      |> addNat "remainingInviteByIdEntries" (size inviteByIdKeys)
      |> addNat "remainingInviteByToEntries" (size inviteByToKeys)
      |> addNat "remainingInviteByFromEntries" (size inviteByFromKeys)
      |> addNat "remainingChannelEntries" (size channelByIdKeys)
      |> addNat "remainingChannelPairEntries" (size channelPairKeys)
      |> addNat "remainingChannelParticipantEntries" (size channelParticipantKeys)
      |> addNat "remainingDeviceEntries" (size deviceKeys)
      |> addNat "remainingUserEntries" (size userKeys))

turbo.service.httpWithConfig :
  Text
  -> Boolean
  -> Database
  -> '{Route, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.httpWithConfig mode supportsWebSocket db =
  use Route or
  or health (or (service.config mode supportsWebSocket) (or (seed db) (or (resetState db) (or (resetAll db) (or (runtimeInspection db) (or (service.presence.heartbeat db) (or (session db) (or (service.devices.register db) (or (summary db) (or (users.byHandle db) (or (presenceByHandle db) (or (invites.create db) (or (incoming db) (or (outgoing db) (or (invites.accept db) (or (decline db) (or (invites.cancel db) (or (channels.direct db) (or (channels.join db) (or (leave db) (or (channels.state db) (or (ephemeralToken db) (or (channels.beginTransmit db) (or (channels.renewTransmit db) (or (channels.endTransmit db) (readiness db))))))))))))))))))))))))))

turbo.service.routes.tests.examples : '{IO, Exception} [test.Result]
turbo.service.routes.tests.examples = do
  test.verify do
    use Route.test.harness.cloud simple
    use test ensureEqual
    setup _ = Database.default()
    server db = turbo.service.http db ()
    healthStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusGet "/v1/health")
    configStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusGet "/v1/config")
    seedStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusPost "/v1/dev/seed")
    resetStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusPost "/v1/dev/reset-state")
    resetAllStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusPost "/v1/dev/reset-all")
    heartbeatStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusPost "/v1/presence/heartbeat")
    contactSummariesStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusGet "/v1/contacts/summaries/device")
    incomingInvitesStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusGet "/v1/invites/incoming")
    channelStateStatus = catch do simple setup server (turbo.service.routes.tests.clientStatusGet "/v1/channels/example/state/device")
    ensureEqual healthStatus (Right 200)
    ensureEqual configStatus (Right 200)
    ensureEqual seedStatus (Right 200)
    ensureEqual resetStatus (Right 200)
    ensureEqual resetAllStatus (Right 200)
    ensureEqual heartbeatStatus (Right 401)
    ensureEqual contactSummariesStatus (Right 401)
    ensureEqual incomingInvitesStatus (Right 401)
    ensureEqual channelStateStatus (Right 401)
