{
  "name": "websocket_ready_session_recovery",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": {
      "handle": "@avery",
      "deviceId": "sim-scenario-avery"
    },
    "b": {
      "handle": "@blake",
      "deviceId": "sim-scenario-blake"
    }
  },
  "steps": [
    {
      "description": "both peers open each other",
      "actions": [
        { "actor": "a", "type": "openPeer", "peer": "b" },
        { "actor": "b", "type": "openPeer", "peer": "a" }
      ]
    },
    {
      "description": "request propagates to recipient",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "requested", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "incomingRequest", "isJoined": false }
      }
    },
    {
      "description": "recipient joins and requester becomes peerReady",
      "actions": [
        { "actor": "b", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "peerReady", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "waitingForPeer", "isJoined": true }
      }
    },
    {
      "description": "both sides become ready",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true }
      }
    },
    {
      "description": "websocket disconnect preserves the local session and degrades the remote side to wake-ready",
      "actions": [
        { "actor": "a", "type": "disconnectWebSocket" }
      ],
      "expectEventually": {
        "a": {
          "selectedHandle": "@blake",
          "phase": "waitingForPeer",
          "isJoined": true,
          "backend": {
            "remoteAudioReadiness": "ready",
            "membership": "both(peerDeviceConnected: true)",
            "requestRelationship": "none",
            "webSocketConnected": false
          }
        },
        "b": {
          "selectedHandle": "@avery",
          "phase": "wakeReady",
          "isJoined": true,
          "pttTokenRegistrationKind": "registered",
          "contacts": [
            { "handle": "@avery", "listState": "waiting-for-peer", "badgeStatus": "online" }
          ],
          "backend": {
            "peerDeviceConnected": false,
            "remoteAudioReadiness": "unknown",
            "remoteWakeCapabilityKind": "wake-capable"
          }
        }
      }
    },
    {
      "description": "websocket reconnect plus refresh restores converged control-plane state",
      "actions": [
        { "actor": "a", "type": "reconnectWebSocket" },
        { "actor": "a", "type": "refreshContactSummaries" },
        { "actor": "a", "type": "refreshInvites" },
        { "actor": "a", "type": "refreshChannelState" },
        { "actor": "a", "type": "reconcileSelectedSession" },
        { "actor": "b", "type": "refreshContactSummaries" },
        { "actor": "b", "type": "refreshInvites" },
        { "actor": "b", "type": "refreshChannelState" },
        { "actor": "b", "type": "reconcileSelectedSession" }
      ],
      "expectEventually": {
        "a": {
          "selectedHandle": "@blake",
          "phase": "ready",
          "isJoined": true,
          "canTransmitNow": true,
          "backend": {
            "channelStatus": "ready",
            "readiness": "ready",
            "remoteAudioReadiness": "ready",
            "membership": "both(peerDeviceConnected: true)",
            "requestRelationship": "none",
            "canTransmit": true,
            "webSocketConnected": true
          }
        },
        "b": {
          "selectedHandle": "@avery",
          "phase": "ready",
          "isJoined": true,
          "canTransmitNow": true,
          "backend": {
            "channelStatus": "ready",
            "readiness": "ready",
            "remoteAudioReadiness": "ready"
          }
        }
      }
    },
    {
      "description": "disconnect clears both joined states",
      "actions": [
        { "actor": "a", "type": "disconnect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "isJoined": false, "isTransmitting": false },
        "b": { "selectedHandle": "@avery", "isJoined": false, "isTransmitting": false }
      }
    }
  ]
}
