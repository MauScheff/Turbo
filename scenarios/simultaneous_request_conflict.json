{
  "name": "simultaneous_request_conflict",
  "baseURL": "https://beepbeep.to",
  "participants": {
    "a": {
      "handle": "@avery",
      "deviceId": "sim-scenario-avery"
    },
    "b": {
      "handle": "@blake",
      "deviceId": "sim-scenario-blake"
    }
  },
  "steps": [
    {
      "description": "both peers open each other",
      "actions": [
        { "actor": "a", "type": "openPeer", "peer": "b" },
        { "actor": "b", "type": "openPeer", "peer": "a" }
      ]
    },
    {
      "description": "both peers attempt to connect in the same step",
      "actions": [
        { "actor": "a", "type": "connect" },
        { "actor": "b", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "incomingRequest", "isJoined": false },
        "b": { "selectedHandle": "@avery", "phase": "incomingRequest", "isJoined": false }
      }
    },
    {
      "description": "requester resolves the conflict into a ready session",
      "actions": [
        { "actor": "a", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "waitingForPeer", "isJoined": true },
        "b": { "selectedHandle": "@avery", "phase": "peerReady", "isJoined": false }
      }
    },
    {
      "description": "second peer joins and both sides become ready",
      "actions": [
        { "actor": "b", "type": "connect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "phase": "ready", "isJoined": true, "canTransmitNow": true },
        "b": { "selectedHandle": "@avery", "phase": "ready", "isJoined": true, "canTransmitNow": true }
      }
    },
    {
      "description": "disconnect clears both joined states",
      "actions": [
        { "actor": "a", "type": "disconnect" }
      ],
      "expectEventually": {
        "a": { "selectedHandle": "@blake", "isJoined": false, "isTransmitting": false },
        "b": { "selectedHandle": "@avery", "isJoined": false, "isTransmitting": false }
      }
    }
  ]
}
