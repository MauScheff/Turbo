    noCapture POST (s "v1" / s "presence" / s "heartbeat")
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        currentHandle =
          (User _ handleText _ _ _) = currentUser
          handleText
        fields = decodeJson (Decoder.object Decoder.text)
        match Map.get "deviceId" fields with
          None -> badRequest.json (empty |> addText "error" "missing deviceId")
          Some deviceIdText ->
            devTraffic = isWhitelistedDevHandle (Some currentHandle) ()
            deviceId = DeviceId.fromText deviceIdText
            _ = store.presence.heartbeat db deviceId currentUserId ()
            _ = touchCurrent db deviceId ()
            _ =
              internal.send
                "backend.presence.heartbeat"
                "backend"
                "notice"
                currentUserId
                (Some currentHandle)
                (Some deviceId)
                None
                None
                None
                None
                None
                None
                (Some "presence")
                (Some "heartbeat")
                (Some "presence heartbeat recorded")
                None
                devTraffic
                false
                ()
            ok.json
              (empty
                |> addText "deviceId" deviceIdText
                |> addText "userId" (UserId.toText currentUserId)
                |> addText "status" "online")

turbo.service.presence.heartbeat.doc : Doc
turbo.service.presence.heartbeat.doc =
  {{
  {{ docExample 1 do db -> service.presence.heartbeat db }} records app-level
  online presence for the caller's device.
  
  This endpoint keeps contact online/offline state separate from channel join
  state.
  
  **Also see:** {store.presence.heartbeat}, {{
