-- The definitions below no longer typecheck with the changes above.
-- Please fix the errors and try `update` again.

type turbo.domain.DeviceSession
  = DeviceSession Text DeviceId UserId SignalInbox Instant Instant

type turbo.domain.SignalInbox
  = SignalInbox (Remote.Ref ([SignalEnvelope], Optional (Remote.Promise ())))

turbo.domain.SignalEnvelope.fromText.doc : Doc
turbo.domain.SignalEnvelope.fromText.doc =
  {{
  `` SignalEnvelope.fromText text `` parses a websocket signaling envelope from
  the JSON string `text`.
  
  The payload is kept as opaque text in v1 so the backend can authenticate and
  route signaling frames without understanding SDP or ICE internals.
  
  **Also see:** {SignalEnvelope.toJson}
  }}

turbo.domain.SignalEnvelope.toJson.doc : Doc
turbo.domain.SignalEnvelope.toJson.doc =
  {{
  `` SignalEnvelope.toJson envelope `` renders `envelope` as the flat JSON
  object sent over Turbo's websocket signaling channel.
  
  **Also see:** {SignalEnvelope.fromText}
  }}

turbo.domain.SignalInbox.delete : SignalInbox -> '{Remote} ()
turbo.domain.SignalInbox.delete inbox = do Ref.delete (internal.ref inbox)

turbo.domain.SignalInbox.dequeue : SignalInbox -> '{Remote} SignalEnvelope
turbo.domain.SignalInbox.dequeue inbox = do
  use Promise delete
  use Ref cas
  use Remote.Promise read
  use SignalInbox dequeue
  ref = internal.ref inbox
  (ticket, (items, waiter)) = Ref.readForCas ref
  match items with
    envelope +: rest ->
      success = cas ref ticket (rest, None)
      if success then envelope else dequeue inbox ()
    []               ->
      match waiter with
        Some promise ->
          _ = read promise
          _ = delete promise
          dequeue inbox ()
        None         ->
          promise = detached!
          success = cas ref ticket ([], Some promise)
          if success then
            _ = read promise
            _ = delete promise
            dequeue inbox ()
          else dequeue inbox ()

turbo.domain.SignalInbox.enqueue :
  SignalInbox -> SignalEnvelope -> '{Remote} ()
turbo.domain.SignalInbox.enqueue inbox envelope = do
  use List :+
  use Ref cas
  use SignalInbox enqueue
  ref = internal.ref inbox
  (ticket, (items, waiter)) = Ref.readForCas ref
  match waiter with
    None         ->
      success = cas ref ticket (items :+ envelope, None)
      if success then () else enqueue inbox envelope ()
    Some promise ->
      success = cas ref ticket (items :+ envelope, None)
      if success then
        _ = Remote.Promise.write promise ()
        ()
      else enqueue inbox envelope ()

turbo.domain.SignalInbox.internal.ref :
  SignalInbox -> Remote.Ref ([SignalEnvelope], Optional (Remote.Promise ()))
turbo.domain.SignalInbox.internal.ref = cases SignalInbox ref -> ref

turbo.domain.SignalInbox.new : '{Remote} SignalInbox
turbo.domain.SignalInbox.new = do
  ref = detached ([], None)
  SignalInbox ref

turbo.domain.SignalKind.fromText.doc : Doc
turbo.domain.SignalKind.fromText.doc =
  use SignalKind fromText
  {{
  `` fromText text `` parses a websocket signaling tag from `text`. For
  example:
  
  ```
  fromText "offer"
  ```
  
  Unknown tags return `None`:
  
  ```
  fromText "unknown"
  ```
  
  **Also see:** {SignalKind.toText}
  }}

test> turbo.domain.SignalKind.fromText.tests.props = 
  test.verify do
    Each.repeat 100
    n = natIn 0 6
    kind = match n with
      0 -> Offer
      1 -> Answer
      2 -> IceCandidate
      3 -> Hangup
      4 -> TransmitStart
      5 -> TransmitStop
      _ -> AudioChunk
    labeled "fromText inverts toText" do
      ensureEqual (SignalKind.fromText (SignalKind.toText kind)) (Some kind)

turbo.domain.SignalKind.toText.doc : Doc
turbo.domain.SignalKind.toText.doc =
  use SignalKind toText
  {{
  `` toText kind `` returns the wire-format tag for `kind`. For example:
  
  ```
  toText Offer
  ```
  
  **Also see:** {SignalKind.fromText}
  }}

turbo.domain.WakeJob.doc : Doc
turbo.domain.WakeJob.doc =
  {{
  {type WakeJob} stores one pending production wake send for the external APNs
  worker.
  
  The deployed Unison service still cannot open the APNs HTTPS connection
  directly, so {{ docLink (docEmbedTermLink do channels.beginTransmit) }}
  enqueues one of these jobs and the worker drains them.
  }}

turbo.serveHttpLocal : '{IO, Exception} ()
turbo.serveHttpLocal =
  do
    use Text ++
    setBuffering stdOut LineBuffering
    config =
      LocalCloudConfig.default()
        |> printBanners.set true
        |> LocalCloudConfig.httpPort.set (Port.number 8081)
    Random.run do
      Threads.run do
        _ = 
          local.impl config do
            env = Environment.default()
            database = Database.named "turbo-local-control-plane"
            Database.assign database env
            localHttpService = httpWithConfig "local-http" false database
            hash = deployHttp env (Route.run localHttpService)
            serviceName = ServiceName.named "turbo"
            namedUri = ServiceName.assign serviceName hash
            namedTxt0 = URI.toText namedUri
            namedTxt =
              if endsWith "/" namedTxt0 then namedTxt0 else namedTxt0 ++ "/"
            hashText = ServiceHash.toText hash
            printLine ("Named: " ++ namedTxt)
            printLine ("Hash:  http://localhost:8081/h/" ++ hashText ++ "/")
            ()
        printLine
          "Local HTTP computation starting on port 8081. Press Enter to stop it.\n"
        _ = match catch do readLine() with
          Right _ -> ()
          Left _  -> ()
        ()

turbo.serveLocal :
  '{IO, Exception} ServiceHash
    HttpRequest (Either HttpResponse (WebSocket ->{Remote, WebSockets} ()))
turbo.serveLocal =
  do
    use Text ++
    setBuffering stdOut LineBuffering
    config =
      LocalCloudConfig.default()
        |> printBanners.set true
        |> LocalCloudConfig.httpPort.set (Port.number 8090)
    Random.run do
      Threads.run do
        hash = 
          local.impl config do
            env = Environment.default()
            database = Database.named "turbo-local-control-plane"
            Database.assign database env
            localWebService = web database
            hash = Route.deployWebSocket env localWebService
            serviceName = ServiceName.named "turbo"
            namedUri = ServiceName.assign serviceName hash
            namedTxt0 = URI.toText namedUri
            namedTxt =
              if endsWith "/" namedTxt0 then namedTxt0 else namedTxt0 ++ "/"
            hashText = ServiceHash.toText hash
            printLine ("Named: " ++ namedTxt)
            printLine ("Hash:  http://localhost:8090/h/" ++ hashText ++ "/")
            hash
        printLine
          "Local Cloud computation starting on port 8090. Press Enter to stop it.\n"
        _ = match catch do readLine() with
          Right _ -> ()
          Left _  -> ()
        hash

turbo.service.api :
  Database
  -> '{Route, Config, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.api db = apiWithConfig "cloud" true db

turbo.service.apiWithConfig :
  Text
  -> Boolean
  -> Database
  -> '{Route, Config, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.apiWithConfig mode supportsWebSocket db =
  use Route or
  or
    health
    (or
      (service.config mode supportsWebSocket)
      (or
        (iceServers db)
        (or
          (uploadEvent db)
          (or
            (internal.routes db)
            (or
              (dev db)
              (or
                (service.presence.heartbeat db)
                (or
                  (background db)
                  (or
                    (offline db)
                    (or
                      (auth db) (or (users db) (or (invites db) (channels db))))))))))))

turbo.service.channels.beginTransmit :
  Database -> '{Route, Config, Exception, Http, Storage, Remote, Random} ()
turbo.service.channels.beginTransmit db =
  do
    use Parser /
    use Text ++
    use object empty
    channelIdText =
      route POST (s "v1" / s "channels" / Parser.text / s "begin-transmit")
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        currentHandle =
          (User _ handleText _ _ _) = currentUser
          handleText
        currentDisplayName =
          (User _ _ displayName _ _) = currentUser
          displayName
        fields = decodeJson (Decoder.object Decoder.text)
        channelId = ChannelId.fromText channelIdText
        isMember = memberships.exists db channelId currentUserId ()
        if Boolean.not isMember then
          unauthorized.json (empty |> addText "error" "not a channel member")
        else
          match Map.get "deviceId" fields with
            Some deviceIdText ->
              resolvedTarget =
                resolveTransmitTarget db channelId currentUserId ()
              match resolvedTarget with
                Left err -> badRequest.json (empty |> addText "error" err)
                Right (targetUserId, targetDeviceId) ->
                  result =
                    runtime.beginTransmit
                      db
                      channelId
                      currentUserId
                      (DeviceId.fromText deviceIdText)
                      targetUserId
                      targetDeviceId
                      ()
                  match result with
                    Left err -> badRequest.json (empty |> addText "error" err)
                    Right state ->
                      devTraffic =
                        isWhitelistedDevHandle (Some currentHandle) ()
                      (startedAt, expiresAt, senderDeviceId, transmitIdText) =
                        (TransmitState _ _ fromDeviceId _ _ startedAt expiresAt)
                          =
                          state
                        ( Instant.toText startedAt
                        , Instant.toText expiresAt
                        , fromDeviceId
                        , transmitId state
                        )
                      _ = 
                        forkAt pool() do
                          toRemote do
                            _ =
                              sendTransmitPrepareIfTargetConnected
                                db
                                channelId
                                currentUserId
                                senderDeviceId
                                targetUserId
                                targetDeviceId
                                ()
                            ()
                      _ =
                        sendWakePushUnlessTargetAudioReady
                          db
                          channelId
                          currentHandle
                          currentDisplayName
                          currentUserId
                          senderDeviceId
                          targetUserId
                          targetDeviceId
                          startedAt
                          ()
                      _ = 
                        forkAt pool() do
                          toRemote do
                            _ =
                              internal.send
                                "backend.transmit.begin_granted"
                                "backend"
                                "notice"
                                currentUserId
                                (Some currentHandle)
                                (Some senderDeviceId)
                                (Some channelId)
                                (Some targetUserId)
                                (Some targetDeviceId)
                                None
                                None
                                None
                                (Some "begin-transmit")
                                None
                                (Some "backend transmit lease granted")
                                (Some
                                  ("transmitId="
                                    ++ transmitIdText
                                    ++ " startedAt="
                                    ++ startedAt
                                    ++ " expiresAt="
                                    ++ expiresAt))
                                devTraffic
                                false
                                ()
                            ()
                      ok.json
                        (empty
                          |> addText "channelId" channelIdText
                          |> addText "status" "transmitting"
                          |> addText "transmitId" transmitIdText
                          |> addText "startedAt" startedAt
                          |> addText "expiresAt" expiresAt
                          |> addText
                               "targetUserId" (UserId.toText targetUserId)
                          |> addText
                               "targetDeviceId"
                               (DeviceId.toText targetDeviceId))
            None ->
              badRequest.json (empty |> addText "error" "missing deviceId")

turbo.service.channels.beginTransmit.doc : Doc
turbo.service.channels.beginTransmit.doc =
  {{
  {{ docExample 1 do db -> channels.beginTransmit db }} starts transmit state
  for a direct channel if it is currently idle.
  
  The request body only needs the sender `deviceId`.
  
  The backend resolves the other channel member and selects that user's
  currently active receiving device.
  }}

turbo.service.channels.endTransmit.doc : Doc
turbo.service.channels.endTransmit.doc =
  {{
  {{ docExample 1 do db -> channels.endTransmit db }} ends transmit state for
  the caller's device.
  
  This operation is idempotent: if the caller no longer owns an active transmit
  lease, the backend still returns `idle`.
  
  **Also see:** {channels.beginTransmit}, {runtime.endTransmit}
  }}

turbo.service.channels.internal.joinControlCommand :
  Database
  -> User
  -> Text
  -> Map Text Text
  -> '{Config, Exception, Http, Storage, Remote, Random} ControlCommandRouteResult
turbo.service.channels.internal.joinControlCommand
  db currentUser channelIdText fields =
  joinControlCommandWithConnectedDevice
    db currentUser None channelIdText fields

turbo.service.channels.internal.joinControlCommandWithConnectedDevice :
  Database
  -> User
  -> Optional DeviceId
  -> Text
  -> Map Text Text
  -> '{Config, Exception, Http, Storage, Remote, Random} ControlCommandRouteResult
turbo.service.channels.internal.joinControlCommandWithConnectedDevice
  db currentUser websocketDeviceIdOpt channelIdText fields =
  do
    use Text ==
    use memberships add
    use object empty
    currentUserId =
      (User userId _ _ _ _) = currentUser
      userId
    currentHandle =
      (User _ handleText _ _ _) = currentUser
      handleText
    operationId = Map.get "operationId" fields
    channelId = ChannelId.fromText channelIdText
    joinedJson membership presence =
      membershipUserId =
        (ChannelMembership _ userId _) = membership
        userId
      presenceDeviceId =
        (DevicePresence deviceId _ _ _ _) = presence
        deviceId
      empty
        |> addText "channelId" channelIdText
        |> addText "userId" (UserId.toText membershipUserId)
        |> addText "deviceId" (DeviceId.toText presenceDeviceId)
        |> addText "status" "joined"
        |> addOptionalText "operationId" operationId
    replayJoinedJson deviceId =
      empty
        |> addText "channelId" channelIdText
        |> addText "userId" (UserId.toText currentUserId)
        |> addText "deviceId" (DeviceId.toText deviceId)
        |> addText "status" "joined"
        |> addOptionalText "operationId" operationId
    channelOpt = OrderedTable.tryRead (channels.tables.byId db) channelId
    match channelOpt with
      None -> ControlCommandRouteNotFound "channel not found"
      Some channel ->
        use UserId toText
        otherUserId =
          (DirectChannel _ lowUserId highUserId _) = channel
          if toText lowUserId == toText currentUserId then highUserId
          else lowUserId
        match Map.get "deviceId" fields with
          None -> ControlCommandRouteBadRequest "missing deviceId"
          Some deviceIdText ->
            devTraffic = isWhitelistedDevHandle (Some currentHandle) ()
            deviceId = DeviceId.fromText deviceIdText
            targetKey = channelTargetKey channelId
            replayPlan =
              controlCommands.replayPlan
                db currentUserId deviceId operationId JoinChannel targetKey ()
            match replayPlan with
              RejectControlCommand err -> ControlCommandRouteBadRequest err
              ReplayControlCommand ->
                ControlCommandRouteOk (replayJoinedJson deviceId)
              RunControlCommand ->
                existingActiveChannelId =
                  match presence.get db deviceId () with
                    Some (DevicePresence _ _ _ currentChannelId _) ->
                      currentChannelId
                    None -> None
                storedSessionOrSocketConnected =
                  Boolean.or
                    (sessions.isConnected db deviceId ())
                    (sockets.isConnected db deviceId ())
                sessionConnected =
                  joinControlCommandSessionConnected
                    websocketDeviceIdOpt
                    deviceId
                    storedSessionOrSocketConnected
                joinPresencePlan =
                  joinPresencePlanFromConnection
                    sessionConnected existingActiveChannelId
                match joinPresencePlan with
                  JoinPresencePlanRejectMissingConnectedSession
                    staleChannelIdOpt ->
                    _ =
                      appendJoinWithoutConnectedSessionInvariant
                        db
                        currentUserId
                        (Some currentHandle)
                        channelId
                        deviceId
                        staleChannelIdOpt
                        ()
                    _ = match staleChannelIdOpt with
                      Some _ ->
                        _ = clearActiveChannel db deviceId currentUserId ()
                        ()
                      None   -> ()
                    ControlCommandRouteBadRequest
                      "device session not connected"
                  JoinPresencePlanActivate ->
                    _ = add db channelId currentUserId ()
                    _ = add db channelId otherUserId ()
                    presence =
                      presence.upsert
                        db
                        deviceId
                        currentUserId
                        DevicePresenceStatus.Online
                        (Some channelId)
                        ()
                    _ =
                      match getForUserInChannel db otherUserId channelId () with
                        Some _ ->
                          markConnectedForChannel
                            db currentUserId otherUserId channelId ()
                        None -> None
                    membership = add db channelId currentUserId ()
                    _ =
                      recordSucceeded
                        db
                        currentUserId
                        deviceId
                        operationId
                        JoinChannel
                        targetKey
                        ()
                    _ =
                      internal.send
                        "backend.channel.joined"
                        "backend"
                        "notice"
                        currentUserId
                        (Some currentHandle)
                        (Some deviceId)
                        (Some channelId)
                        (Some otherUserId)
                        None
                        None
                        None
                        None
                        (Some "join")
                        None
                        (Some "channel joined")
                        operationId
                        devTraffic
                        false
                        ()
                    ControlCommandRouteOk (joinedJson membership presence)

turbo.service.channels.internal.peerSetupTargetDeviceId :
  Database
  -> UserId
  -> ChannelId
  -> '{Exception, Remote, Random} Optional DeviceId
turbo.service.channels.internal.peerSetupTargetDeviceId db peerUserId channelId =
  do
    inChannel = getConnectedForUserInChannel db peerUserId channelId ()
    match inChannel with
      Some (DevicePresence deviceId _ _ _ _) -> Some deviceId
      None                                   ->
        match getForUser db peerUserId () with
          Some (DevicePresence deviceId _ _ _ _) -> Some deviceId
          None                                   -> None

turbo.service.channels.internal.sendTransmitPrepareIfTargetConnected :
  Database
  -> ChannelId
  -> UserId
  -> DeviceId
  -> UserId
  -> DeviceId
  -> '{Exception, Remote} ()
turbo.service.channels.internal.sendTransmitPrepareIfTargetConnected
  db channelId senderUserId senderDeviceId targetUserId targetDeviceId =
  do
    match sessions.get db targetDeviceId () with
      None -> ()
      Some session ->
        envelope =
          SignalEnvelope
            TransmitStart
            channelId
            senderUserId
            senderDeviceId
            targetUserId
            targetDeviceId
            "ptt-prepare"
        SignalInbox.enqueue (inbox session) envelope ()

turbo.service.channels.internal.sendWakePushUnlessTargetAudioReady :
  Database
  -> ChannelId
  -> Text
  -> Text
  -> UserId
  -> DeviceId
  -> UserId
  -> DeviceId
  -> Text
  -> '{Config, Exception, Http, Storage, Remote, Random} ()
turbo.service.channels.internal.sendWakePushUnlessTargetAudioReady
  db
  channelId
  senderHandle
  senderDisplayName
  senderUserId
  senderDeviceId
  targetUserId
  targetDeviceId
  startedAt =
  do
    use devWakeEvents appendRecent
    targetAudioReady =
      isReadyForCurrentSession db channelId targetUserId targetDeviceId ()
    targetSocketConnected = sockets.isConnected db targetDeviceId ()
    devTraffic = isWhitelistedDevHandle (Some senderHandle) ()
    if Boolean.and targetSocketConnected targetAudioReady then
      _ =
        appendRecent
          db
          senderUserId
          channelId
          senderDeviceId
          senderHandle
          targetUserId
          targetDeviceId
          startedAt
          "skipped-target-ready"
          "0"
          None
          ()
      _ = 
        forkAt pool() do
          toRemote do
            _ =
              internal.send
                "backend.wake.skipped_target_ready"
                "backend"
                "notice"
                senderUserId
                (Some senderHandle)
                (Some senderDeviceId)
                (Some channelId)
                (Some targetUserId)
                (Some targetDeviceId)
                None
                None
                None
                (Some "wake")
                (Some "target-ready")
                (Some
                  "wake send skipped because the selected target already had receiver audio ready and an open WebSocket")
                None
                devTraffic
                false
                ()
            ()
      ()
    else
      _ =
        appendRecent
          db
          senderUserId
          channelId
          senderDeviceId
          senderHandle
          targetUserId
          targetDeviceId
          startedAt
          "scheduled"
          "0"
          None
          ()
      _ = 
        forkAt pool() do
          toRemote do
            _ =
              sendWakePushIfPossible
                db
                channelId
                senderHandle
                senderDisplayName
                senderUserId
                senderDeviceId
                targetUserId
                targetDeviceId
                startedAt
                ()
            ()
      ()

turbo.service.channels.join :
  Database -> '{Route, Config, Exception, Http, Storage, Remote, Random} ()
turbo.service.channels.join db =
  do
    use Parser /
    channelIdText = route POST (s "v1" / s "channels" / Parser.text / s "join")
    match requireUser db () with
      Left err -> unauthorized.json (object.empty |> addText "error" err)
      Right currentUser ->
        fields = decodeJson (Decoder.object Decoder.text)
        respondHttp
          (joinControlCommand db currentUser channelIdText fields ()) ()

turbo.service.channels.join.doc : Doc
turbo.service.channels.join.doc =
  {{
  {{ docExample 1 do db -> channels.join db }} marks the caller's device as
  joined to a direct channel, but only when the backend still has a live
  connected session for that device. If the device's control-plane session is
  stale, the route rejects the join and clears any carried active-channel
  presence instead of projecting a poisoned live session.
  }}

turbo.service.channels.leave.doc : Doc
turbo.service.channels.leave.doc =
  {{
  {{ docExample 1 do db -> leave db }} clears the caller's active
  device-channel binding for `channelId`.
  
  This is the control-plane leave operation used when a device exits a
  conversation. It also sends a best-effort PushToTalk `leave-channel` push to
  the peer's latest channel token so a background peer can tear down its
  local/system session without waiting for presence polling.
  
  **Also see:** {clearActiveChannel}, {{
  docLink (docEmbedTermLink do channels.join) }}
  }}

turbo.service.channels.pttPushTarget.doc : Doc
turbo.service.channels.pttPushTarget.doc =
  {{
  {{ docExample 1 do db -> pttPushTarget db }} returns the current receiver
  push target for the caller's active transmit.
  
  This is the canonical background-wake payload shape for a live transmit
  owner. It is useful for APNs integration and simulator push tooling.
  
  **Also see:** {channels.beginTransmit}, {{
  docLink (docEmbedTermLink do latestForUserInChannel) }}
  }}

turbo.service.channels.readiness :
  Database -> '{Route, Exception, Storage, Remote, Random} ()
turbo.service.channels.readiness db =
  do
    use Boolean not
    use Optional map
    use Parser / text
    use Text ==
    use object add empty
    (channelIdText, deviceIdText) =
      route
        GET (s "v1" / s "channels" / text / s "readiness" / text => Tuple.pair)
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        channelId = ChannelId.fromText channelIdText
        currentDeviceId = DeviceId.fromText deviceIdText
        canReadChannel = userCanReadDirectChannel db channelId currentUserId ()
        if not canReadChannel then
          unauthorized.json
            (empty |> addText "error" "not a channel participant")
        else
          channelOpt = OrderedTable.tryRead (channels.tables.byId db) channelId
          match channelOpt with
            None ->
              notFound.json (empty |> addText "error" "channel not found")
            Some channel ->
              peerUserId =
                (DirectChannel _ lowUserId highUserId _) = channel
                if UserId.toText lowUserId == UserId.toText currentUserId then
                  highUserId
                else lowUserId
              selfPresence = presence.get db currentDeviceId ()
              rawSelfHasActiveDevice =
                match selfPresence with
                  Some presence ->
                    matchesDeviceChannelPresence
                      currentUserId currentDeviceId channelId presence
                  None -> false
              selfHasActiveDevice =
                selfJoinedChannel db currentUserId channelId selfPresence ()
              _ =
                if Boolean.and rawSelfHasActiveDevice (not selfHasActiveDevice) then
                  appendStaleSelfPresenceProjectedLiveInvariant
                    db currentUserId channelId currentDeviceId "readiness" ()
                else ()
              rawPeerPresence =
                getRawForUserInChannel db peerUserId channelId ()
              peerPresence = getForUserInChannel db peerUserId channelId ()
              _ =
                match (rawPeerPresence, peerPresence) with
                  (Some (DevicePresence peerDeviceId _ _ _ _), None) ->
                    appendStalePeerPresenceProjectedLiveInvariant
                      db
                      currentUserId
                      channelId
                      currentDeviceId
                      peerDeviceId
                      "readiness"
                      ()
                  _ -> ()
              peerHasActiveDevice = isSome peerPresence
              peerTargetDeviceId =
                peerSetupTargetDeviceId db peerUserId channelId ()
              peerDirectQuicIdentity =
                match peerTargetDeviceId with
                  Some targetDeviceId ->
                    match directQuicIdentity.get db targetDeviceId () with
                      Some identity ->
                        if directQuicDeviceIdentityIsActive identity then
                          Some identity
                        else None
                      None -> None
                  None -> None
              peerMediaEncryptionIdentity =
                match peerTargetDeviceId with
                  Some targetDeviceId ->
                    match mediaEncryptionIdentity.get db targetDeviceId () with
                      Some identity ->
                        if mediaEncryptionDeviceIdentityIsActive identity then
                          Some identity
                        else None
                      None -> None
                  None -> None
              selfAudioStatus =
                if selfHasActiveDevice then
                  match statusForCurrentSession
                    db channelId currentUserId currentDeviceId () with
                    AudioReadinessUnknown -> AudioReadinessWaiting
                    status                -> status
                else AudioReadinessUnknown
              peerBaseAudioStatus =
                match peerTargetDeviceId with
                  Some targetDeviceId ->
                    match statusForCurrentSession
                      db channelId peerUserId targetDeviceId () with
                      AudioReadinessUnknown -> AudioReadinessWaiting
                      status                -> status
                  None -> AudioReadinessUnknown
              selfWakeTargetDeviceId =
                map
                  (cases EphemeralToken _ _ tokenDeviceId _ _ -> tokenDeviceId)
                  (tokens.get db channelId currentUserId currentDeviceId ())
              peerWakeTargetDeviceId =
                map
                  (cases EphemeralToken _ _ tokenDeviceId _ _ -> tokenDeviceId)
                  (latestForUserInChannel db channelId peerUserId ())
              peerAudioStatus =
                match ( peerBaseAudioStatus
                , wakeCapabilityStatusFromOptionalDeviceId
                    peerWakeTargetDeviceId
                ) with
                  (AudioReadinessWaiting, WakeCapable _) ->
                    AudioReadinessWakeCapable
                  _ -> peerBaseAudioStatus
              audioReadiness =
                ChannelAudioReadiness
                  selfAudioStatus peerAudioStatus peerTargetDeviceId
              wakeReadiness =
                ChannelWakeReadiness
                  (wakeCapabilityStatusFromOptionalDeviceId
                    selfWakeTargetDeviceId)
                  (wakeCapabilityStatusFromOptionalDeviceId
                    peerWakeTargetDeviceId)
              activeTransmit = currentTransmit db channelId ()
              activeTransmitterUserId =
                map
                  (cases TransmitState _ activeUserId _ _ _ _ _ -> activeUserId)
                  activeTransmit
              activeTransmitExpiresAt =
                map
                  (cases
                    TransmitState _ _ _ _ _ _ expiresAt ->
                      Instant.toText expiresAt)
                  activeTransmit
              activeTransmitId = map transmitId activeTransmit
              readiness =
                channelReadinessStatusFromDevices
                  currentUserId
                  selfHasActiveDevice
                  peerHasActiveDevice
                  activeTransmitterUserId
              projectionEpoch = Instant.toText now!
              base =
                empty
                  |> addText "channelId" channelIdText
                  |> addText "stateEpoch" projectionEpoch
                  |> addText "serverTimestamp" projectionEpoch
                  |> addText "peerUserId" (UserId.toText peerUserId)
                  |> addBoolean "selfHasActiveDevice" selfHasActiveDevice
                  |> addBoolean "peerHasActiveDevice" peerHasActiveDevice
                  |> add "readiness" (channelReadinessStatusJson readiness)
                  |> add
                       "audioReadiness"
                       (channelAudioReadinessJson audioReadiness)
                  |> add
                       "wakeReadiness" (channelWakeReadinessJson wakeReadiness)
                  |> addOptionalText
                       "activeTransmitterUserId"
                       (map UserId.toText activeTransmitterUserId)
                  |> addOptionalText "activeTransmitId" activeTransmitId
                  |> addOptionalText
                       "activeTransmitExpiresAt" activeTransmitExpiresAt
                  |> addText
                       "status" (channelReadinessStatusKindText readiness)
              withDirect =
                match peerDirectQuicIdentity with
                  Some identity ->
                    base
                      |> add
                        "peerDirectQuicIdentity"
                        (directQuicDeviceIdentityJson identity)
                  None -> base
              payload =
                match peerMediaEncryptionIdentity with
                  Some identity ->
                    withDirect
                      |> add
                        "peerMediaEncryptionIdentity"
                        (mediaEncryptionDeviceIdentityJson identity)
                  None -> withDirect
              ok.json payload

turbo.service.channels.readiness.doc : Doc
turbo.service.channels.readiness.doc =
  {{
  {{ docExample 1 do db -> readiness db }} reports the caller and peer
  readiness state for a direct channel.
  
  This is a control-plane readiness check used by the client to distinguish
  local join state from true peer availability. When the connected peer device
  has an active Direct QUIC identity, readiness projects only that peer's
  fingerprint in `peerDirectQuicIdentity`; clients must compare it with the TLS
  certificate fingerprint observed on the direct QUIC path.
  
  It matches `GET /v1/channels/<channelId>/readiness/<deviceId>`.
  }}

turbo.service.channels.renewTransmit.doc : Doc
turbo.service.channels.renewTransmit.doc =
  {{
  {{ docExample 1 do db -> channels.renewTransmit db }} extends the caller's
  active transmit lease for a direct channel.
  
  The request body only needs the sender `deviceId`.
  
  **Also see:** {{ docLink (docEmbedTermLink do channels.beginTransmit) }}, {{
  docLink (docEmbedTermLink do channels.endTransmit) }}
  }}

turbo.service.channels.revokeEphemeralToken :
  Database -> '{Route, Exception, Storage, Remote, Random} ()
turbo.service.channels.revokeEphemeralToken db =
  do
    use Parser /
    use object empty
    channelIdText =
      route
        POST
        (s "v1"
          / s "channels"
          / Parser.text
          / s "ephemeral-token"
          / s "revoke")
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        fields = decodeJson (Decoder.object Decoder.text)
        channelId = ChannelId.fromText channelIdText
        isMember = memberships.exists db channelId currentUserId ()
        if Boolean.not isMember then
          unauthorized.json (empty |> addText "error" "not a channel member")
        else
          match Map.get "deviceId" fields with
            None ->
              badRequest.json (empty |> addText "error" "missing deviceId")
            Some deviceIdText ->
              deviceId = DeviceId.fromText deviceIdText
              _ = tokens.delete db channelId currentUserId deviceId ()
              _ =
                deleteEphemeralRow
                  db ((channelId, currentUserId, deviceId), ())
              ready =
                isReadyForCurrentSession db channelId currentUserId deviceId ()
              cleared =
                if ready then None
                else clearIfTargetDevice db channelId currentUserId deviceId ()
              status = match cleared with
                Some _ -> "revoked-active-transmit-cleared"
                None   -> "revoked"
              ok.json
                (empty
                  |> addText "channelId" channelIdText
                  |> addText "deviceId" deviceIdText
                  |> addText "status" status)

turbo.service.channels.state :
  Database -> '{Route, Exception, Storage, Remote, Random} ()
turbo.service.channels.state db =
  do
    use Boolean and not or
    use Optional map
    use Parser / text
    use memberships exists
    use object add empty
    (channelIdText, deviceIdText) =
      route GET (s "v1" / s "channels" / text / s "state" / text => Tuple.pair)
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        channelId = ChannelId.fromText channelIdText
        deviceId = DeviceId.fromText deviceIdText
        match OrderedTable.tryRead (channels.tables.byId db) channelId with
          None -> notFound.json (empty |> addText "error" "channel not found")
          Some (DirectChannel _ lowUserId highUserId _) ->
            peerUserId =
              if userIdEqual lowUserId currentUserId then highUserId
              else lowUserId
            peerHandle = match users.getById db peerUserId () with
              Some (User _ handleText _ _ _) -> handleText
              None                           -> UserId.toText peerUserId
            selfPresence = presence.get db deviceId ()
            selfOnline = match selfPresence with
              Some presence -> presenceMatches currentUserId presence
              None          -> false
            rawSelfJoined =
              match selfPresence with
                Some presence ->
                  matchesDeviceChannelPresence
                    currentUserId deviceId channelId presence
                None -> false
            normalizedSelfJoined =
              selfJoinedChannel db currentUserId channelId selfPresence ()
            _ =
              if and rawSelfJoined (not normalizedSelfJoined) then
                appendStaleSelfPresenceProjectedLiveInvariant
                  db currentUserId channelId deviceId "state" ()
              else ()
            peerPresence = getForUser db peerUserId ()
            peerOnline = isSome peerPresence
            rawPeerPresence = getRawForUserInChannel db peerUserId channelId ()
            peerJoinedPresence = getForUserInChannel db peerUserId channelId ()
            _ =
              match (rawPeerPresence, peerJoinedPresence) with
                (Some (DevicePresence peerDeviceId _ _ _ _), None) ->
                  appendStalePeerPresenceProjectedLiveInvariant
                    db currentUserId channelId deviceId peerDeviceId "state" ()
                _ -> ()
            peerConnectedPresence =
              getConnectedForUserInChannel db peerUserId channelId ()
            rawPeerDeviceConnected = isSome peerConnectedPresence
            incomingInvite =
              incomingInviteForChannel db currentUserId peerUserId channelId ()
            outgoingInvite =
              outgoingInviteForChannel db currentUserId peerUserId channelId ()
            hasIncomingRequest = isSome incomingInvite
            hasOutgoingRequest = isSome outgoingInvite
            hasPendingRequest = or hasIncomingRequest hasOutgoingRequest
            durableSelfJoined = exists db channelId currentUserId ()
            durablePeerJoined = exists db channelId peerUserId ()
            membership =
              stateMembershipFromDurableMembership
                hasPendingRequest
                durableSelfJoined
                durablePeerJoined
                rawPeerDeviceConnected
            _ =
              match membership with
                NoMembership ->
                  if
                    and
                      (not hasPendingRequest)
                      (or durableSelfJoined durablePeerJoined) then
                    appendNoMembershipProjectionWhileDurableMembershipExistsInvariant
                      db
                      currentUserId
                      channelId
                      deviceId
                      durableSelfJoined
                      durablePeerJoined
                      ()
                  else ()
                _ -> ()
            selfJoined = channelMembershipHasLocalMembership membership
            peerJoined = channelMembershipHasPeerMembership membership
            peerDeviceConnected =
              channelMembershipPeerDeviceConnected membership
            requestCount = pendingCount incomingInvite outgoingInvite
            requestRelationship =
              requestRelationshipFromFlags
                hasIncomingRequest hasOutgoingRequest requestCount
            activeTransmit = currentTransmit db channelId ()
            activeTransmitterUserId = map transmitUserId activeTransmit
            activeTransmitExpiresAt = map transmitExpiresAtText activeTransmit
            activeTransmitId = map transmitId activeTransmit
            conversationStatus =
              channelStateStatusFromView
                currentUserId
                membership
                requestRelationship
                peerOnline
                activeTransmitterUserId
            _ =
              if
                channelStateStatusConnectsWithoutMembershipOrRequest
                  membership requestRelationship conversationStatus then
                appendConnectingWithoutMembershipOrRequestInvariant
                  db currentUserId channelId ()
              else ()
            projectionEpoch = Instant.toText now!
            ok.json
              (empty
                |> addText "channelId" channelIdText
                |> addText "stateEpoch" projectionEpoch
                |> addText "serverTimestamp" projectionEpoch
                |> addText "selfUserId" (UserId.toText currentUserId)
                |> addText "peerUserId" (UserId.toText peerUserId)
                |> addText "peerHandle" peerHandle
                |> addBoolean "selfOnline" selfOnline
                |> addBoolean "peerOnline" peerOnline
                |> addBoolean "selfJoined" selfJoined
                |> addBoolean "peerJoined" peerJoined
                |> addBoolean "peerDeviceConnected" peerDeviceConnected
                |> addBoolean "hasIncomingRequest" hasIncomingRequest
                |> addBoolean "hasOutgoingRequest" hasOutgoingRequest
                |> addNat "requestCount" requestCount
                |> add "membership" (channelMembershipJson membership)
                |> add
                     "requestRelationship"
                     (requestRelationshipJson requestRelationship)
                |> add
                     "conversationStatus"
                     (channelStateStatusJson conversationStatus)
                |> addOptionalText
                     "activeTransmitterUserId"
                     (map UserId.toText activeTransmitterUserId)
                |> addOptionalText "activeTransmitId" activeTransmitId
                |> addOptionalText
                     "transmitLeaseExpiresAt" activeTransmitExpiresAt
                |> addText
                     "status" (channelStateStatusKindText conversationStatus)
                |> addBoolean
                     "canTransmit"
                     (canTransmit
                       currentUserId
                       selfOnline
                       peerOnline
                       membership
                       activeTransmitterUserId))

turbo.service.channels.state.doc : Doc
turbo.service.channels.state.doc =
  {{
  {{ docExample 1 do db -> channels.state db }} returns the authoritative
  active-session snapshot for a direct channel and device.
  
  The snapshot is derived from canonical facts only: device presence, pending
  invites, memberships, and the current transmit lease. Clients should render
  the selected conversation directly from this route instead of merging
  multiple backend reads.
  
  It matches `GET /v1/channels/<channelId>/state/<deviceId>`.
  
  **Also see:** {{ docLink (docEmbedTermLink do summary) }}, {currentTransmit}
  }}

turbo.service.contacts.internal.selfJoinedChannel :
  Database
  -> UserId
  -> ChannelId
  -> Optional DevicePresence
  -> '{Exception, Remote, Random} Boolean
turbo.service.contacts.internal.selfJoinedChannel
  db currentUserId channelId selfPresence =
  do
    now = now!
    match selfPresence with
      Some presence@(DevicePresence deviceId _ _ _ _) ->
        if
          matchesDeviceChannelPresence
            currentUserId deviceId channelId presence then
          if presence.internal.isFresh now presence then
            hasConnectedSessionEvidence db deviceId ()
          else false
        else false
      None -> false

turbo.service.contacts.internal.summaryJson :
  Database
  -> UserId
  -> Optional DevicePresence
  -> User
  -> '{Exception, Storage, Remote, Random} Optional Json
turbo.service.contacts.internal.summaryJson db currentUserId selfPresence user =
  do
    use Boolean or
    use memberships exists
    use object add
    (User otherUserId handleText displayName _ _) = user
    if userIdEqual currentUserId otherUserId then None
    else
      directChannelOpt = internal.directChannel db currentUserId otherUserId ()
      peerPresence = getForUser db otherUserId ()
      peerConnectedPresence = getConnectedForUser db otherUserId ()
      rawPeerOnline = match peerPresence with
        None                                         -> false
        Some (DevicePresence _ _ presenceStatus _ _) ->
          match presenceStatus with
            DevicePresenceStatus.Online  -> true
            DevicePresenceStatus.Offline -> false
      peerOnline =
        hasConnectedSessionEvidenceFromFlags
          rawPeerOnline (isSome peerConnectedPresence)
      channelFacts =
        match directChannelOpt with
          None -> (None, false, false, false, None, None, None)
          Some (DirectChannel channelId _ _ _) ->
            rawPeerDeviceConnected =
              isSome (getConnectedForUserInChannel db otherUserId channelId ())
            incomingInvite =
              incomingInviteForChannel
                db currentUserId otherUserId channelId ()
            outgoingInvite =
              outgoingInviteForChannel
                db currentUserId otherUserId channelId ()
            hasPendingRequest =
              or (isSome incomingInvite) (isSome outgoingInvite)
            durableSelfJoined = exists db channelId currentUserId ()
            durablePeerJoined = exists db channelId otherUserId ()
            membershipView =
              stateMembershipFromDurableMembership
                hasPendingRequest
                durableSelfJoined
                durablePeerJoined
                rawPeerDeviceConnected
            selfJoined = channelMembershipHasLocalMembership membershipView
            peerJoined = channelMembershipHasPeerMembership membershipView
            peerDeviceConnected =
              channelMembershipPeerDeviceConnected membershipView
            activeTransmit = currentTransmit db channelId ()
            activeTransmitterUserId =
              Optional.map transmitUserId activeTransmit
            ( Some (ChannelId.toText channelId)
            , selfJoined
            , peerJoined
            , peerDeviceConnected
            , incomingInvite
            , outgoingInvite
            , activeTransmitterUserId
            )
      ( channelIdTextOpt,
        selfJoined,
        peerJoined,
        peerDeviceConnected,
        incomingInvite,
        outgoingInvite,
        activeTransmitterUserId)
        =
        channelFacts
      hasIncomingRequest = isSome incomingInvite
      hasOutgoingRequest = isSome outgoingInvite
      requestCount = pendingCount incomingInvite outgoingInvite
      requestRelationship =
        requestRelationshipFromFlags
          hasIncomingRequest hasOutgoingRequest requestCount
      membership =
        channelMembershipFromFlags selfJoined peerJoined peerDeviceConnected
      summaryStatus =
        contactSummaryStatusFromView
          currentUserId
          peerOnline
          membership
          requestRelationship
          activeTransmitterUserId
      _ =
        if
          summaryConnectableWithoutLivePeerOrRequest
            summaryStatus
            requestRelationship
            peerDeviceConnected
            activeTransmitterUserId then
          appendSummaryConnectableWithoutLivePeerOrRequestInvariant
            db currentUserId otherUserId channelIdTextOpt summaryStatus ()
        else ()
      isActiveConversation =
        or
          (channelMembershipHasLocalMembership membership)
          (or
            (channelMembershipHasPeerMembership membership)
            (isSome activeTransmitterUserId))
      Some
        (userIdentityJson user
          |> addOptionalText "channelId" channelIdTextOpt
          |> addBoolean "isOnline" peerOnline
          |> addBoolean "hasIncomingRequest" hasIncomingRequest
          |> addBoolean "hasOutgoingRequest" hasOutgoingRequest
          |> addNat "requestCount" requestCount
          |> add "membership" (channelMembershipJson membership)
          |> add
               "requestRelationship"
               (requestRelationshipJson requestRelationship)
          |> add "summaryStatus" (contactSummaryStatusJson summaryStatus)
          |> addBoolean "isActiveConversation" isActiveConversation
          |> addText "badgeStatus" (contactSummaryStatusKindText summaryStatus))

turbo.service.contacts.internal.summaryJsons :
  Database
  -> UserId
  -> Optional DevicePresence
  -> [User]
  -> '{Exception, Storage, Remote, Random} [Json]
turbo.service.contacts.internal.summaryJsons
  db currentUserId selfPresence users =
  do match users with
    []           -> []
    user +: rest ->
      use List +:
      current = summaryJson db currentUserId selfPresence user ()
      remaining = summaryJsons db currentUserId selfPresence rest ()
      match current with
        None         -> remaining
        Some summary -> summary +: remaining

turbo.service.contacts.summary :
  Database -> '{Route, Exception, Storage, Remote, Random} ()
turbo.service.contacts.summary db =
  do
    use Parser /
    deviceIdText =
      route GET (s "v1" / s "contacts" / s "summaries" / Parser.text)
    match requireUser db () with
      Left err -> unauthorized.json (object.empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        currentDeviceId = DeviceId.fromText deviceIdText
        selfPresence = presence.get db currentDeviceId ()
        candidateUserIds = internal.candidateUserIds db currentUserId ()
        users = usersByIds db candidateUserIds ()
        summaries = summaryJsons db currentUserId selfPresence users ()
        ok.json (Json.array summaries)

turbo.service.contacts.summary.doc : Doc
turbo.service.contacts.summary.doc =
  {{
  {{ docExample 1 do db -> summary db }} returns authoritative contact
  summaries for the caller's current device.
  
  The route only summarizes relationship-backed contacts: peers with a pending
  invite or an existing direct channel. It does not enumerate the entire seeded
  dev user directory.
  
  **Also see:** {incoming}, {outgoing}, {{
  docLink (docEmbedTermLink do channels.state) }}
  }}

turbo.service.dev.internal.clearDeviceState :
  Database -> DeviceId -> '{Exception, Storage, Remote} ()
turbo.service.dev.internal.clearDeviceState db deviceId = do
  _ = OrderedTable.delete (presence.tables.byDevice db) deviceId
  match OrderedTable.tryRead (sessions.tables.byDevice db) deviceId with
    Some session ->
      _ = SignalInbox.delete (inbox session) ()
      _ = OrderedTable.delete (sessions.tables.byDevice db) deviceId
      _ = OrderedTable.delete (sockets.tables.byDevice db) deviceId
      ()
    None         ->
      _ = OrderedTable.delete (sockets.tables.byDevice db) deviceId
      ()

turbo.service.dev.internal.deleteSessionRow :
  Database -> (DeviceId, a) ->{Remote} ()
turbo.service.dev.internal.deleteSessionRow db = cases
  (key, _) ->
    _ = OrderedTable.delete (sessions.tables.byDevice db) key
    ()

turbo.service.dev.internal.disconnectSession :
  Database -> DeviceSession ->{Exception, Storage, Remote} ()
turbo.service.dev.internal.disconnectSession db = cases
  DeviceSession expectedSessionId deviceId _ _ _ _ ->
    _ = sessions.disconnect db deviceId expectedSessionId ()
    ()

turbo.service.dev.internal.performReset :
  Database -> '{Exception, Storage, Remote} ResetSummary
turbo.service.dev.internal.performReset db =
  do
    use List foreach size
    use OrderedTable toStream
    use Stream toList
    runtimeRows = toList (toStream (byChannel db))
    _ = foreach (deleteRuntimeRow db) runtimeRows
    presenceRows = toList (toStream (presence.tables.byDevice db))
    _ = foreach (deletePresenceRow db) presenceRows
    tokenRows = toList (toStream (tokens.tables.byChannelUserDevice db))
    _ = foreach (deleteTokenRow db) tokenRows
    ephemeralEnvironmentRows =
      toList (toStream (ephemeralByChannelUserDevice db))
    _ = foreach (deleteEphemeralRow db) ephemeralEnvironmentRows
    alertEnvironmentRows = toList (toStream (alertByUserDevice db))
    _ = foreach (deleteAlertRow db) alertEnvironmentRows
    inviteIdRows = toList (toStream (invites.tables.byId db))
    _ = foreach (deleteInviteIdRow db) inviteIdRows
    inviteFromRows = toList (toStream (byFromCreatedAt db))
    _ = foreach (deleteInviteFromRow db) inviteFromRows
    inviteToRows = toList (toStream (byToCreatedAt db))
    _ = foreach (deleteInviteToRow db) inviteToRows
    membershipRows = toList (toStream (byChannelUser db))
    _ = foreach (deleteMembershipRow db) membershipRows
    sessionRows = toList (toStream (sessions.tables.byDevice db))
    _ = foreach (deleteSessionRow db) sessionRows
    channelRows = toList (toStream (channels.tables.byId db))
    _ = foreach (deleteChannelRow db) channelRows
    participantRows = toList (toStream (byParticipantCreatedAt db))
    _ = foreach (deleteChannelParticipantRow db) participantRows
    userPairRows = toList (toStream (byUserPair db))
    _ = foreach (deleteChannelUserPairRow db) userPairRows
    savedContactOwnerRows = toList (toStream (byOwnerUser db))
    _ = foreach (deleteSavedContactOwnerRow db) savedContactOwnerRows
    controlCommandRows = toList (toStream (byActorOperation db))
    _ = foreach (deleteControlCommandRow db) controlCommandRows
    wakeJobRowCount = clearPending db ()
    wakeEventRowCount = devWakeEvents.clearRecent db ()
    invariantEventRowCount = devInvariantEvents.clearRecent db ()
    ResetSummary
      (size runtimeRows)
      (size presenceRows)
      (size tokenRows)
      (size inviteIdRows)
      (size inviteFromRows)
      (size inviteToRows)
      (size membershipRows)
      (size sessionRows)
      0
      (size channelRows)
      (size userPairRows)
      wakeJobRowCount
      wakeEventRowCount
      invariantEventRowCount
      (size controlCommandRows)

turbo.service.dev.internal.resetUserState :
  Database -> UserId -> '{Exception, Storage, Remote, Random} ResetStateSummary
turbo.service.dev.internal.resetUserState db currentUserId =
  do
    use List foreach size
    outgoingInvites = listOutgoingPending db currentUserId ()
    incomingInvites = listIncomingPending db currentUserId ()
    deviceIds = userDeviceIds db currentUserId ()
    channelIds = userChannelIds db currentUserId ()
    _ = foreach (invite -> cancelOutgoingInvite db invite ()) outgoingInvites
    _ = foreach (invite -> declineIncomingInvite db invite ()) incomingInvites
    _ = foreach (deviceId -> clearDeviceState db deviceId ()) deviceIds
    tokenRows =
      Stream.toList
        (OrderedTable.toStream (tokens.tables.byChannelUserDevice db))
    _ =
      foreach
        (tokenRow -> clearTokenRow db currentUserId deviceIds tokenRow ())
        tokenRows
    _ = foreach (channelId -> clearChannelRuntime db channelId ()) channelIds
    ResetStateSummary
      (size outgoingInvites)
      (size incomingInvites)
      (size deviceIds)
      (size channelIds)
      (size deviceIds)
      (size tokenRows)

turbo.service.dev.resetAll :
  Database -> '{Route, Exception, Storage, Remote} ()
turbo.service.dev.resetAll db = do
  use Parser /
  noCapture POST (s "v1" / s "dev" / s "reset-all")
  summary = performReset db ()
  ok.json (resetSummaryJson "reset-all" summary)

turbo.service.dev.resetState :
  Database -> '{Route, Exception, Storage, Remote} ()
turbo.service.dev.resetState db = do
  use Parser /
  noCapture POST (s "v1" / s "dev" / s "reset-state")
  summary = performReset db ()
  ok.json (resetSummaryJson "reset" summary)

turbo.service.dev.runtimeInspection :
  Database -> '{Route, Exception, Http, Storage, Remote, Random} ()
turbo.service.dev.runtimeInspection db =
  do
    use Parser / text
    use memberships exists
    use object empty
    (channelIdText, deviceIdText) =
      route GET (s "v1" / s "dev" / s "runtime" / text / text => Tuple.pair)
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        channelId = ChannelId.fromText channelIdText
        deviceId = DeviceId.fromText deviceIdText
        match OrderedTable.tryRead (channels.tables.byId db) channelId with
          None -> notFound.json (empty |> addText "error" "channel not found")
          Some (DirectChannel _ lowUserId highUserId _) ->
            peerUserId =
              if
                textEqual
                  (UserId.toText lowUserId) (UserId.toText currentUserId) then
                highUserId
              else lowUserId
            selfPresence = presence.get db deviceId ()
            selfSession = sessions.get db deviceId ()
            selfSocketVisible = sockets.isConnected db deviceId ()
            selfMembership = exists db channelId currentUserId ()
            peerPresence = getForUser db peerUserId ()
            peerMembership = exists db channelId peerUserId ()
            peerJoinedPresence = getForUserInChannel db peerUserId channelId ()
            peerConnectedPresence =
              getConnectedForUserInChannel db peerUserId channelId ()
            activeTransmit = currentTransmit db channelId ()
            selfPresenceChannelId =
              match selfPresence with
                Some (DevicePresence _ _ _ currentChannelId _) ->
                  Optional.map ChannelId.toText currentChannelId
                None -> None
            selfSessionTimes =
              match selfSession with
                Some (DeviceSession sessionId _ _ _ connectedAt lastSeenAt) ->
                  ( Some sessionId
                  , Some (Instant.toText connectedAt)
                  , Some (Instant.toText lastSeenAt)
                  )
                None -> (None, None, None)
            (selfSessionIdText, selfConnectedAtText, selfLastSeenAtText) =
              selfSessionTimes
            peerConnectedDeviceId =
              match peerConnectedPresence with
                Some (DevicePresence connectedDeviceId _ _ _ _) ->
                  Some (DeviceId.toText connectedDeviceId)
                None -> None
            activeTransmitJson =
              match activeTransmit with
                None -> Null
                Some
                  (TransmitState
                    _
                    fromUserId
                    fromDeviceId
                    toUserId
                    toDeviceId
                    startedAt
                    expiresAt) ->
                  empty
                    |> addText "fromUserId" (UserId.toText fromUserId)
                    |> addText "fromDeviceId" (DeviceId.toText fromDeviceId)
                    |> addText "toUserId" (UserId.toText toUserId)
                    |> addText "toDeviceId" (DeviceId.toText toDeviceId)
                    |> addText "startedAt" (Instant.toText startedAt)
                    |> addText "expiresAt" (Instant.toText expiresAt)
            ok.json
              (empty
                |> addText "channelId" channelIdText
                |> addText "currentUserId" (UserId.toText currentUserId)
                |> addText "peerUserId" (UserId.toText peerUserId)
                |> addText "deviceId" deviceIdText
                |> addBoolean "selfPresenceFound" (isSome selfPresence)
                |> addOptionalText
                     "selfPresenceChannelId" selfPresenceChannelId
                |> addBoolean "selfSessionConnected" (isSome selfSession)
                |> addOptionalText "selfSessionId" selfSessionIdText
                |> addOptionalText "selfSessionConnectedAt" selfConnectedAtText
                |> addOptionalText "selfSessionLastSeenAt" selfLastSeenAtText
                |> addBoolean "selfSocketVisible" selfSocketVisible
                |> addBoolean "selfMembership" selfMembership
                |> addBoolean "peerPresenceFound" (isSome peerPresence)
                |> addBoolean "peerMembership" peerMembership
                |> addBoolean
                     "peerJoinedPresenceFound" (isSome peerJoinedPresence)
                |> addBoolean
                     "peerConnectedPresenceFound"
                     (isSome peerConnectedPresence)
                |> addOptionalText
                     "peerConnectedDeviceId" peerConnectedDeviceId
                |> object.add "activeTransmit" activeTransmitJson)

turbo.service.dev.runtimeInspection.doc : Doc
turbo.service.dev.runtimeInspection.doc =
  {{
  {{ docExample 1 do db -> runtimeInspection db }} returns a backend runtime
  snapshot for the caller's device in a channel.
  
  This is a dev-only diagnostic surface used by probes and on-device tooling to
  distinguish presence, durable websocket session truth, local socket
  visibility, and transmit ownership.
  
  **Also see:** {channels.state}, {sessions.get}, {sockets.lookup}
  }}

turbo.service.http :
  Database
  -> '{Route, Config, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.http db = Route.or (api db) (share db)

turbo.service.httpWithConfig :
  Text
  -> Boolean
  -> Database
  -> '{Route, Config, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.httpWithConfig mode supportsWebSocket db =
  Route.or (apiWithConfig mode supportsWebSocket db) (share db)

turbo.service.invites.accept.doc : Doc
turbo.service.invites.accept.doc =
  {{
  {{ docExample 1 do db -> invites.accept db }} acknowledges an incoming invite
  for the current user.
  
  The invite remains pending until both peers have actually joined the channel;
  the join step is still authoritative for transitioning to connected state.
  
  **Also see:** {{ docLink (docEmbedTermLink do channels.join) }},
  {invites.getById}
  }}

turbo.service.presence.background :
  Database -> '{Route, Config, Exception, Http, Storage, Remote, Random} ()
turbo.service.presence.background db =
  do
    use Parser /
    use object empty
    noCapture POST (s "v1" / s "presence" / s "background")
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        currentHandle =
          (User _ handleText _ _ _) = currentUser
          handleText
        fields = decodeJson (Decoder.object Decoder.text)
        match Map.get "deviceId" fields with
          None -> badRequest.json (empty |> addText "error" "missing deviceId")
          Some deviceIdText ->
            devTraffic = isWhitelistedDevHandle (Some currentHandle) ()
            deviceId = DeviceId.fromText deviceIdText
            currentChannelIdOpt =
              match presence.get db deviceId () with
                Some (DevicePresence _ _ _ currentChannelId _) ->
                  currentChannelId
                None -> None
            _ = match currentChannelIdOpt with
              Some channelId ->
                _ = runtime.endTransmit db channelId currentUserId deviceId ()
                ()
              None           -> ()
            _ = sockets.disconnect db deviceId ()
            _ = disconnectCurrent db deviceId ()
            _ =
              presence.upsert
                db
                deviceId
                currentUserId
                DevicePresenceStatus.Offline
                currentChannelIdOpt
                ()
            sessionConnected = sessions.isConnected db deviceId ()
            socketConnected = sockets.isConnected db deviceId ()
            _ =
              if
                hasConnectedSessionEvidenceFromFlags
                  sessionConnected socketConnected then
                appendOfflineRetainedConnectedSessionInvariant
                  db
                  currentUserId
                  (Some currentHandle)
                  deviceId
                  sessionConnected
                  socketConnected
                  ()
              else ()
            _ =
              internal.send
                "backend.presence.background"
                "backend"
                "notice"
                currentUserId
                (Some currentHandle)
                (Some deviceId)
                currentChannelIdOpt
                None
                None
                None
                None
                None
                (Some "presence")
                (Some "background")
                (Some "presence transitioned to background")
                None
                devTraffic
                false
                ()
            ok.json
              (empty
                |> addText "deviceId" deviceIdText
                |> addText "userId" (UserId.toText currentUserId)
                |> addText "status" "offline")

turbo.service.presence.background.doc : Doc
turbo.service.presence.background.doc =
  {{
  {{ docExample 1 do db -> background db }} records app-level offline presence
  for the caller's device while preserving any active channel membership for
  wake-capable background receive.
  
  Use this for app background transitions where the device should appear
  offline in presence surfaces but remain reachable for the current channel.
  }}

turbo.service.presence.heartbeat :
