type turbo.domain.SignalKind
  = Offer
  | Answer
  | IceCandidate
  | Hangup
  | TransmitStart
  | TransmitStop
  | AudioChunk
  | ReceiverReady
  | ReceiverNotReady
  | DirectQuicUpgradeRequest
  | SelectedPeerPrewarm

type turbo.domain.SignalEnvelope
  = SignalEnvelope
      turbo.domain.SignalKind ChannelId UserId DeviceId UserId DeviceId Text

turbo.domain.SignalKind.fromText : Text -> Optional turbo.domain.SignalKind
turbo.domain.SignalKind.fromText = cases
  "offer" -> Some turbo.domain.SignalKind.Offer
  "answer" -> Some turbo.domain.SignalKind.Answer
  "ice-candidate" -> Some turbo.domain.SignalKind.IceCandidate
  "hangup" -> Some turbo.domain.SignalKind.Hangup
  "transmit-start" -> Some turbo.domain.SignalKind.TransmitStart
  "transmit-stop" -> Some turbo.domain.SignalKind.TransmitStop
  "audio-chunk" -> Some turbo.domain.SignalKind.AudioChunk
  "receiver-ready" -> Some turbo.domain.SignalKind.ReceiverReady
  "receiver-not-ready" -> Some turbo.domain.SignalKind.ReceiverNotReady
  "direct-quic-upgrade-request" ->
    Some turbo.domain.SignalKind.DirectQuicUpgradeRequest
  "selected-peer-prewarm" -> Some turbo.domain.SignalKind.SelectedPeerPrewarm
  _ -> None

turbo.domain.SignalKind.toText : turbo.domain.SignalKind -> Text
turbo.domain.SignalKind.toText = cases
  turbo.domain.SignalKind.Offer -> "offer"
  turbo.domain.SignalKind.Answer -> "answer"
  turbo.domain.SignalKind.IceCandidate -> "ice-candidate"
  turbo.domain.SignalKind.Hangup -> "hangup"
  turbo.domain.SignalKind.TransmitStart -> "transmit-start"
  turbo.domain.SignalKind.TransmitStop -> "transmit-stop"
  turbo.domain.SignalKind.AudioChunk -> "audio-chunk"
  turbo.domain.SignalKind.ReceiverReady -> "receiver-ready"
  turbo.domain.SignalKind.ReceiverNotReady -> "receiver-not-ready"
  turbo.domain.SignalKind.DirectQuicUpgradeRequest ->
    "direct-quic-upgrade-request"
  turbo.domain.SignalKind.SelectedPeerPrewarm -> "selected-peer-prewarm"

turbo.domain.SignalEnvelope.fromText :
  Text ->{Exception} turbo.domain.SignalEnvelope
turbo.domain.SignalEnvelope.fromText text =
  use Text ++
  use object at!
  runAllowTrailing
    (do
      kindText = at! "type" Decoder.text
      kind = match turbo.domain.SignalKind.fromText kindText with
        Some kind -> kind
        None      -> Decoder.fail ("unknown signal type: " ++ kindText)
      channelIdText = at! "channelId" Decoder.text
      fromUserIdText = at! "fromUserId" Decoder.text
      fromDeviceIdText = at! "fromDeviceId" Decoder.text
      toUserIdText = at! "toUserId" Decoder.text
      toDeviceIdText = at! "toDeviceId" Decoder.text
      payload = at! "payload" Decoder.text
      turbo.domain.SignalEnvelope.SignalEnvelope
        kind
        (ChannelId.fromText channelIdText)
        (UserId.fromText fromUserIdText)
        (DeviceId.fromText fromDeviceIdText)
        (UserId.fromText toUserIdText)
        (DeviceId.fromText toDeviceIdText)
        payload)
    text

turbo.domain.SignalEnvelope.toJson : turbo.domain.SignalEnvelope -> Json
turbo.domain.SignalEnvelope.toJson = cases
  turbo.domain.SignalEnvelope.SignalEnvelope
    kind channelId fromUserId fromDeviceId toUserId toDeviceId payload ->
    object.empty
      |> addText "type" (turbo.domain.SignalKind.toText kind)
      |> addText "channelId" (ChannelId.toText channelId)
      |> addText "fromUserId" (UserId.toText fromUserId)
      |> addText "fromDeviceId" (DeviceId.toText fromDeviceId)
      |> addText "toUserId" (UserId.toText toUserId)
      |> addText "toDeviceId" (DeviceId.toText toDeviceId)
      |> addText "payload" payload

turbo.domain.SignalKind.fromText.tests.examples : [Result]
turbo.domain.SignalKind.fromText.tests.examples = 
  test.verify do
    labeled "parses known tag" do
      ensureEqual
        (turbo.domain.SignalKind.fromText "answer")
        (Some turbo.domain.SignalKind.Answer)
    labeled "parses audio chunk tag" do
      ensureEqual
        (turbo.domain.SignalKind.fromText "audio-chunk")
        (Some turbo.domain.SignalKind.AudioChunk)
    labeled "parses receiver ready tag" do
      ensureEqual
        (turbo.domain.SignalKind.fromText "receiver-ready")
        (Some turbo.domain.SignalKind.ReceiverReady)
    labeled "parses receiver not ready tag" do
      ensureEqual
        (turbo.domain.SignalKind.fromText "receiver-not-ready")
        (Some turbo.domain.SignalKind.ReceiverNotReady)
    labeled "parses direct quic upgrade request tag" do
      ensureEqual
        (turbo.domain.SignalKind.fromText "direct-quic-upgrade-request")
        (Some turbo.domain.SignalKind.DirectQuicUpgradeRequest)
    labeled "parses selected peer prewarm tag" do
      ensureEqual
        (turbo.domain.SignalKind.fromText "selected-peer-prewarm")
        (Some turbo.domain.SignalKind.SelectedPeerPrewarm)
    labeled "rejects unknown tag" do
      ensureEqual (turbo.domain.SignalKind.fromText "bogus") None

turbo.domain.SignalKind.toText.tests.examples : [Result]
turbo.domain.SignalKind.toText.tests.examples = 
  test.verify do
    labeled "encodes offer" do
      ensureEqual
        (turbo.domain.SignalKind.toText turbo.domain.SignalKind.Offer) "offer"
    labeled "encodes transmit stop" do
      ensureEqual
        (turbo.domain.SignalKind.toText turbo.domain.SignalKind.TransmitStop)
        "transmit-stop"
    labeled "encodes audio chunk" do
      ensureEqual
        (turbo.domain.SignalKind.toText turbo.domain.SignalKind.AudioChunk)
        "audio-chunk"
    labeled "encodes receiver ready" do
      ensureEqual
        (turbo.domain.SignalKind.toText turbo.domain.SignalKind.ReceiverReady)
        "receiver-ready"
    labeled "encodes receiver not ready" do
      ensureEqual
        (turbo.domain.SignalKind.toText
          turbo.domain.SignalKind.ReceiverNotReady)
        "receiver-not-ready"
    labeled "encodes direct quic upgrade request" do
      ensureEqual
        (turbo.domain.SignalKind.toText
          turbo.domain.SignalKind.DirectQuicUpgradeRequest)
        "direct-quic-upgrade-request"
    labeled "encodes selected peer prewarm" do
      ensureEqual
        (turbo.domain.SignalKind.toText
          turbo.domain.SignalKind.SelectedPeerPrewarm)
        "selected-peer-prewarm"

turbo.domain.SignalEnvelope.fromText.tests.examples : [Result]
turbo.domain.SignalEnvelope.fromText.tests.examples = 
  test.verify do
    envelope =
      turbo.domain.SignalEnvelope.SignalEnvelope
        turbo.domain.SignalKind.SelectedPeerPrewarm
        (ChannelId.fromText "channel-1")
        (UserId.fromText "alice")
        (DeviceId.fromText "alice-phone")
        (UserId.fromText "bob")
        (DeviceId.fromText "bob-phone")
        "selected-contact"
    labeled "roundtrips selected peer prewarm envelope" do
      ensureEqual
        (catch do
          turbo.domain.SignalEnvelope.fromText
            (Json.toText (turbo.domain.SignalEnvelope.toJson envelope)))
        (Right envelope)

turbo.domain.SignalEnvelope.fromText.tests.props : [Result]
turbo.domain.SignalEnvelope.fromText.tests.props = 
  test.verify do
    use Text ++
    Each.repeat 50
    n = natIn 0 9
    kind = match n with
      0 -> turbo.domain.SignalKind.Offer
      1 -> turbo.domain.SignalKind.Answer
      2 -> turbo.domain.SignalKind.IceCandidate
      3 -> turbo.domain.SignalKind.Hangup
      4 -> turbo.domain.SignalKind.TransmitStart
      5 -> turbo.domain.SignalKind.TransmitStop
      6 -> turbo.domain.SignalKind.AudioChunk
      7 -> turbo.domain.SignalKind.ReceiverReady
      8 -> turbo.domain.SignalKind.DirectQuicUpgradeRequest
      _ -> turbo.domain.SignalKind.SelectedPeerPrewarm
    suffix = Nat.toText (natIn 0 1000000)
    envelope =
      turbo.domain.SignalEnvelope.SignalEnvelope
        kind
        (ChannelId.fromText ("channel-" ++ suffix))
        (UserId.fromText ("from-" ++ suffix))
        (DeviceId.fromText ("from-device-" ++ suffix))
        (UserId.fromText ("to-" ++ suffix))
        (DeviceId.fromText ("to-device-" ++ suffix))
        ("payload-" ++ suffix)
    labeled "json roundtrip preserves the envelope" do
      ensureEqual
        (catch do
          turbo.domain.SignalEnvelope.fromText
            (Json.toText (turbo.domain.SignalEnvelope.toJson envelope)))
        (Right envelope)

turbo.service.ws.internal.signalUsesActiveTransmitTarget :
  turbo.domain.SignalKind -> Boolean
turbo.service.ws.internal.signalUsesActiveTransmitTarget = cases
  turbo.domain.SignalKind.AudioChunk    -> true
  turbo.domain.SignalKind.TransmitStart -> true
  turbo.domain.SignalKind.TransmitStop  -> true
  _                                     -> false

turbo.service.ws.internal.signalUsesActiveTransmitTarget.tests.examples :
  [Result]
turbo.service.ws.internal.signalUsesActiveTransmitTarget.tests.examples = 
  test.verify do
    ensureEqual
      true
      (turbo.service.ws.internal.signalUsesActiveTransmitTarget
        turbo.domain.SignalKind.AudioChunk)
    ensureEqual
      true
      (turbo.service.ws.internal.signalUsesActiveTransmitTarget
        turbo.domain.SignalKind.TransmitStart)
    ensureEqual
      true
      (turbo.service.ws.internal.signalUsesActiveTransmitTarget
        turbo.domain.SignalKind.TransmitStop)
    ensureEqual
      false
      (turbo.service.ws.internal.signalUsesActiveTransmitTarget
        turbo.domain.SignalKind.ReceiverReady)
    ensureEqual
      false
      (turbo.service.ws.internal.signalUsesActiveTransmitTarget
        turbo.domain.SignalKind.DirectQuicUpgradeRequest)
    ensureEqual
      false
      (turbo.service.ws.internal.signalUsesActiveTransmitTarget
        turbo.domain.SignalKind.SelectedPeerPrewarm)

turbo.service.ws.internal.signalUsesPreJoinDirectQuicSetupTarget :
  turbo.domain.SignalKind -> Boolean
turbo.service.ws.internal.signalUsesPreJoinDirectQuicSetupTarget = cases
  turbo.domain.SignalKind.DirectQuicUpgradeRequest -> true
  turbo.domain.SignalKind.SelectedPeerPrewarm      -> true
  turbo.domain.SignalKind.Offer                    -> true
  turbo.domain.SignalKind.Answer                   -> true
  turbo.domain.SignalKind.IceCandidate             -> true
  _                                                -> false

turbo.service.ws.internal.signalUsesPreJoinDirectQuicSetupTarget.tests.examples :
  [Result]
turbo.service.ws.internal.signalUsesPreJoinDirectQuicSetupTarget.tests.examples = 
  test.verify do
    ensureEqual
      true
      (turbo.service.ws.internal.signalUsesPreJoinDirectQuicSetupTarget
        turbo.domain.SignalKind.DirectQuicUpgradeRequest)
    ensureEqual
      true
