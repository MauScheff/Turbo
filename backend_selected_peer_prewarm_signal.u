  }}

turbo.service.presence.internal.clearStaleActiveChannelOnSessionConnect :
  Database -> UserId -> DeviceId -> '{Exception, Storage, Remote, Random} ()
turbo.service.presence.internal.clearStaleActiveChannelOnSessionConnect
  db currentUserId currentDeviceId =
  do
    sessionConnected = sessions.isConnected db currentDeviceId ()
    socketConnected = sockets.isConnected db currentDeviceId ()
    staleChannelIdOpt =
      staleActiveChannelOnSessionConnect
        currentUserId
        currentDeviceId
        sessionConnected
        socketConnected
        (presence.get db currentDeviceId ())
        ()
    match staleChannelIdOpt with
      Some channelId ->
        _ =
          appendStaleActiveChannelOnSessionConnectInvariant
            db currentUserId channelId currentDeviceId ()
        _ = clearActiveChannel db currentDeviceId currentUserId ()
        ()
      None -> ()

turbo.service.presence.offline :
  Database -> '{Route, Config, Exception, Http, Storage, Remote, Random} ()
turbo.service.presence.offline db =
  do
    use Parser /
    use Text ++
    use internal send
    use memberships remove
    use object empty
    use sockets disconnect
    noCapture POST (s "v1" / s "presence" / s "offline")
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        currentHandle =
          (User _ handleText _ _ _) = currentUser
          handleText
        fields = decodeJson (Decoder.object Decoder.text)
        match Map.get "deviceId" fields with
          None -> badRequest.json (empty |> addText "error" "missing deviceId")
          Some deviceIdText ->
            devTraffic = isWhitelistedDevHandle (Some currentHandle) ()
            deviceId = DeviceId.fromText deviceIdText
            currentChannelIdOpt =
              match presence.get db deviceId () with
                Some (DevicePresence _ _ _ currentChannelId _) ->
                  currentChannelId
                None -> None
            _ =
              match currentChannelIdOpt with
                Some channelId ->
                  _ =
                    runtime.endTransmit db channelId currentUserId deviceId ()
                  _ = clearActiveChannel db deviceId currentUserId ()
                  _ = remove db channelId currentUserId ()
                  match OrderedTable.tryRead
                    (channels.tables.byId db) channelId with
                    Some (DirectChannel _ lowUserId highUserId _) ->
                      peerUserId =
                        if userIdEqual lowUserId currentUserId then highUserId
                        else lowUserId
                      _ = remove db channelId peerUserId ()
                      match getRawForUserInChannel db peerUserId channelId () with
                        Some (DevicePresence peerDeviceId _ _ _ _) ->
                          _ = clearActiveChannel db peerDeviceId peerUserId ()
                          ()
                        None                                       -> ()
                    None -> ()
                None -> ()
            _ = disconnect db deviceId ()
            _ = disconnectCurrent db deviceId ()
            initialSessionConnected = sessions.isConnected db deviceId ()
            initialSocketConnected = sockets.isConnected db deviceId ()
            initialConnected =
              hasConnectedSessionEvidenceFromFlags
                initialSessionConnected initialSocketConnected
            _ =
              if initialConnected then
                _ = disconnect db deviceId ()
                _ = disconnectCurrent db deviceId ()
                ()
              else ()
            sessionConnected = sessions.isConnected db deviceId ()
            socketConnected = sockets.isConnected db deviceId ()
            repairPlan =
              offlineConnectedSessionRepairPlan
                initialSessionConnected
                initialSocketConnected
                sessionConnected
                socketConnected
            _ =
              match repairPlan with
                ConnectedSessionRepairSucceeded ->
                  metadata =
                    "deviceId="
                      ++ DeviceId.toText deviceId
                      ++ " sessionConnected="
                      ++ (if initialSessionConnected then "true" else "false")
                      ++ " socketConnected="
                      ++ (if initialSocketConnected then "true" else "false")
                  _ =
                    send
                      "backend.presence.offline.repair"
                      "backend"
                      "notice"
                      currentUserId
                      (Some currentHandle)
                      (Some deviceId)
                      currentChannelIdOpt
                      None
                      None
                      None
                      None
                      None
                      (Some "presence")
                      (Some "offline")
                      (Some
                        "presence.offline repaired connected session residue")
                      (Some metadata)
                      devTraffic
                      false
                      ()
                  ()
                _ -> ()
            _ =
              presence.upsert
                db deviceId currentUserId DevicePresenceStatus.Offline None ()
            _ =
              match repairPlan with
                LeaveChannel ->
                  _ = disconnect db deviceId ()
                  _ = disconnectCurrent db deviceId ()
                  finalSessionConnected = sessions.isConnected db deviceId ()
                  finalSocketConnected = sockets.isConnected db deviceId ()
                  finalRepairPlan =
                    offlineConnectedSessionRepairPlan
                      sessionConnected
                      socketConnected
                      finalSessionConnected
                      finalSocketConnected
                  _ =
                    match finalRepairPlan with
                      ConnectedSessionRepairSucceeded ->
                        metadata =
                          "deviceId="
                            ++ DeviceId.toText deviceId
                            ++ " sessionConnected="
                            ++ (if sessionConnected then "true" else "false")
                            ++ " socketConnected="
                            ++ (if socketConnected then "true" else "false")
                            ++ " repairPass=post-offline-write"
                        _ =
                          send
                            "backend.presence.offline.repair"
                            "backend"
                            "notice"
                            currentUserId
                            (Some currentHandle)
                            (Some deviceId)
                            currentChannelIdOpt
                            None
                            None
                            None
                            None
                            None
                            (Some "presence")
                            (Some "offline")
                            (Some
                              "presence.offline repaired connected session residue after offline write")
                            (Some metadata)
                            devTraffic
                            false
                            ()
                        ()
                      ConnectedSessionRepairFailed ->
                        appendOfflineRetainedConnectedSessionInvariant
                          db
                          currentUserId
                          (Some currentHandle)
                          deviceId
                          finalSessionConnected
                          finalSocketConnected
                          ()
                      NoConnectedSessionRepairNeeded -> ()
                  ()
                _ -> ()
            _ =
              send
                "backend.presence.offline"
                "backend"
                "notice"
                currentUserId
                (Some currentHandle)
                (Some deviceId)
                currentChannelIdOpt
                None
                None
                None
                None
                None
                (Some "presence")
                (Some "offline")
                (Some "presence transitioned to offline")
                None
                devTraffic
                false
                ()
            ok.json
              (empty
                |> addText "deviceId" deviceIdText
                |> addText "userId" (UserId.toText currentUserId)
                |> addText "status" "offline")

turbo.service.presence.offline.doc : Doc
turbo.service.presence.offline.doc =
  {{
  {{ docExample 1 do db -> offline db }} records app-level offline presence for
  the caller's device.
  
  This is the explicit disconnect or clean-shutdown counterpart to
  {service.presence.heartbeat}. It also clears connected-session truth and
  active channel membership for the device immediately so peers stop projecting
  the session as live.
  }}

turbo.service.routes.channels :
  Database
  -> '{Route, Config, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.routes.channels db =
  use Route or
  or
    (channels.direct db)
    (or
      (channels.join db)
      (or
        (leave db)
        (or
          (channels.state db)
          (or
            (revokeEphemeralToken db)
            (or
              (channels.ephemeralToken db)
              (or
                (pttPushTarget db)
                (or
                  (channels.beginTransmit db)
                  (or
                    (channels.renewTransmit db)
                    (or (channels.endTransmit db) (readiness db))))))))))

turbo.service.routes.dev :
  Database
  -> '{Route, Config, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.routes.dev db =
  use Route or
  or
    (dev.deployStamp db)
    (or
      (seed db)
      (or
        (resetAll db)
        (or
          (resetState db)
          (or
            (clearDiagnosticsForDevice db)
            (or
              (clearDiagnostics db)
              (or
                (uploadDiagnostics db)
                (or
                  (latestDiagnostics db)
                  (or
                    (latestDiagnosticsForCurrentUser db)
                    (or
                      (runtimeInspection db)
                      (or
                        (uploadWakeEvent db)
                        (or
                          (recentWakeEvents db)
                          (or
                            (uploadInvariantEvent db)
                            (recentInvariantEvents db)))))))))))))

turbo.service.routes.users :
  Database -> '{Route, Exception, Http, Storage, Remote, Random, Log} ()
turbo.service.routes.users db =
  use Route or
  or
    (profile db)
    (or
      (resolveIdentity db)
      (or
        (contacts.forget db)
        (or
          (contacts.remember db)
          (or (summary db) (or (presenceByHandle db) (users.byHandle db))))))

turbo.service.web :
  Database
  -> '{Route,
  Config,
  Exception,
  Http,
  OpenWebSocket,
  Storage,
  Remote,
  WebSockets,
  Random,
  Log} ()
turbo.service.web db =
  use Route or
  or (api db) (or (ws db) (share db))

turbo.service.ws :
  Database
  -> '{Route,
  Config,
  Exception,
  Http,
  OpenWebSocket,
  Storage,
  Remote,
  WebSockets,
  Random,
  Log} ()
turbo.service.ws db =
  do
    use Parser & /
    use Remote cancel
    use object empty
    deviceIdOpt = route GET (s "v1" / s "ws" & (do ParseQuery.text "deviceId"))
    match deviceIdOpt with
      None -> badRequest.json (empty |> addText "error" "missing deviceId")
      Some deviceIdText ->
        match requireUser db () with
          Left err -> unauthorized.json (empty |> addText "error" err)
          Right currentUser ->
            currentUserId =
              (User userId _ _ _ _) = currentUser
              userId
            ws = openWebSocket
            deviceId = DeviceId.fromText deviceIdText
            _ =
              clearStaleActiveChannelOnSessionConnect
                db currentUserId deviceId ()
            session = sessions.connect db currentUserId deviceId ()
            sessionId = internal.sessionId session
            inbox = internal.inbox session
            _ = sockets.connect db currentUserId deviceId ws ()
            outboundTask = 
              forkAt pool() do
                toRemote do
                  sendQueuedEnvelopesForSession
                    db deviceId sessionId inbox ws ()
            freshnessTask = 
              forkAt pool() do
                toRemote do
                  keepSessionFreshWhileSocketOpen
                    db deviceId currentUserId sessionId ()
            _ =
              WebSockets.send
                ws
                (TextMessage
                  (Json.toText
                    (empty
                      |> addText "status" "connected"
                      |> addText "deviceId" deviceIdText
                      |> addText "sessionId" sessionId)))
            _ = 
              catch do
                forever do
                  _ = sessions.touch db deviceId sessionId ()
                  message = WebSockets.receive ws
                  handleMessageSafely
                    db currentUser deviceId sessionId ws message ()
            _ = cancel freshnessTask
            _ = cancel outboundTask
            _ = disconnectSocketForCurrentSession db deviceId sessionId ()
            sessions.disconnect db deviceId sessionId ()

turbo.service.ws.internal.appendActiveTransmitSenderPresenceDriftInvariant :
  Database
  -> UserId
  -> ChannelId
  -> DeviceId
  -> SignalKind
  -> '{Exception, Storage, Remote} ()
turbo.service.ws.internal.appendActiveTransmitSenderPresenceDriftInvariant
  db currentUserId channelId deviceId signalKind =
  do
    use Text ++
    metadata =
      "channelId="
        ++ ChannelId.toText channelId
        ++ " deviceId="
        ++ DeviceId.toText deviceId
        ++ " signalKind="
        ++ SignalKind.toText signalKind
    appendInvariantEvent
      db
      currentUserId
      "channel.active_transmit_sender_presence_drift"
      "backend"
      "backend"
      "active transmit matched the signaling sender while raw joined presence was missing"
      (Some metadata)
      ()

turbo.service.ws.internal.disconnectSocketForCurrentSession :
  Database -> DeviceId -> Text -> '{Exception, Storage, Remote} ()
turbo.service.ws.internal.disconnectSocketForCurrentSession
  db deviceId expectedSessionId =
  do
    currentSessionOpt = sessions.get db deviceId ()
    currentSessionMatches = match currentSessionOpt with
      Some session -> textEqual (sessionId session) expectedSessionId
      None         -> false
    if currentSessionMatches then sockets.disconnect db deviceId () else ()

turbo.service.ws.internal.executeControlCommand :
  Database
  -> User
  -> Optional DeviceId
  -> ControlCommandRequest
  -> '{Config, Exception, Http, Storage, Remote, Random} ControlCommandRouteResult
turbo.service.ws.internal.executeControlCommand
  db currentUser websocketDeviceIdOpt = cases
  ControlCommandRequest _ kind fields ->
    do
      match kind with
        ConnectRequest -> createControlCommand db currentUser fields ()
        JoinChannel ->
          match Map.get "channelId" fields with
            None -> ControlCommandRouteBadRequest "missing channelId"
            Some channelIdText ->
              joinControlCommandWithConnectedDevice
                db currentUser websocketDeviceIdOpt channelIdText fields ()
        LeaveChannel ->
          match Map.get "channelId" fields with
            None -> ControlCommandRouteBadRequest "missing channelId"
            Some channelIdText ->
              leaveControlCommand db currentUser channelIdText fields ()

turbo.service.ws.internal.forwardEnvelope :
  Database
  -> UserId
  -> DeviceId
  -> WebSocket
  -> SignalEnvelope
  -> '{Exception, Storage, Remote, WebSockets, Random} ()
turbo.service.ws.internal.forwardEnvelope
  db currentUserId currentDeviceId currentSocket envelope =
  do
    use Json toText
    use Text ==
    use WebSockets send
    use object empty
    resolved =
      resolveEnvelopeTargetWithRetry
        db currentUserId currentDeviceId envelope 6 ()
    match resolved with
      Left err ->
        send
          currentSocket (TextMessage (toText (empty |> addText "error" err)))
      Right resolvedEnvelope ->
        (SignalEnvelope kind channelId _ _ _ targetDeviceId payload) =
          resolvedEnvelope
        receiverStatusOpt =
          match kind with
            ReceiverReady -> Some AudioReadinessReady
            ReceiverNotReady ->
              if payload == "app-background-media-closed" then
                Some AudioReadinessWakeCapable
              else Some AudioReadinessWaiting
            _ -> None
        _ =
          match receiverStatusOpt with
            Some receiverStatus ->
              match sessions.get db currentDeviceId () with
                Some session ->
                  _ =
                    receiverAudioReadiness.upsert
                      db
                      channelId
                      currentUserId
                      currentDeviceId
                      (sessionId session)
                      receiverStatus
                      ()
                  ()
                None -> ()
            _ -> ()
        match lookupTargetInboxWithRetry db targetDeviceId 6 () with
          None ->
            send
              currentSocket
              (TextMessage
                (toText
                  (empty
                    |> addText "error" "target device has no routable inbox")))
          Some inbox -> SignalInbox.enqueue inbox resolvedEnvelope ()

turbo.service.ws.internal.handleMessage :
  Database
  -> User
  -> DeviceId
  -> Text
  -> WebSocket
  -> websockets.Message
  -> '{Config, Exception, Http, Storage, Remote, WebSockets, Random} ()
turbo.service.ws.internal.handleMessage
  db currentUser currentDeviceId currentSessionId currentSocket = cases
  TextMessage text ->
    do
      currentUserId =
        (User userId _ _ _ _) = currentUser
        userId
      match controlCommandFrameFromText text with
        ParsedControlCommandFrame request ->
          sendControlCommandResponse
            db currentUser currentDeviceId currentSocket request ()
        InvalidControlCommandFrame err ->
          sendInvalidControlCommandResponse currentSocket err ()
        NotControlCommandFrame ->
          handleSignalMessage
            db
            currentUserId
            currentDeviceId
            currentSessionId
            currentSocket
            text
            ()
  _ ->
    do
      WebSockets.send
        currentSocket
        (TextMessage
          (Json.toText
            (object.empty
              |> addText "error" "binary websocket messages are not supported")))

turbo.service.ws.internal.handleMessageSafely :
  Database
  -> User
  -> DeviceId
  -> Text
  -> WebSocket
  -> websockets.Message
  -> '{Config, Exception, Http, Storage, Remote, WebSockets, Random} ()
turbo.service.ws.internal.handleMessageSafely
  db currentUser currentDeviceId currentSessionId currentSocket message =
  do
    match catch do
      handleMessage
        db
        currentUser
        currentDeviceId
        currentSessionId
        currentSocket
        message
        () with
      Left _ ->
        WebSockets.send
          currentSocket
          (TextMessage
            (Json.toText
              (object.empty
                |> addText "error" "websocket message handling failed")))
      Right _ -> ()

turbo.service.ws.internal.handleSignalMessage :
  Database
  -> UserId
  -> DeviceId
  -> Text
  -> WebSocket
  -> Text
  -> '{Exception, Storage, Remote, WebSockets, Random} ()
turbo.service.ws.internal.handleSignalMessage
  db currentUserId currentDeviceId currentSessionId currentSocket text =
  do
    use Json toText
    use WebSockets send
    use object empty
    parsed = catch do
      envelope = SignalEnvelope.fromText text
      signalSessionId = sessionIdFromText text
      (envelope, signalSessionId)
    match parsed with
      Left _ ->
        send
          currentSocket
          (TextMessage
            (toText (empty |> addText "error" "invalid signaling payload")))
      Right (envelope, signalSessionId) ->
        if signalSessionAccepted currentSessionId signalSessionId then
          forwardEnvelope
            db currentUserId currentDeviceId currentSocket envelope ()
        else
          send
            currentSocket
            (TextMessage
              (toText (empty |> addText "error" "stale signaling session")))

turbo.service.ws.internal.keepSessionFreshWhileSocketOpen :
  Database
  -> DeviceId
  -> UserId
  -> Text
  ->{Exception, Storage, Remote, Random} '{Exception, Storage, Remote, Random} ()
turbo.service.ws.internal.keepSessionFreshWhileSocketOpen
  db deviceId userId sessionId =
  do
    touchedCurrentSession = isSome (sessions.touch db deviceId sessionId ())
    socketStillRegistered = isSome (sockets.lookup db deviceId ())
    if keepSessionFreshShouldContinue
      touchedCurrentSession socketStillRegistered then
      _ = store.presence.heartbeat db deviceId userId ()
      _ = Remote.sleepMicroseconds sessionFreshnessTouchIntervalMicroseconds
      keepSessionFreshWhileSocketOpen db deviceId userId sessionId ()
    else ()

turbo.service.ws.internal.lookupTargetInboxWithRetry :
  Database -> DeviceId -> Nat -> '{Exception, Remote} Optional SignalInbox
turbo.service.ws.internal.lookupTargetInboxWithRetry
  db targetDeviceId attemptsRemaining =
  do
    match sessions.get db targetDeviceId () with
      Some session -> Some (inbox session)
      None ->
        use Nat - <=
        remainingAfterThisAttempt =
          if attemptsRemaining <= 1 then 0 else attemptsRemaining - 1
        match remainingAfterThisAttempt with
          0 -> None
          _ ->
            _ = Remote.sleepMicroseconds 100000
            lookupTargetInboxWithRetry
              db targetDeviceId remainingAfterThisAttempt ()

turbo.service.ws.internal.resolveEnvelopeTarget :
  Database
  -> UserId
  -> DeviceId
  -> SignalEnvelope
  -> '{Exception, Storage, Remote, Random} Either Text SignalEnvelope
turbo.service.ws.internal.resolveEnvelopeTarget
  db currentUserId currentDeviceId = cases
  SignalEnvelope kind channelId fromUserId fromDeviceId toUserId _ payload ->
    do
      use Boolean not
      sameUser =
        textEqual (UserId.toText currentUserId) (UserId.toText fromUserId)
      sameDevice =
        textEqual
          (DeviceId.toText currentDeviceId) (DeviceId.toText fromDeviceId)
      activeTransmit = currentTransmit db channelId ()
      senderIsJoined =
        isDeviceJoinedInChannel db fromUserId fromDeviceId channelId ()
      senderCanReadChannel =
        userCanReadDirectChannel db channelId fromUserId ()
      signalUsesSetupTarget = signalUsesPreJoinDirectQuicSetupTarget kind
      senderMatchesActiveTransmit =
        activeTransmitMatchesSender fromUserId fromDeviceId activeTransmit
      transmitOwnedSignal = signalUsesActiveTransmitTarget kind
      senderAuthorizedByActiveTransmit =
        transmitOwnedSignal && senderMatchesActiveTransmit
      senderAuthorizedBySetupMembership =
        signalUsesSetupTarget && senderCanReadChannel
      senderIsAuthorized =
        senderIsJoined || senderAuthorizedByActiveTransmit
          || senderAuthorizedBySetupMembership
      if not sameUser
        || not sameDevice then
        Left "signaling sender does not match authenticated socket"
      else
        _ =
          if senderAuthorizedByActiveTransmit && not senderIsJoined then
            appendActiveTransmitSenderPresenceDriftInvariant
              db currentUserId channelId fromDeviceId kind ()
          else ()
        if not senderIsAuthorized then
          Left "signaling sender device is not joined to this channel"
        else
          targetPlan =
            signalTargetResolutionPlanFromActiveTransmit
              kind fromUserId fromDeviceId toUserId activeTransmit
          match targetPlan with
            SignalTargetResolutionUseActiveTransmitTarget targetDeviceId ->
              Right
                (SignalEnvelope
                  kind
                  channelId
                  fromUserId
                  fromDeviceId
                  toUserId
                  targetDeviceId
                  payload)
            SignalTargetResolutionUseConnectedPresence ->
              if signalUsesSetupTarget then
                match getForUser db toUserId () with
                  None -> Left "target user has no fresh receiving device"
                  Some (DevicePresence targetDeviceId _ _ _ _) ->
                    Right
                      (SignalEnvelope
                        kind
                        channelId
                        fromUserId
                        fromDeviceId
                        toUserId
                        targetDeviceId
                        payload)
              else
                match getConnectedForUserInChannel db toUserId channelId () with
                  None ->
                    Left
                      "target user has no connected receiving device in this channel"
                  Some (DevicePresence targetDeviceId _ _ _ _) ->
                    Right
                      (SignalEnvelope
                        kind
                        channelId
                        fromUserId
                        fromDeviceId
                        toUserId
                        targetDeviceId
                        payload)

turbo.service.ws.internal.resolveEnvelopeTarget.doc : Doc
turbo.service.ws.internal.resolveEnvelopeTarget.doc =
  {{
  {{
  docExample 4 do
    db currentUserId currentDeviceId envelope ->
      resolveEnvelopeTarget db currentUserId currentDeviceId envelope }}
  resolves a routable signaling envelope only when the authenticated sender
  device is authorized for the in-channel signal.
  
  The normal authorization path still requires the sender device to appear as
  the joined in-channel presence. For active transmit signal kinds, a matching
  backend transmit lease can also authorize the sender temporarily so
  transmit-owned signaling does not collapse during presence/session drift.
  
  For active transmit signal kinds, routing preserves the backend-chosen
  transmit target device so wake-capable delivery does not depend on a second
  presence lookup catching up first. Other signal kinds still route through the
  latest connected in-channel presence.
  
  **Also see:** {currentTransmit},
  {{ docLink (docEmbedTermLink do isDeviceJoinedInChannel) }}, {{
  docLink (docEmbedTermLink do getConnectedForUserInChannel) }}
  }}

turbo.service.ws.internal.resolveEnvelopeTargetWithRetry :
  Database
  -> UserId
  -> DeviceId
  -> SignalEnvelope
  -> Nat
  -> '{Exception, Storage, Remote, Random} Either Text SignalEnvelope
turbo.service.ws.internal.resolveEnvelopeTargetWithRetry
  db currentUserId currentDeviceId envelope attemptsRemaining =
  do
    use Nat - <= >
    resolved =
      resolveEnvelopeTarget db currentUserId currentDeviceId envelope ()
    match resolved with
      Right resolvedEnvelope -> Right resolvedEnvelope
      Left err ->
        remainingAfterThisAttempt =
          if attemptsRemaining <= 1 then 0 else attemptsRemaining - 1
        if isTransientTargetError err
          && remainingAfterThisAttempt > 0 then
          _ = Remote.sleepMicroseconds 100000
          resolveEnvelopeTargetWithRetry
            db
            currentUserId
            currentDeviceId
            envelope
            remainingAfterThisAttempt
            ()
        else Left err

turbo.service.ws.internal.sendControlCommandResponse :
  Database
  -> User
  -> DeviceId
  -> WebSocket
  -> ControlCommandRequest
  -> '{Config, Exception, Http, Storage, Remote, WebSockets, Random} ()
turbo.service.ws.internal.sendControlCommandResponse
  db currentUser currentDeviceId currentSocket request =
  do
    (ControlCommandRequest requestId kind _) = request
    result =
      executeControlCommand db currentUser (Some currentDeviceId) request ()
    body = websocketResponseJson requestId kind result
    WebSockets.send currentSocket (TextMessage (Json.toText body))

turbo.service.ws.internal.sendQueuedEnvelopes :
  SignalInbox -> WebSocket -> '{Exception, Remote, WebSockets} ()
turbo.service.ws.internal.sendQueuedEnvelopes inbox ws =
  do
    forever do
      envelope = SignalInbox.dequeue inbox ()
      WebSockets.send
        ws (TextMessage (Json.toText (SignalEnvelope.toJson envelope)))

turbo.service.ws.internal.sendQueuedEnvelopesForSession :
  Database
  -> DeviceId
  -> Text
  -> SignalInbox
  -> WebSocket
  -> '{Exception, Storage, Remote, WebSockets} ()
turbo.service.ws.internal.sendQueuedEnvelopesForSession
  db deviceId sessionId inbox ws =
  do
    envelope = SignalInbox.dequeue inbox ()
    sent = 
      catch do
        WebSockets.send
          ws (TextMessage (Json.toText (SignalEnvelope.toJson envelope)))
    match sent with
      Right _ ->
        sendQueuedEnvelopesForSession db deviceId sessionId inbox ws ()
      Left _ ->
        _ = disconnectSocketForCurrentSession db deviceId sessionId ()
        sessions.disconnect db deviceId sessionId ()

turbo.service.ws.internal.signalTargetResolutionPlanFromActiveTransmit :
  SignalKind
  -> UserId
  -> DeviceId
  -> UserId
  -> Optional TransmitState
  -> SignalTargetResolutionPlan
turbo.service.ws.internal.signalTargetResolutionPlanFromActiveTransmit
  kind fromUserId fromDeviceId toUserId activeTransmit =
  if signalUsesActiveTransmitTarget kind then
    match activeTransmit with
      Some
        (TransmitState
          _
          activeFromUserId
          activeFromDeviceId
          activeToUserId
          activeToDeviceId
          _
          _) ->
        sameSenderUser =
          textEqual (UserId.toText activeFromUserId) (UserId.toText fromUserId)
        sameSenderDevice =
          textEqual
            (DeviceId.toText activeFromDeviceId) (DeviceId.toText fromDeviceId)
        sameTargetUser =
          textEqual (UserId.toText activeToUserId) (UserId.toText toUserId)
        if sameSenderUser && sameSenderDevice && sameTargetUser then
          SignalTargetResolutionUseActiveTransmitTarget activeToDeviceId
        else SignalTargetResolutionUseConnectedPresence
      None -> SignalTargetResolutionUseConnectedPresence
  else SignalTargetResolutionUseConnectedPresence

test> turbo.service.ws.internal.signalTargetResolutionPlanFromActiveTransmit.tests.examples = 
  test.verify do
    channelId = ChannelId.fromText "channel-123"
    senderUserId = UserId.fromText "sender-user"
    senderDeviceId = DeviceId.fromText "sender-device"
    targetUserId = UserId.fromText "target-user"
    targetDeviceId = DeviceId.fromText "target-device"
    otherUserId = UserId.fromText "other-user"
    startedAt = epoch
    expiresAt = epoch
    activeTransmit =
      Some
        (TransmitState
          channelId
          senderUserId
          senderDeviceId
          targetUserId
          targetDeviceId
          startedAt
          expiresAt)
    ensureEqual
      (SignalTargetResolutionUseActiveTransmitTarget targetDeviceId)
      (signalTargetResolutionPlanFromActiveTransmit
        AudioChunk senderUserId senderDeviceId targetUserId activeTransmit)
    ensureEqual
      SignalTargetResolutionUseConnectedPresence
      (signalTargetResolutionPlanFromActiveTransmit
        ReceiverReady senderUserId senderDeviceId targetUserId activeTransmit)
    ensureEqual
      SignalTargetResolutionUseConnectedPresence
      (signalTargetResolutionPlanFromActiveTransmit
        AudioChunk otherUserId senderDeviceId targetUserId activeTransmit)
    ensureEqual
      SignalTargetResolutionUseConnectedPresence
      (signalTargetResolutionPlanFromActiveTransmit
        AudioChunk senderUserId senderDeviceId otherUserId activeTransmit)

turbo.setApnsPrivateKeyFromPath : Text -> '{IO, Exception} ()
turbo.setApnsPrivateKeyFromPath pathText = do
  pemText = readFileUtf8 (FilePath pathText)
  setApnsPrivateKey pemText ()

turbo.store.presence.getConnectedForUser :
  Database -> UserId -> '{Exception, Remote, Random} Optional DevicePresence
turbo.store.presence.getConnectedForUser db userId = do
  entries = Stream.toList (OrderedTable.toStream (presence.tables.byDevice db))
  firstConnectedPresenceForUser db userId entries ()

turbo.store.presence.getConnectedForUser.doc : Doc
turbo.store.presence.getConnectedForUser.doc =
  {{
  {{ docExample 2 do db userId -> getConnectedForUser db userId }} returns the
  most recent fresh connected device presence for `userId`, if one exists.
  
  Unlike {getForUser}, this helper also requires connected-session evidence
  instead of relying only on a fresh presence heartbeat.
  
  **Also see:** {{ docLink (docEmbedTermLink do getForUser) }}, {{
  docLink (docEmbedTermLink do sessions.isConnected) }}
  }}

turbo.store.presence.getConnectedForUserInChannel :
  Database
  -> UserId
  -> ChannelId
  -> '{Exception, Remote, Random} Optional DevicePresence
turbo.store.presence.getConnectedForUserInChannel db userId channelId =
  do
    indexedEntries =
      Stream.toList
        (rangeClosed.prefix
          (byUserChannelDevice db)
          userChannelPrefixOrdering
          (userId, channelId)
          (userId, channelId))
    entries =
      List.map
        (cases ((_, _, deviceId), presence) -> (deviceId, presence))
        indexedEntries
    bestConnectedPresence db userId channelId entries None ()

turbo.store.presence.getConnectedForUserInChannel.doc : Doc
turbo.store.presence.getConnectedForUserInChannel.doc =
  {{
  {{
  docExample 3 do
    db userId channelId -> getConnectedForUserInChannel db userId channelId }}
  returns the most recently active connected in-channel device presence for
  `userId`.
  
  When multiple stale or concurrent devices exist, the backend prefers the
  session with the newest observed websocket activity.
  
  **Also see:** {sessions.touch}, {resolveTransmitTarget}
  }}

turbo.store.presence.getForUser.doc : Doc
turbo.store.presence.getForUser.doc =
  {{
  {{ docExample 2 do db userId -> getForUser db userId }} returns the first
  fresh online device presence for `userId`, if one exists.
  
  Freshness is derived from the presence heartbeat timestamp rather than
  websocket session ownership.
  
  **Also see:** {{ docLink (docEmbedTermLink do presence.get) }}, {{
  docLink (docEmbedTermLink do getForUserInChannel) }}
  }}

turbo.store.presence.getForUserInChannel :
  Database
  -> UserId
  -> ChannelId
  -> '{Exception, Remote, Random} Optional DevicePresence
turbo.store.presence.getForUserInChannel db userId channelId =
  do
    indexedEntries =
      Stream.toList
        (rangeClosed.prefix
          (byUserChannelDevice db)
          userChannelPrefixOrdering
          (userId, channelId)
          (userId, channelId))
    entries =
      List.map
        (cases ((_, _, deviceId), presence) -> (deviceId, presence))
        indexedEntries
    firstConnectedPresence db userId channelId entries ()

turbo.store.presence.getForUserInChannel.doc : Doc
turbo.store.presence.getForUserInChannel.doc =
  {{
  {{
  docExample 3 do
    db userId channelId -> getForUserInChannel db userId channelId }} returns
  the fresh online device presence for `userId` in `channelId`, if one exists
  and the device still has a live connected session.
  
  This lookup requires both a recent heartbeat and a live websocket-backed
  session for the device.
  
  **Also see:** {{ docLink (docEmbedTermLink do presence.get) }}, {{
  docLink (docEmbedTermLink do resolveTransmitTarget) }}
  }}

turbo.store.presence.internal.bestConnectedPresence :
  Database
  -> UserId
  -> ChannelId
  -> [(DeviceId, DevicePresence)]
  -> Optional (DeviceSession, DevicePresence)
  -> '{Exception, Remote, Random} Optional DevicePresence
turbo.store.presence.internal.bestConnectedPresence
  db userId channelId entries currentBest =
  do
    use Instant >=
    now = now!
    match entries with
      [] -> Optional.map (cases (_, presence) -> presence) currentBest
      (_, presence@(DevicePresence deviceId _ _ _ _)) +: rest ->
        if Boolean.and
          (matchesOnlinePresence userId channelId presence)
          (presence.internal.isFresh now presence) then
          if hasConnectedSessionEvidence db deviceId () then
            match sessions.get db deviceId () with
              None ->
                bestConnectedPresence db userId channelId rest currentBest ()
              Some candidateSession ->
                nextBest =
                  match currentBest with
                    None -> Some (candidateSession, presence)
                    Some (bestSession, bestPresence) ->
                      if lastSeenAt candidateSession >= lastSeenAt bestSession then
                        Some (candidateSession, presence)
                      else Some (bestSession, bestPresence)
                bestConnectedPresence db userId channelId rest nextBest ()
          else bestConnectedPresence db userId channelId rest currentBest ()
        else bestConnectedPresence db userId channelId rest currentBest ()

turbo.store.presence.internal.firstConnectedPresence :
  Database
  -> UserId
  -> ChannelId
  -> [(DeviceId, DevicePresence)]
  -> '{Exception, Remote, Random} Optional DevicePresence
turbo.store.presence.internal.firstConnectedPresence
  db userId channelId entries =
  do
    now = now!
    match entries with
      [] -> None
      (_, presence@(DevicePresence deviceId _ _ _ _)) +: rest ->
        if
          Boolean.and
            (matchesOnlinePresence userId channelId presence)
            (presence.internal.isFresh now presence) then
          if hasConnectedSessionEvidence db deviceId () then Some presence
          else firstConnectedPresence db userId channelId rest ()
        else firstConnectedPresence db userId channelId rest ()

turbo.store.presence.internal.firstConnectedPresenceForUser :
  Database
  -> UserId
  -> [(DeviceId, DevicePresence)]
  -> '{Exception, Remote, Random} Optional DevicePresence
turbo.store.presence.internal.firstConnectedPresenceForUser db userId entries =
  do
    use Text ==
    use UserId toText
    now = now!
    match entries with
      [] -> None
      (_, presence@(DevicePresence deviceId candidateUserId status _ _)) +: rest ->
        sameUser = toText candidateUserId == toText userId
        isOnline = match status with
          DevicePresenceStatus.Online  -> true
          DevicePresenceStatus.Offline -> false
        if sameUser && isOnline && presence.internal.isFresh now presence then
          if sessions.isConnected db deviceId () then Some presence
          else firstConnectedPresenceForUser db userId rest ()
        else firstConnectedPresenceForUser db userId rest ()

turbo.store.presence.internal.hasConnectedSessionEvidence :
  Database -> DeviceId -> '{Exception, Remote, Random} Boolean
turbo.store.presence.internal.hasConnectedSessionEvidence db deviceId = do
  sessionConnected = sessions.isConnected db deviceId ()
  socketOpen = isSome (sockets.lookup db deviceId ())
  hasConnectedSessionEvidenceFromFlags sessionConnected socketOpen

turbo.store.presence.isDeviceJoinedInChannel.doc : Doc
turbo.store.presence.isDeviceJoinedInChannel.doc =
  {{
  {{
  docExample 4 do
    db userId deviceId channelId ->
      isDeviceJoinedInChannel db userId deviceId channelId }} returns whether
  `deviceId` is the caller's currently online joined presence for `channelId`.
  
  This is the websocket sender-side participation check and avoids relying on a
  separate membership row becoming visible before routing.
  
  **Also see:** {presence.get}, {getConnectedForUserInChannel}
  }}

turbo.store.receiverAudioReadiness.getForCurrentSession :
  Database
  -> ChannelId
  -> UserId
  -> DeviceId
  -> '{Exception, Remote} Optional ReceiverAudioReadinessRecord
turbo.store.receiverAudioReadiness.getForCurrentSession
  db channelId userId deviceId =
  do
    recordOpt =
      OrderedTable.tryRead
        (receiverAudioReadiness.tables.byChannelUserDevice db)
        (channelId, userId, deviceId)
    sessionOpt = sessions.get db deviceId ()
    match (recordOpt, sessionOpt) with
      (Some record, Some session) ->
        if
          textEqual
            (receiverAudioReadinessRecordSessionId record) (sessionId session) then
          Some record
        else None
      _ -> None

turbo.store.receiverAudioReadiness.isReadyForCurrentSession :
  Database -> ChannelId -> UserId -> DeviceId -> '{Exception, Remote} Boolean
turbo.store.receiverAudioReadiness.isReadyForCurrentSession
  db channelId userId deviceId =
  do match getForCurrentSession db channelId userId deviceId () with
    Some record -> receiverAudioReadinessRecordIsReady record
    None        -> false

turbo.store.receiverAudioReadiness.statusForCurrentSession :
  Database
  -> ChannelId
  -> UserId
  -> DeviceId
  -> '{Exception, Remote} AudioReadinessStatus
turbo.store.receiverAudioReadiness.statusForCurrentSession
  db channelId userId deviceId =
  do match getForCurrentSession db channelId userId deviceId () with
    Some record -> receiverAudioReadinessRecordStatus record
    None        -> AudioReadinessUnknown

turbo.store.runtime.resolveTransmitTarget :
  Database
  -> ChannelId
  -> UserId
  -> '{Exception, Remote, Random} Either Text (UserId, DeviceId)
turbo.store.runtime.resolveTransmitTarget db channelId senderUserId =
  do
    channelOpt = OrderedTable.tryRead (channels.tables.byId db) channelId
    match channelOpt with
      None -> Left "channel not found"
      Some channel ->
        targetUserId = internal.targetUserId channel senderUserId
        wakeCapableTargetDeviceId =
          match latestForUserInChannel db channelId targetUserId () with
            Some (EphemeralToken _ _ targetDeviceId _ _) -> Some targetDeviceId
            None                                         -> None
        match getConnectedForUserInChannel db targetUserId channelId () with
          Some (DevicePresence targetDeviceId _ _ _ _) ->
            if isReadyForCurrentSession
              db channelId targetUserId targetDeviceId () then
              Right (targetUserId, targetDeviceId)
            else
              match wakeCapableTargetDeviceId with
                Some wakeCapableTargetDeviceId ->
                  Right (targetUserId, wakeCapableTargetDeviceId)
                None -> Left "target receiving device audio is not ready"
          None ->
            match wakeCapableTargetDeviceId with
              Some wakeCapableTargetDeviceId ->
                Right (targetUserId, wakeCapableTargetDeviceId)
              None ->
                Left
                  "no connected or wake-capable receiving device for target user"

turbo.store.runtime.resolveTransmitTarget.doc : Doc
turbo.store.runtime.resolveTransmitTarget.doc =
  {{
  {{
  docExample 3 do
    db channelId senderUserId ->
      resolveTransmitTarget db channelId senderUserId }} resolves the receiving
  target for a transmit attempt.
  
  The backend prefers a currently connected joined device for the other
  direct-channel member. If there is no connected presence, it falls back to
  that user's latest PushToTalk token device for the channel so wake-capable
  transmit can still begin.
  
  **Also see:** {getConnectedForUserInChannel}, {latestForUserInChannel},
  {runtime.beginTransmit}
  }}

turbo.store.sessions.connect :
  Database
  -> UserId
  -> DeviceId
  -> '{Exception, Storage, Remote, Random} DeviceSession
turbo.store.sessions.connect db userId deviceId = do
  now = now!
  sessionId = Uuid.toText newv4()
  inbox = SignalInbox.new()
  session = DeviceSession sessionId deviceId userId inbox now now
  OrderedTable.write (sessions.tables.byDevice db) deviceId session
  session

turbo.store.sessions.connect.doc : Doc
turbo.store.sessions.connect.doc =
  {{
  {{ docExample 3 do db userId deviceId -> sessions.connect db userId deviceId
  }} creates a fresh websocket session identity and per-device remote inbox for
  `deviceId`.
  
  The returned session is the authoritative routable transport record for the
  current connection.
  
  **Also see:** {{ docLink (docEmbedTermLink do sessions.touch) }},
  {{ docLink (docEmbedTermLink do sessions.disconnect) }}, {{
  docLink (docEmbedTermLink do SignalInbox.enqueue) }}
  }}

turbo.store.sessions.disconnect :
  Database -> DeviceId -> Text -> '{Exception, Storage, Remote} ()
turbo.store.sessions.disconnect db deviceId expectedSessionId = do
  table = sessions.tables.byDevice db
  match OrderedTable.tryRead table deviceId with
    Some session ->
      if textEqual (sessionId session) expectedSessionId then
        _ = SignalInbox.delete (inbox session) ()
        OrderedTable.delete table deviceId
      else ()
    None         -> ()

turbo.store.sessions.disconnect.doc : Doc
turbo.store.sessions.disconnect.doc =
  {{
  {{
  docExample 3 do
    db deviceId expectedSessionId ->
      sessions.disconnect db deviceId expectedSessionId }} removes the current
  websocket session for `deviceId` only if the stored session still matches
  `expectedSessionId`.
  
  If it matches, the associated remote inbox is deleted as part of cleanup.
  
  **Also see:** {{ docLink (docEmbedTermLink do sessions.connect) }}, {{
  docLink (docEmbedTermLink do SignalInbox.delete) }}
  }}

turbo.store.sessions.disconnectCurrent :
  Database -> DeviceId -> '{Exception, Storage, Remote} ()
turbo.store.sessions.disconnectCurrent db deviceId =
  do match sessions.get db deviceId () with
    Some session -> sessions.disconnect db deviceId (sessionId session) ()
    None         -> ()

turbo.store.sessions.get :
  Database -> DeviceId -> '{Exception, Remote} Optional DeviceSession
turbo.store.sessions.get db deviceId =
  do OrderedTable.tryRead (sessions.tables.byDevice db) deviceId

turbo.store.sessions.get.doc : Doc
turbo.store.sessions.get.doc =
  {{
  {{ docExample 2 do db deviceId -> sessions.get db deviceId }} returns the
  active websocket session record for `deviceId`, including its routable inbox.
  
  **Also see:** {{ docLink (docEmbedTermLink do sessions.connect) }}, {{
  docLink (docEmbedTermLink do sessions.isConnected) }}
  }}

turbo.store.sessions.internal.inbox : DeviceSession -> SignalInbox
turbo.store.sessions.internal.inbox = cases
  DeviceSession _ _ _ inbox _ _ -> inbox

turbo.store.sessions.internal.isFresh : Instant -> DeviceSession -> Boolean
turbo.store.sessions.internal.isFresh now = cases
  DeviceSession _ _ _ _ _ observedAt -> isFreshFromLastSeen now observedAt

turbo.store.sessions.internal.lastSeenAt : DeviceSession -> Instant
turbo.store.sessions.internal.lastSeenAt = cases
  DeviceSession _ _ _ _ _ lastSeenAt -> lastSeenAt

turbo.store.sessions.internal.sessionId : DeviceSession -> Text
turbo.store.sessions.internal.sessionId = cases
  DeviceSession sessionId _ _ _ _ _ -> sessionId

turbo.store.sessions.isConnected :
  Database -> DeviceId -> '{Exception, Remote, Random} Boolean
turbo.store.sessions.isConnected db deviceId = do
  now = now!
  match sessions.get db deviceId () with
    Some session -> sessions.internal.isFresh now session
    None         -> false

turbo.store.sessions.isConnected.doc : Doc
turbo.store.sessions.isConnected.doc =
  {{
  {{ docExample 2 do db deviceId -> sessions.isConnected db deviceId }} returns
  whether `deviceId` currently has a durable active websocket session.
  
  **Also see:** {{ docLink (docEmbedTermLink do sessions.get) }}, {{
  docLink (docEmbedTermLink do getConnectedForUserInChannel) }}
  }}

turbo.store.sessions.tables.byDevice :
  Database -> OrderedTable DeviceId DeviceSession
turbo.store.sessions.tables.byDevice db =
  OrderedTable.named db "turboDeviceSessionsByDevice_v2" Universal.ordering

turbo.store.sessions.touch :
  Database
  -> DeviceId
  -> Text
  -> '{Exception, Storage, Remote, Random} Optional DeviceSession
turbo.store.sessions.touch db deviceId expectedSessionId = do
  table = sessions.tables.byDevice db
  match OrderedTable.tryRead table deviceId with
    Some (DeviceSession sessionId _ userId inbox connectedAt _) ->
      if textEqual sessionId expectedSessionId then
        now = now!
        session = DeviceSession sessionId deviceId userId inbox connectedAt now
        _ = OrderedTable.write table deviceId session
        Some session
      else None
    None                                                        -> None

turbo.store.sessions.touch.doc : Doc
turbo.store.sessions.touch.doc =
  {{
  {{
  docExample 3 do
    db deviceId expectedSessionId ->
      sessions.touch db deviceId expectedSessionId }} refreshes the activity
  timestamp for the current websocket session if it still owns `deviceId`.
  
  This prevents stale reconnect cleanup from mutating a newer session.
  
  **Also see:** {{ docLink (docEmbedTermLink do sessions.connect) }}, {{
  docLink (docEmbedTermLink do sessions.get) }}
  }}

turbo.store.sessions.touchCurrent :
  Database
  -> DeviceId
  -> '{Exception, Storage, Remote, Random} Optional DeviceSession
turbo.store.sessions.touchCurrent db deviceId = do
  table = sessions.tables.byDevice db
  match OrderedTable.tryRead table deviceId with
    Some (DeviceSession sessionId _ userId inbox connectedAt _) ->
      now = now!
      session = DeviceSession sessionId deviceId userId inbox connectedAt now
      _ = OrderedTable.write table deviceId session
      Some session
    None                                                        -> None

turbo.store.sockets.connect.doc : Doc
turbo.store.sockets.connect.doc =
  {{
  {{
  docExample 4 do
    db userId deviceId ws -> sockets.connect db userId deviceId ws }} records
  the live websocket transport handle for `deviceId`.
  
  This registry is transport-local. Durable session truth lives in the
  `turbo.store.sessions.*` definitions.
  
  **Also see:** {{ docLink (docEmbedTermLink do sessions.connect) }},
  {sockets.lookup}, {{ docLink (docEmbedTermLink do sockets.disconnect) }}
  }}

turbo.store.sockets.disconnect.doc : Doc
turbo.store.sockets.disconnect.doc =
  {{
  {{ docExample 2 do db deviceId -> sockets.disconnect db deviceId }} removes
  the live websocket transport handle for `deviceId`.
  
  **Also see:** {{ docLink (docEmbedTermLink do sockets.connect) }}, {{
  docLink (docEmbedTermLink do sessions.disconnect) }}
  }}

turbo.store.sockets.isConnected.doc : Doc
turbo.store.sockets.isConnected.doc =
  {{
  {{ docExample 2 do db deviceId -> sockets.isConnected db deviceId }} returns
  whether this handler can currently look up a live websocket transport for
  `deviceId`.
  
  This is a transport-level diagnostic and should not be used as the durable
  readiness source.
  
  **Also see:** {{ docLink (docEmbedTermLink do sessions.isConnected) }},
  {sockets.lookup}
  }}

