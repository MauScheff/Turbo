turbo.schemaDrift.fixture.userId : UserId
turbo.schemaDrift.fixture.userId =
  UserId.fromText "user-schema-avery"

turbo.schemaDrift.fixture.peerUserId : UserId
turbo.schemaDrift.fixture.peerUserId =
  UserId.fromText "user-schema-blake"

turbo.schemaDrift.fixture.deviceId : DeviceId
turbo.schemaDrift.fixture.deviceId =
  DeviceId.fromText "device-schema-ios-a"

turbo.schemaDrift.fixture.peerDeviceId : DeviceId
turbo.schemaDrift.fixture.peerDeviceId =
  DeviceId.fromText "device-schema-ios-b"

turbo.schemaDrift.fixture.channelId : ChannelId
turbo.schemaDrift.fixture.channelId =
  ChannelId.fromText "channel-schema-direct"

turbo.schemaDrift.fixture.inviteId : InviteId
turbo.schemaDrift.fixture.inviteId =
  InviteId.fromText "invite-schema-direct"

turbo.schemaDrift.fixture.instant : Instant
turbo.schemaDrift.fixture.instant =
  Instant.fromEpochSeconds +1712345678

turbo.schemaDrift.fixture.laterInstant : Instant
turbo.schemaDrift.fixture.laterInstant =
  Instant.fromEpochSeconds +1712345689

turbo.schemaDrift.internal.hash : a -> Nat
turbo.schemaDrift.internal.hash value =
  Universal.murmurHashTyped value

turbo.schemaDrift.internal.serializedValueCanDeserialize : a -> Boolean
turbo.schemaDrift.internal.serializedValueCanDeserialize value =
  match Value.deserialize.impl (Value.serialize_v4 (Value.value value)) with
    Left _ -> false
    Right _ -> true

