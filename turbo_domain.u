turbo.domain.directChannelKey.doc =
  {{
  {{ docExample 2 do a b -> turbo.domain.directChannelKey a b }} returns a
  canonical ordered pair of user ids for direct-channel lookup. For example:
  
  ```
  turbo.domain.directChannelKey
    (turbo.domain.UserId.fromText "alice") (turbo.domain.UserId.fromText "bob")
  ```
  
  Swapping the inputs returns the same pair:
  
  ```
  turbo.domain.directChannelKey
    (turbo.domain.UserId.fromText "bob") (turbo.domain.UserId.fromText "alice")
  ```
  
  **Also see:** {{ docLink (docEmbedTermLink do turbo.domain.UserId.toText) }}
  
  # Implementation notes
  
    The pair is ordered lexicographically by the underlying text of the ids so
    the same direct channel key is produced regardless of caller order.
  }}

turbo.domain.directChannelKey :
  turbo.domain.UserId
  -> turbo.domain.UserId
  -> (turbo.domain.UserId, turbo.domain.UserId)
turbo.domain.directChannelKey left right =
  use Text <=
  if turbo.domain.UserId.toText left <= turbo.domain.UserId.toText right then
    (left, right)
  else (right, left)

test> turbo.domain.directChannelKey.tests.examples = 
  test.verify do
    labeled "keeps already ordered ids" do
      ensureEqual
        (turbo.domain.directChannelKey
          (turbo.domain.UserId.fromText "alice")
          (turbo.domain.UserId.fromText "bob"))
        ( turbo.domain.UserId.fromText "alice"
        , turbo.domain.UserId.fromText "bob"
        )
    labeled "normalizes reversed ids" do
      ensureEqual
        (turbo.domain.directChannelKey
          (turbo.domain.UserId.fromText "bob")
          (turbo.domain.UserId.fromText "alice"))
        ( turbo.domain.UserId.fromText "alice"
        , turbo.domain.UserId.fromText "bob"
        )
    labeled "keeps identical ids intact" do
      ensureEqual
        (turbo.domain.directChannelKey
          (turbo.domain.UserId.fromText "same")
          (turbo.domain.UserId.fromText "same"))
        ( turbo.domain.UserId.fromText "same"
        , turbo.domain.UserId.fromText "same"
        )

test> turbo.domain.directChannelKey.tests.props = 
  test.verify do
    use Nat toText
    use Text <=
    Each.repeat 100
    leftN = natIn 0 1000000
    rightN = natIn 0 1000000
    left = turbo.domain.UserId.fromText (toText leftN)
    right = turbo.domain.UserId.fromText (toText rightN)
    (low, high) = turbo.domain.directChannelKey left right
    labeled "result is ordered" do
      ensureEqual
        true
        (turbo.domain.UserId.toText low <= turbo.domain.UserId.toText high)
    labeled "swapping inputs is idempotent" do
      ensureEqual
        (turbo.domain.directChannelKey left right)
        (turbo.domain.directChannelKey right left)

turbo.serveLocal.doc =
  {{
  {{ docExample 0 do turbo.serveLocal }} runs Turbo's backend locally using the
  same shared service logic intended for deployment.
  
  This entrypoint serves the combined HTTP control plane and websocket
  signaling route under local cloud serving, keeps the local service alive so
  the printed hash URL remains reachable during development, and prints both
  named and hash local URLs for local debugging.
  }}

turbo.serveLocal :
  '{IO, Exception} ServiceHash
    HttpRequest (Either HttpResponse (WebSocket ->{Remote, WebSockets} ()))
turbo.serveLocal =
  do
    use Text ++
    setBuffering stdOut LineBuffering
    config = LocalCloudConfig.default() |> printBanners.set true
    Random.run do
      Threads.run do
        hash = 
          local.impl config do
            env = Environment.default()
            database = Database.named "turbo-local-control-plane"
            Database.assign database env
            localHttpService = httpWithConfig "local-cloud" true database
            hash =
              deployHttpWebSocket
                env (req -> Left (Route.run localHttpService req))
            serviceNameText = "turbo"
            serviceName = ServiceName.named serviceNameText
            namedUri = ServiceName.assign serviceName hash
            namedTxt0 = URI.toText namedUri
            namedTxt =
              if endsWith "/" namedTxt0 then namedTxt0 else namedTxt0 ++ "/"
            hashText = ServiceHash.toText hash
            printLine ("Named: " ++ namedTxt)
            printLine ("Hash:  http://localhost:8080/h/" ++ hashText ++ "/")
            hash
        printLine "Local Cloud computation starting. Press Enter to stop it.\n"
        _ = match catch do readLine() with
          Right _ -> ()
          Left _  -> ()
        hash

turbo.serveHttpLocal.doc =
  {{
  {{ docExample 0 do turbo.serveHttpLocal }} runs Turbo's HTTP control plane
  locally on a fixed development port.
  
  This entrypoint bypasses the websocket-style local cloud exposure and serves
  the HTTP routes through a plain local cloud HTTP service on port `8081`.
  }}

turbo.serveHttpLocal : '{IO, Exception} ()
turbo.serveHttpLocal =
  do
    use Text ++
    setBuffering stdOut LineBuffering
    config =
      LocalCloudConfig.default()
        |> printBanners.set true
        |> LocalCloudConfig.httpPort.set (Port.number 8081)
    Random.run do
      Threads.run do
        _ = 
          local.impl config do
            env = Environment.default()
            database = Database.named "turbo-local-control-plane"
            Database.assign database env
            localHttpService = httpWithConfig "local-http" false database
            hash = deployHttp env (Route.run localHttpService)
            serviceNameText = "turbo"
            serviceName = ServiceName.named serviceNameText
            namedUri = ServiceName.assign serviceName hash
            namedTxt0 = URI.toText namedUri
            namedTxt =
              if endsWith "/" namedTxt0 then namedTxt0 else namedTxt0 ++ "/"
            hashText = ServiceHash.toText hash
            printLine ("Named: " ++ namedTxt)
            printLine ("Hash:  http://localhost:8081/h/" ++ hashText ++ "/")
            ()
        printLine
          "Local HTTP computation starting on port 8081. Press Enter to stop it.\n"
        _ = match catch do readLine() with
          Right _ -> ()
          Left _  -> ()
        ()

turbo.deploy.doc =
  {{
  {{ docExample 0 do turbo.deploy }} deploys Turbo's backend to Unison Cloud.
  
  This entrypoint provisions the environment, attaches the database, and
  exposes the shared HTTP plus websocket Turbo service.
  }}

turbo.deploy : '{IO, Exception} URI
turbo.deploy = Cloud.main do
  env = Environment.named "turbo-production"
  database = Database.named "turbo-control-plane"
  Database.assign database env
  serviceHash = Route.deployWebSocket env (web database)
  serviceName = ServiceName.named "turbo"
  ServiceName.assign serviceName serviceHash

-- The definitions below no longer typecheck with the changes above.
