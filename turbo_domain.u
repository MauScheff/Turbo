type turbo.domain.UserIdTag = UserIdTag

type turbo.domain.DeviceIdTag = DeviceIdTag

type turbo.domain.ChannelIdTag = ChannelIdTag

type turbo.domain.UserId = UserId Text turbo.domain.UserIdTag

type turbo.domain.DeviceId = DeviceId Text turbo.domain.DeviceIdTag

type turbo.domain.ChannelId = ChannelId Text turbo.domain.ChannelIdTag

type turbo.domain.User
  = User turbo.domain.UserId Text Text Instant Instant

type turbo.domain.DevicePlatform
  = IOS

type turbo.domain.Device
  = Device
      turbo.domain.DeviceId
      turbo.domain.UserId
      turbo.domain.DevicePlatform
      (Optional Text)
      Instant
      Instant

type turbo.domain.DirectChannel
  = DirectChannel
      turbo.domain.ChannelId
      turbo.domain.UserId
      turbo.domain.UserId
      Instant

turbo.domain.UserId.toText.doc = {{

``UserId.toText userId`` returns the raw text inside `userId`. For example:

```
UserId.toText (UserId.fromText "alice")
```

*Also see:* {turbo.domain.directChannelKey}

}}
turbo.domain.UserId.toText : turbo.domain.UserId -> Text
turbo.domain.UserId.toText = cases
  UserId text _ -> text

turbo.domain.UserId.fromText.doc = {{

``UserId.fromText text`` wraps `text` as a user id.

*Also see:* {turbo.domain.UserId.toText}

}}
turbo.domain.UserId.fromText : Text -> turbo.domain.UserId
turbo.domain.UserId.fromText text = UserId text UserIdTag

turbo.domain.DeviceId.toText.doc = {{

``DeviceId.toText deviceId`` returns the raw text inside `deviceId`.

*Also see:* {turbo.domain.DeviceId.fromText}

}}
turbo.domain.DeviceId.toText : turbo.domain.DeviceId -> Text
turbo.domain.DeviceId.toText = cases
  DeviceId text _ -> text

turbo.domain.DeviceId.fromText.doc = {{

``DeviceId.fromText text`` wraps `text` as a device id.

*Also see:* {turbo.domain.DeviceId.toText}

}}
turbo.domain.DeviceId.fromText : Text -> turbo.domain.DeviceId
turbo.domain.DeviceId.fromText text = DeviceId text DeviceIdTag

turbo.domain.ChannelId.toText.doc = {{

``ChannelId.toText channelId`` returns the raw text inside `channelId`.

*Also see:* {turbo.domain.ChannelId.fromText}

}}
turbo.domain.ChannelId.toText : turbo.domain.ChannelId -> Text
turbo.domain.ChannelId.toText = cases
  ChannelId text _ -> text

turbo.domain.ChannelId.fromText.doc = {{

``ChannelId.fromText text`` wraps `text` as a channel id.

*Also see:* {turbo.domain.ChannelId.toText}

}}
turbo.domain.ChannelId.fromText : Text -> turbo.domain.ChannelId
turbo.domain.ChannelId.fromText text = ChannelId text ChannelIdTag

turbo.domain.directChannelKey.doc = {{

``directChannelKey a b`` returns a canonical ordered pair of user ids for direct-channel lookup. For example:

```
directChannelKey (UserId.fromText "alice") (UserId.fromText "bob")
```

Swapping the inputs returns the same pair:

```
directChannelKey (UserId.fromText "bob") (UserId.fromText "alice")
```

*Also see:* {turbo.domain.UserId.toText}

# Implementation notes

The pair is ordered lexicographically by the underlying text of the ids so the same direct channel key is produced regardless of caller order.

}}
turbo.domain.directChannelKey : turbo.domain.UserId -> turbo.domain.UserId -> (turbo.domain.UserId, turbo.domain.UserId)
turbo.domain.directChannelKey left right =
  if turbo.domain.UserId.toText left <= turbo.domain.UserId.toText right then
    (left, right)
  else
    (right, left)

test> turbo.domain.directChannelKey.tests.examples = test.verify do
  labeled "keeps already ordered ids" do
    test.ensureEqual
      (turbo.domain.directChannelKey (turbo.domain.UserId.fromText "alice") (turbo.domain.UserId.fromText "bob"))
      (turbo.domain.UserId.fromText "alice", turbo.domain.UserId.fromText "bob")
  labeled "normalizes reversed ids" do
    test.ensureEqual
      (turbo.domain.directChannelKey (turbo.domain.UserId.fromText "bob") (turbo.domain.UserId.fromText "alice"))
      (turbo.domain.UserId.fromText "alice", turbo.domain.UserId.fromText "bob")
  labeled "keeps identical ids intact" do
    test.ensureEqual
      (turbo.domain.directChannelKey (turbo.domain.UserId.fromText "same") (turbo.domain.UserId.fromText "same"))
      (turbo.domain.UserId.fromText "same", turbo.domain.UserId.fromText "same")

test> turbo.domain.directChannelKey.tests.props = test.verify do
  Each.repeat 100
  leftN = Random.natIn 0 1000000
  rightN = Random.natIn 0 1000000
  left = turbo.domain.UserId.fromText (Nat.toText leftN)
  right = turbo.domain.UserId.fromText (Nat.toText rightN)
  (low, high) = turbo.domain.directChannelKey left right
  labeled "result is ordered" do
    test.ensureEqual true (turbo.domain.UserId.toText low <= turbo.domain.UserId.toText high)
  labeled "swapping inputs is idempotent" do
    test.ensureEqual
      (turbo.domain.directChannelKey left right)
      (turbo.domain.directChannelKey right left)

turbo.serveLocal.doc = {{

``turbo.serveLocal`` runs Turbo's backend locally using the same shared service logic intended for deployment.

This entrypoint serves the combined HTTP control plane and websocket signaling route under local cloud serving, keeps the local service alive so the printed hash URL remains reachable during development, and prints both named and hash local URLs for local debugging.

}}
turbo.serveLocal :
  '{IO, Exception}
    ServiceHash
      HttpRequest
      (Either HttpResponse (WebSocket ->{Remote, WebSockets} ()))
turbo.serveLocal =
  do
    use Text ++
    setBuffering stdOut LineBuffering
    config = LocalCloudConfig.default() |> printBanners.set true
    Random.run do
      Threads.run do
        hash =
          Cloud.run.local.impl config do
            env = Environment.default()
            database = Database.named "turbo-local-control-plane"
            Database.assign database env
            localHttpService = turbo.service.httpWithConfig "local-cloud" true database
            hash =
              Cloud.deployHttpWebSocket env
                (req ->
                  Left ((Route.run localHttpService) req))
            serviceNameText = "turbo"
            serviceName = ServiceName.named serviceNameText
            namedUri = ServiceName.assign serviceName hash
            namedTxt0 = URI.toText namedUri
            namedTxt =
              if Text.endsWith "/" namedTxt0 then namedTxt0 else namedTxt0 ++ "/"
            hashText = ServiceHash.toText hash
            printLine ("Named: " ++ namedTxt)
            printLine ("Hash:  http://localhost:8080/h/" ++ hashText ++ "/")
            hash
        printLine "Local Cloud computation starting. Press Enter to stop it.\n"
        _ = match catch do readLine() with
          Right _ -> ()
          Left _  -> ()
        hash

turbo.serveHttpLocal.doc = {{

``turbo.serveHttpLocal`` runs Turbo's HTTP control plane locally on a fixed development port.

This entrypoint bypasses the websocket-style local cloud exposure and serves the HTTP routes through a plain local cloud HTTP service on port `8081`.

}}
turbo.serveHttpLocal : '{IO, Exception} ()
turbo.serveHttpLocal =
  do
    use Text ++
    setBuffering stdOut LineBuffering
    config =
      LocalCloudConfig.default()
        |> printBanners.set true
        |> httpPort.set (Port.number 8081)
    Random.run do
      Threads.run do
        _ =
          Cloud.run.local.impl config do
            env = Environment.default()
            database = Database.named "turbo-local-control-plane"
            Database.assign database env
            localHttpService = turbo.service.httpWithConfig "local-http" false database
            hash = Cloud.deployHttp env (Route.run localHttpService)
            serviceNameText = "turbo"
            serviceName = ServiceName.named serviceNameText
            namedUri = ServiceName.assign serviceName hash
            namedTxt0 = URI.toText namedUri
            namedTxt =
              if Text.endsWith "/" namedTxt0 then namedTxt0 else namedTxt0 ++ "/"
            hashText = ServiceHash.toText hash
            printLine ("Named: " ++ namedTxt)
            printLine ("Hash:  http://localhost:8081/h/" ++ hashText ++ "/")
            ()
        printLine "Local HTTP computation starting on port 8081. Press Enter to stop it.\n"
        _ = match catch do readLine() with
          Right _ -> ()
          Left _  -> ()
        ()

turbo.deploy.doc = {{

``turbo.deploy`` deploys Turbo's backend to Unison Cloud.

This entrypoint provisions the environment, attaches the database, and exposes the shared HTTP plus websocket Turbo service.

}}
turbo.deploy : '{IO, Exception} URI
turbo.deploy =
  Cloud.main do
    env = Environment.named "turbo-production"
    database = Database.named "turbo-control-plane"
    Database.assign database env
    serviceHash = Route.deployWebSocket env (turbo.service.web database)
    serviceName = ServiceName.named "turbo"
    ServiceName.assign serviceName serviceHash
