turbo.store.presence.getForUserInChannel.doc : base.Doc
turbo.store.presence.getForUserInChannel.doc =
  use base.syntax docCode docEmbedTermLink docGroup docJoin docLink docParagraph docTransclude docWord
  {{
  {{
  base.syntax.docExample 3 do
    db userId channelId -> getForUserInChannel db userId channelId }} returns
  the currently online device presence for `userId` in `channelId`, if one
  exists.
  
  This v1 lookup scans the presence table and returns the first matching online
  device bound to the channel.
  
  **Also see:** {{ docLink (docEmbedTermLink do presence.get) }}, {{
  docLink (docEmbedTermLink do resolveTransmitTarget) }}
  }}

turbo.store.runtime.resolveTransmitTarget :
  unison_cloud_27_3_0.Database
  -> ChannelId
  -> UserId
  -> '{base.abilities.Exception, unison_cloud_27_3_0.Remote} base.Either
    base.Text (UserId, DeviceId)
turbo.store.runtime.resolveTransmitTarget db channelId senderUserId =
  do
    use UserId toText
    use base.Either Left
    use base.Optional None Some
    use base.Text ==
    channelOpt =
      unison_cloud_27_3_0.durable.OrderedTable.tryRead
        (channels.tables.byId db) channelId
    match channelOpt with
      None -> Left "channel not found"
      Some channel ->
        targetUserId =
          (DirectChannel _ lowUserId highUserId _) = channel
          senderIsLow = toText senderUserId == toText lowUserId
          if senderIsLow then highUserId else lowUserId
        match getForUserInChannel db targetUserId channelId () with
          None -> Left "no active receiving device for target user"
          Some (DevicePresence targetDeviceId _ _ _ _) ->
            base.Either.Right (targetUserId, targetDeviceId)

turbo.store.runtime.resolveTransmitTarget.doc : base.Doc
turbo.store.runtime.resolveTransmitTarget.doc =
  use base.syntax docEmbedTermLink docLink docParagraph docTransclude docWord
  {{
  {{
  base.syntax.docExample 3 do
    db channelId senderUserId ->
      resolveTransmitTarget db channelId senderUserId }} resolves the receiving
  target for a transmit attempt.
  
  The backend finds the other direct-channel member and then selects that
  user's currently online device presence for the same channel.
  
  **Also see:** {{ docLink (docEmbedTermLink do getForUserInChannel) }}, {{
  docLink (docEmbedTermLink do runtime.beginTransmit) }}
  }}

