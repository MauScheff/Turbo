turbo.service.devices.register :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote,
  base.abilities.Random} ()
turbo.service.devices.register db =
  do
    use Parser /
    use base.Function |>
    use base.data.Map get
    use unison_json_1_3_5.core.Json.object addText empty
    Route.noCapture
      base.IO.net.URI.Method.POST (s "v1" / s "devices" / s "register")
    match requireUser db () with
      base.Either.Left err -> unauthorized.json (empty |> addText "error" err)
      base.Either.Right user ->
        fields =
          decodeJson
            (unison_json_1_3_5.Decoder.object unison_json_1_3_5.Decoder.text)
        deviceJson = cases
          Device deviceId userId platform deviceLabel _ lastSeenAt ->
            platformText =
              IOS = platform
              "ios"
            empty
              |> addText "deviceId" (DeviceId.toText deviceId)
              |> addText "userId" (UserId.toText userId)
              |> addText "platform" platformText
              |> unison_json_1_3_5.core.Json.object.addOptionalText
                   "deviceLabel" deviceLabel
              |> addText "lastSeenAt" (base.time.Instant.toText lastSeenAt)
        match get "deviceId" fields with
          base.Optional.Some deviceIdText ->
            deviceLabel = get "deviceLabel" fields
            device =
              store.devices.register
                db
                (match user with User.User userId _ _ _ _ -> userId)
                (DeviceId.fromText deviceIdText)
                DevicePlatform.IOS
                deviceLabel
                ()
            ok.json (deviceJson device)
          base.Optional.None ->
            badRequest.json (empty |> addText "error" "missing deviceId")

