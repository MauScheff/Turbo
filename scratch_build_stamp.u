turbo.service.invites.create :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote,
  base.abilities.Random} ()
turbo.service.invites.create db =
  do
    use Parser /
    use User User
    use UserId toText
    use base.Function |>
    use base.Optional None Some
    use base.Text ==
    use base.data.Map get
    use unison_json_1_3_5.core.Json.object addText empty
    Route.noCapture base.IO.net.URI.Method.POST (s "v1" / s "invites")
    match requireUser db () with
      base.Either.Left err -> unauthorized.json (empty |> addText "error" err)
      base.Either.Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        fields =
          decodeJson
            (unison_json_1_3_5.Decoder.object unison_json_1_3_5.Decoder.text)
        resolvedOther = match get "otherUserId" fields with
          Some otherUserIdText -> Some (UserId.fromText otherUserIdText)
          None                 ->
            match get "otherHandle" fields with
              None             -> None
              Some otherHandle ->
                match getByHandle db otherHandle () with
                  None                            -> None
                  Some (User otherUserId _ _ _ _) -> Some otherUserId
        match resolvedOther with
          None ->
            badRequest.json
              (empty |> addText "error" "missing otherUserId or otherHandle")
          Some otherUserId ->
            if toText otherUserId == toText currentUserId then
              badRequest.json (empty |> addText "error" "cannot invite self")
            else
              channel = getOrCreateDirect db currentUserId otherUserId ()
              channelId =
                (DirectChannel channelId _ _ _) = channel
                channelId
              invite = createOrReuse db currentUserId otherUserId channelId ()
              availability = users.availability db otherUserId ()
              inviteJson = internal.inviteJson db currentUserId invite ()
              ok.json
                (inviteJson
                  |> addText
                       "targetAvailability" (availabilityText availability)
                  |> (unison_json_1_3_5.core.Json.object.addBoolean
                       "shouldAutoJoinPeer"
                       match availability with
                       Available -> true
                       _         -> false))

turbo.service.invites.create.doc : base.Doc
turbo.service.invites.create.doc =
  use base.syntax docEmbedTermLink docLink docParagraph docTransclude docWord
  {{
  {{ base.syntax.docExample 1 do db -> invites.create db }} creates or reuses a
  pending direct invite.
  
  If the target user is online and idle, the response indicates that the peer
  should auto-join when it notices the incoming request.
  
  **Also see:** {createOrReuse}, {{ docLink (docEmbedTermLink do incoming) }}
  }}

