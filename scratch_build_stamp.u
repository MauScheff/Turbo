turbo.auth.devHandle.doc : base.Doc
turbo.auth.devHandle.doc =
  use base.syntax docCode docGroup docJoin docParagraph docTransclude docWord
  {{
  {{ base.syntax.docExample 0 do devHandle }} resolves the temporary dev
  identity from the current request.
  
  It first checks `x-turbo-user-handle`, then falls back to
  `Authorization: Bearer <handle>`.
  
  **Also see:** {{
  base.syntax.docLink (base.syntax.docEmbedTermLink do requireUser) }}
  }}

turbo.auth.requireUser :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote} base.Either base.Text User
turbo.auth.requireUser db = do match devHandle() with
  base.Optional.None            -> base.Either.Left "missing dev auth"
  base.Optional.Some userHandle ->
    match getByHandle db userHandle () with
      base.Optional.None      -> base.Either.Left "unknown dev user handle"
      base.Optional.Some user -> base.Either.Right user

turbo.auth.requireUser.doc : base.Doc
turbo.auth.requireUser.doc =
  use base.syntax docCode docEmbedTermLink docGroup docJoin docLink docParagraph docTransclude docWord
  {{
  {{ base.syntax.docExample 1 do db -> requireUser db }} resolves the current
  dev user from the request headers.
  
  It accepts either `x-turbo-user-handle` or `Authorization: Bearer <handle>`.
  
  Missing or unknown auth returns a descriptive error instead of failing the
  route.
  
  **Also see:** {{ docLink (docEmbedTermLink do devHandle) }},
  {{ docLink (docEmbedTermLink do getByHandle) }}, {{
  docLink (docEmbedTermLink do users.create) }}
  }}

turbo.service.auth.session :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote} ()
turbo.service.auth.session db =
  do
    use Parser /
    use base.Function |>
    use unison_json_1_3_5.core.Json.object addText empty
    Route.noCapture
      base.IO.net.URI.Method.POST (s "v1" / s "auth" / s "session")
    match requireUser db () with
      base.Either.Left err -> unauthorized.json (empty |> addText "error" err)
      base.Either.Right user ->
        userJson = cases
          User.User userId handleText displayName _ _ ->
            empty
              |> addText "userId" (UserId.toText userId)
              |> addText "handle" handleText
              |> addText "displayName" displayName
        ok.json (userJson user)

turbo.service.auth.session.doc : base.Doc
turbo.service.auth.session.doc =
  use base.syntax docParagraph docTransclude docWord
  {{
  {{ base.syntax.docExample 1 do db -> session db }} serves the dev auth
  session endpoint.
  
  It resolves the current user from the request header and returns a small
  identity payload.
  
  **Also see:** {{
  base.syntax.docLink (base.syntax.docEmbedTermLink do requireUser) }}
  }}

turbo.service.channels.beginTransmit :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote,
  base.abilities.Random} ()
turbo.service.channels.beginTransmit db =
  do
    use Parser /
    use base.Either Left Right
    use base.Function |>
    use base.time Instant.toText
    use unison_json_1_3_5.core.Json.object addText empty
    channelIdText =
      route
        base.IO.net.URI.Method.POST
        (s "v1" / s "channels" / Parser.text / s "begin-transmit")
    match requireUser db () with
      Left err -> unauthorized.json (empty |> addText "error" err)
      Right currentUser ->
        currentUserId =
          (User.User userId _ _ _ _) = currentUser
          userId
        fields =
          decodeJson
            (unison_json_1_3_5.Decoder.object unison_json_1_3_5.Decoder.text)
        channelId = ChannelId.fromText channelIdText
        isMember = memberships.exists db channelId currentUserId ()
        if base.Boolean.not isMember then
          unauthorized.json (empty |> addText "error" "not a channel member")
        else
          match base.data.Map.get "deviceId" fields with
            base.Optional.Some deviceIdText ->
              resolvedTarget =
                resolveTransmitTarget db channelId currentUserId ()
              match resolvedTarget with
                Left err -> badRequest.json (empty |> addText "error" err)
                Right (targetUserId, targetDeviceId) ->
                  result =
                    runtime.beginTransmit
                      db
                      channelId
                      currentUserId
                      (DeviceId.fromText deviceIdText)
                      targetUserId
                      targetDeviceId
                      ()
                  match result with
                    Left err -> badRequest.json (empty |> addText "error" err)
                    Right state ->
                      (startedAt, expiresAt) =
                        (TransmitState _ _ _ _ _ startedAt expiresAt) = state
                        (Instant.toText startedAt, Instant.toText expiresAt)
                      ok.json
                        (empty
                          |> addText "channelId" channelIdText
                          |> addText "status" "transmitting"
                          |> addText "startedAt" startedAt
                          |> addText "expiresAt" expiresAt
                          |> addText
                               "targetUserId" (UserId.toText targetUserId)
                          |> addText
                               "targetDeviceId"
                               (DeviceId.toText targetDeviceId))
            base.Optional.None ->
              badRequest.json (empty |> addText "error" "missing deviceId")

turbo.service.channels.direct :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote,
  base.abilities.Random} ()
turbo.service.channels.direct db =
  do
    use Parser /
    use User User
    use base.Function |>
    use base.Optional None Some
    use base.data.Map get
    use unison_json_1_3_5.core.Json.object addText empty
    Route.noCapture
      base.IO.net.URI.Method.POST (s "v1" / s "channels" / s "direct")
    match requireUser db () with
      base.Either.Left err -> unauthorized.json (empty |> addText "error" err)
      base.Either.Right currentUser ->
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        fields =
          decodeJson
            (unison_json_1_3_5.Decoder.object unison_json_1_3_5.Decoder.text)
        channelJson = cases
          DirectChannel channelId lowUserId highUserId createdAt ->
            empty
              |> addText "channelId" (ChannelId.toText channelId)
              |> addText "lowUserId" (UserId.toText lowUserId)
              |> addText "highUserId" (UserId.toText highUserId)
              |> addText "createdAt" (base.time.Instant.toText createdAt)
        resolvedOther = match get "otherUserId" fields with
          Some otherUserIdText -> Some (UserId.fromText otherUserIdText)
          None                 ->
            match get "otherHandle" fields with
              None             -> None
              Some otherHandle ->
                match getByHandle db otherHandle () with
                  None           -> None
                  Some otherUser ->
                    (User otherUserId _ _ _ _) = otherUser
                    Some otherUserId
        match resolvedOther with
          None ->
            badRequest.json
              (empty |> addText "error" "missing otherUserId or otherHandle")
          Some otherUserId ->
            channel = getOrCreateDirect db currentUserId otherUserId ()
            ok.json (channelJson channel)

turbo.service.channels.direct.doc : base.Doc
turbo.service.channels.direct.doc =
  use base.syntax docCode docEmbedTermLink docGroup docJoin docLink docParagraph docTransclude docWord
  {{
  {{ base.syntax.docExample 1 do db -> channels.direct db }} serves stable
  direct channel lookup and creation.
  
  The request body may identify the remote user by `otherUserId` or
  `otherHandle`.
  
  **Also see:** {{ docLink (docEmbedTermLink do getOrCreateDirect) }}, {{
  docLink (docEmbedTermLink do requireUser) }}
  }}

turbo.service.channels.endTransmit :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote,
  base.abilities.Random} ()
turbo.service.channels.endTransmit db =
  do
    use Parser /
    use base.Function |>
    use base.Optional None Some
    use unison_json_1_3_5.core.Json.object addText empty
    channelIdText =
      route
        base.IO.net.URI.Method.POST
        (s "v1" / s "channels" / Parser.text / s "end-transmit")
    match requireUser db () with
      base.Either.Left err -> unauthorized.json (empty |> addText "error" err)
      base.Either.Right currentUser ->
        currentUserId =
          (User.User userId _ _ _ _) = currentUser
          userId
        fields =
          decodeJson
            (unison_json_1_3_5.Decoder.object unison_json_1_3_5.Decoder.text)
        channelId = ChannelId.fromText channelIdText
        isMember = memberships.exists db channelId currentUserId ()
        if base.Boolean.not isMember then
          unauthorized.json (empty |> addText "error" "not a channel member")
        else
          match base.data.Map.get "deviceId" fields with
