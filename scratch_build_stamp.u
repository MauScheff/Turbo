turbo.service.dev.resetState.doc : base.Doc
turbo.service.dev.resetState.doc =
  use base.syntax docParagraph docWord
  {{
  `` resetState db `` clears Turbo's local dev runtime state.
  
  This deletes durable state that can get wedged during local iteration,
  including presence, pending or connected invites, transient transmit locks,
  and stored ephemeral tokens. It deliberately keeps seeded users, devices, and
  channels.
  
  **Also see:** {seed}
  }}

turbo.service.dev.seed :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote,
  base.abilities.Random} ()
turbo.service.dev.seed db =
  do
    use Parser /
    use base.Function |>
    use base.data.List map
    use unison_json_1_3_5.core.Json.object addText empty
    Route.noCapture base.IO.net.URI.Method.POST (s "v1" / s "dev" / s "seed")
    seeded =
      map
        (cases
          (userHandle, displayName) ->
            users.create db userHandle displayName ())
        defaultUsers
    usersJson =
      unison_json_1_3_5.core.Json.array
        (map
          (cases
            User.User userId handleText displayName _ _ ->
              empty
                |> addText "userId" (UserId.toText userId)
                |> addText "handle" handleText
                |> addText "displayName" displayName)
          seeded)
    ok.json
      (empty
        |> addText "status" "seeded"
        |> unison_json_1_3_5.core.Json.object.add "users" usersJson)

