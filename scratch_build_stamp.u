turbo.service.ws :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_http_15_0_0.client.Http,
  OpenWebSocket,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote,
  unison_cloud_27_3_0.websockets.WebSockets,
  base.abilities.Random,
  unison_cloud_27_3_0.Log} ()
turbo.service.ws db =
  do
    use Parser & /
    use base.Function |>
    use unison_json_1_3_5.core.Json.object addText empty
    deviceIdOpt =
      route
        base.IO.net.URI.Method.GET
        (s "v1" / s "ws" & (do ParseQuery.text "deviceId"))
    match deviceIdOpt with
      base.Optional.None ->
        badRequest.json (empty |> addText "error" "missing deviceId")
      base.Optional.Some deviceIdText ->
        match requireUser db () with
          base.Either.Left err ->
            unauthorized.json (empty |> addText "error" err)
          base.Either.Right currentUser ->
            currentUserId =
              (User.User userId _ _ _ _) = currentUser
              userId
            ws = openWebSocket
            deviceId = DeviceId.fromText deviceIdText
            _ = sockets.connect db currentUserId deviceId ws ()
            _ = base.abilities.Exception.catch do
              base.abilities.forever do
                message = unison_cloud_27_3_0.websockets.WebSockets.receive ws
                handleMessage db currentUserId deviceId ws message ()
            disconnect db deviceId ()

turbo.service.ws.doc : base.Doc
turbo.service.ws.doc =
  use base.syntax docCode docGroup docJoin docLink docParagraph docTransclude docWord
  {{
  {{ base.syntax.docExample 1 do db -> ws db }} serves Turbo's authenticated
  websocket signaling endpoint at `/v1/ws`.
  
  The websocket handshake uses the existing dev auth header plus a required
  `deviceId` query parameter. Each incoming text frame must be a serialized
  {type SignalEnvelope}.
  
  **Also see:** {{ docLink (base.syntax.docEmbedTermLink do web) }}
  }}

