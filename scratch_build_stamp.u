turbo.service.invites.accept :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote} ()
turbo.service.invites.accept db =
  do
    use Parser /
    use UserId toText
    use base.Function |>
    use base.Text ==
    use unison_json_1_3_5.core.Json.object addBoolean addText empty
    inviteIdText =
      route
        base.IO.net.URI.Method.POST
        (s "v1" / s "invites" / Parser.text / s "accept")
    match requireUser db () with
      base.Either.Left err -> unauthorized.json (empty |> addText "error" err)
      base.Either.Right currentUser ->
        currentUserId =
          (User.User userId _ _ _ _) = currentUser
          userId
        inviteId = InviteId.fromText inviteIdText
        match invites.getById db inviteId () with
          base.Optional.None ->
            notFound.json (empty |> addText "error" "invite not found")
          base.Optional.Some invite ->
            (Invite _ _ toUserId _ status _ _ _) = invite
            if base.Boolean.not (toText toUserId == toText currentUserId) then
              unauthorized.json
                (empty |> addText "error" "not invite recipient")
            else
              inviteJson = internal.inviteJson db currentUserId invite ()
              ok.json
                (inviteJson
                  |> addBoolean "accepted" true
                  |> (addBoolean "pendingJoin" match status with
                       InviteStatus.Pending -> true
                       _                    -> false))

turbo.service.invites.accept.doc : base.Doc
turbo.service.invites.accept.doc =
  use base.syntax docEmbedTermLink docLink docParagraph docTransclude docWord
  {{
  {{ base.syntax.docExample 1 do db -> invites.accept db }} acknowledges an
  incoming invite for the current user.
  
  The invite remains pending until both peers have actually joined the channel;
  the join step is still authoritative for transitioning to connected state.
  
  **Also see:** {{ docLink (docEmbedTermLink do channels.join) }},
  {invites.getById}
  }}

