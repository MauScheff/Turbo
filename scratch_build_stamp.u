turbo.service.users.presenceByHandle :
  unison_cloud_27_3_0.Database
  -> '{Route,
  base.abilities.Exception,
  unison_cloud_27_3_0.Storage,
  unison_cloud_27_3_0.Remote} ()
turbo.service.users.presenceByHandle db =
  do
    use Parser /
    use base.Function |>
    use base.Optional None Some
    use unison_json_1_3_5.core.Json.object addText empty
    userHandle =
      route
        base.IO.net.URI.Method.GET
        (s "v1" / s "users" / s "by-handle" / Parser.text / s "presence")
    match requireUser db () with
      base.Either.Left err -> unauthorized.json (empty |> addText "error" err)
      base.Either.Right _ ->
        match getByHandle db userHandle () with
          None -> notFound.json (empty |> addText "error" "user not found")
          Some (User.User userId handleText displayName _ _) ->
            presence = getForUser db userId ()
            (isOnline, currentChannelIdText) =
              match presence with
                None -> (false, None)
                Some (DevicePresence _ _ status currentChannelId _) ->
                  online = match status with
                    Online                       -> true
                    DevicePresenceStatus.Offline -> false
                  channelText = match currentChannelId with
                    None           -> None
                    Some channelId -> Some (ChannelId.toText channelId)
                  (online, channelText)
            ok.json
              (empty
                |> addText "userId" (UserId.toText userId)
                |> addText "handle" handleText
                |> addText "displayName" displayName
                |> unison_json_1_3_5.core.Json.object.addBoolean
                     "isOnline" isOnline
                |> unison_json_1_3_5.core.Json.object.addOptionalText
                     "currentChannelId" currentChannelIdText)

turbo.service.users.presenceByHandle.doc : base.Doc
turbo.service.users.presenceByHandle.doc =
  use base.syntax docEmbedTermLink docGroup docJoin docLink docParagraph docTransclude docWord
  {{
