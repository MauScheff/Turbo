turbo.service.routes.tests.examples : '{IO, Exception} [Result]
turbo.service.routes.tests.examples =
  do
    test.verify do
      use cloud simple
      setup _ = Database.default()
      server db = service.http db ()
      healthStatus = 
        catch do simple setup server (clientStatusGet "/v1/health")
      configStatus = 
        catch do simple setup server (clientStatusGet "/v1/config")
      seedStatus = 
        catch do simple setup server (clientStatusPost "/v1/dev/seed")
      resetStatus = 
        catch do simple setup server (clientStatusPost "/v1/dev/reset-state")
      heartbeatStatus = 
        catch do
          simple setup server (clientStatusPost "/v1/presence/heartbeat")
      incomingInvitesStatus = 
        catch do simple setup server (clientStatusGet "/v1/invites/incoming")
      channelStateStatus = 
        catch do
          simple
            setup server (clientStatusGet "/v1/channels/example/state/device")
      ensureEqual healthStatus (Right 200)
      ensureEqual configStatus (Right 200)
      ensureEqual seedStatus (Right 200)
      ensureEqual resetStatus (Right 200)
      ensureEqual heartbeatStatus (Right 401)
      ensureEqual incomingInvitesStatus (Right 401)
      ensureEqual channelStateStatus (Right 401)

turbo.service.users.presenceByHandle :
  Database -> '{Route, Exception, Storage, Remote} ()
turbo.service.users.presenceByHandle db =
  do
    use Parser /
    use object empty
    userHandle =
      route
        GET (s "v1" / s "users" / s "by-handle" / Parser.text / s "presence")
    _ = requireUser db ()
    match getByHandle db userHandle () with
      None -> notFound.json (empty |> addText "error" "user not found")
      Some (User userId handleText displayName _ _) ->
        presence = getForUser db userId ()
        (isOnline, currentChannelIdText) =
          match presence with
            None -> (false, None)
            Some (DevicePresence _ _ status currentChannelId _) ->
              online = match status with
                Online                       -> true
                DevicePresenceStatus.Offline -> false
              channelText = match currentChannelId with
                None           -> None
                Some channelId -> Some (ChannelId.toText channelId)
              (online, channelText)
        ok.json
          (empty
            |> addText "userId" (UserId.toText userId)
            |> addText "handle" handleText
            |> addText "displayName" displayName
            |> addBoolean "isOnline" isOnline
            |> addOptionalText "currentChannelId" currentChannelIdText)

turbo.service.users.presenceByHandle.doc : Doc
turbo.service.users.presenceByHandle.doc =
  {{
  {{ docExample 1 do db -> presenceByHandle db }} reports whether a
  dev-directory user currently has any online device presence.
  
  It matches `GET /v1/users/by-handle/<handle>/presence`.
  
  **Also see:** {getByHandle}, {getForUser}
  }}

turbo.service.web :
  Database
  -> '{Route,
  Exception,
  Http,
  OpenWebSocket,
  Storage,
  Remote,
  WebSockets,
  Random,
  Log} ()
turbo.service.web db = Route.or (ws db) (service.http db)

turbo.service.web.doc : Doc
turbo.service.web.doc =
  {{
  `` web db `` combines Turbo's HTTP control plane with the websocket signaling
  endpoint.
  
  This is the shared route intended for both local serving and cloud
  deployment.
  
  **Also see:** {service.http}, {ws}
  }}

turbo.service.ws :
  Database
  -> '{Route,
  Exception,
  Http,
  OpenWebSocket,
  Storage,
  Remote,
  WebSockets,
  Random,
  Log} ()
turbo.service.ws db =
  do
    use Parser & /
    deviceIdOpt = route GET (s "v1" / s "ws" & (do ParseQuery.text "deviceId"))
    match deviceIdOpt with
      None ->
        badRequest.json (object.empty |> addText "error" "missing deviceId")
      Some deviceIdText ->
        currentUser = requireUser db ()
        currentUserId =
          (User userId _ _ _ _) = currentUser
          userId
        ws = openWebSocket
        deviceId = DeviceId.fromText deviceIdText
        _ = sockets.connect db currentUserId deviceId ws ()
        _ = catch do
          forever do
            message = WebSockets.receive ws
            handleMessage db currentUserId deviceId ws message ()
        disconnect db deviceId ()

turbo.service.ws.doc : Doc
turbo.service.ws.doc =
  {{
  `` ws db `` serves Turbo's authenticated websocket signaling endpoint at
  `/v1/ws`.
  
  The websocket handshake uses the existing dev auth header plus a required
  `deviceId` query parameter. Each incoming text frame must be a serialized
  {type SignalEnvelope}.
  
  **Also see:** {web}
  }}



---- Anything below this line is ignored by Unison.


type turbo.auth.DevSession
  = DevSession Text

turbo.auth.devHandle.doc = {{

``turbo.auth.devHandle`` resolves the temporary dev identity from the current request.

It first checks `x-turbo-user-handle`, then falls back to `Authorization: Bearer <handle>`.

*Also see:* {turbo.auth.requireUser}

}}
turbo.auth.devHandle : '{Route} Optional Text
turbo.auth.devHandle = do
  match List.head (Route.request.header "x-turbo-user-handle") with
    Some userHandle -> Some userHandle
    None ->
      authorizationHeader =
        match List.head (Route.request.header "authorization") with
          Some header -> Some header
          None -> List.head (Route.request.header "Authorization")
      match authorizationHeader with
        None -> None
        Some header ->
          match Text.words header with
            ["Bearer", userHandle] -> Some userHandle
            [userHandle] -> Some userHandle
            _ -> None

turbo.store.users.create.doc = {{

``turbo.store.users.create db userHandle displayName`` ensures a dev user exists for `userHandle` and returns it.

If a user with the same handle already exists, the existing user is returned.

*Also see:* {turbo.store.users.getByHandle}, {turbo.auth.requireUser}

}}
turbo.store.users.create : Database -> Text -> Text -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} turbo.domain.User
turbo.store.users.create db userHandle displayName = do
  table = turbo.store.users.tables.byId db
  byHandle = turbo.store.users.tables.byHandle db
  byCreatedAt = turbo.store.users.tables.byCreatedAt db
  now = now!
  transact (OrderedTable.database table) do
    match OrderedTable.tryRead.tx byHandle userHandle with
      Some existingId ->
        match OrderedTable.tryRead.tx table existingId with
          Some user -> user
          None ->
            user = User existingId userHandle displayName now now
            _ = OrderedTable.write.tx table existingId user
            _ = OrderedTable.write.tx byCreatedAt (now, existingId) user
            user
      None ->
        id = turbo.domain.UserId.fromText (Random.bytes 20 |> Bytes.base32Hex)
        user = User id userHandle displayName now now
        _ = OrderedTable.write.tx table id user
        _ = OrderedTable.write.tx byHandle userHandle id
        _ = OrderedTable.write.tx byCreatedAt (now, id) user
        user

turbo.store.users.getById.doc = {{

``turbo.store.users.getById db userId`` looks up a user by backend id.

*Also see:* {turbo.store.users.getByHandle}, {turbo.store.users.create}

}}
turbo.store.users.getById : Database -> turbo.domain.UserId -> '{Exception, Remote} Optional turbo.domain.User
turbo.store.users.getById db userId = do
  OrderedTable.tryRead (turbo.store.users.tables.byId db) userId

turbo.store.users.getByHandle.doc = {{

``turbo.store.users.getByHandle db userHandle`` looks up a user by handle.

*Also see:* {turbo.store.users.getById}, {turbo.store.users.create}

}}
turbo.store.users.getByHandle : Database -> Text -> '{Exception, Remote} Optional turbo.domain.User
turbo.store.users.getByHandle db userHandle = do
  match OrderedTable.tryRead (turbo.store.users.tables.byHandle db) userHandle with
    None -> None
    Some userId -> OrderedTable.tryRead (turbo.store.users.tables.byId db) userId

turbo.store.devices.register.doc = {{

``turbo.store.devices.register db userId deviceId platform deviceLabel`` upserts a device registration for `userId`.

If the device already exists, its last-seen timestamp and metadata are refreshed.

*Also see:* {turbo.store.users.getById}

}}
turbo.store.devices.register :
  Database
  -> turbo.domain.UserId
  -> turbo.domain.DeviceId
  -> turbo.domain.DevicePlatform
  -> Optional Text
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} turbo.domain.Device
turbo.store.devices.register db userId deviceId platform deviceLabel = do
  table = turbo.store.devices.tables.byId db
  now = now!
  transact (OrderedTable.database table) do
    createdAt = match OrderedTable.tryRead.tx table deviceId with
      Some (Device _ _ _ _ existingCreatedAt _) -> existingCreatedAt
      None -> now
    device = Device deviceId userId platform deviceLabel createdAt now
    _ = OrderedTable.write.tx table deviceId device
    device

turbo.store.channels.getOrCreateDirect.doc = {{

``turbo.store.channels.getOrCreateDirect db userA userB`` returns the stable direct channel for `userA` and `userB`.

The same channel is returned regardless of caller order.

*Also see:* {turbo.domain.directChannelKey}

}}
turbo.store.channels.getOrCreateDirect :
  Database
  -> turbo.domain.UserId
  -> turbo.domain.UserId
  -> '{Exception, unison_cloud_27_3_0.Storage, Remote, Random} turbo.domain.DirectChannel
turbo.store.channels.getOrCreateDirect db userA userB = do
  table = turbo.store.channels.tables.byId db
  byPair = turbo.store.channels.tables.byUserPair db
  pair = turbo.domain.directChannelKey userA userB
  (lowUserId, highUserId) = pair
  now = now!
  transact (OrderedTable.database table) do
    match OrderedTable.tryRead.tx byPair pair with
      Some channelId ->
        match OrderedTable.tryRead.tx table channelId with
          Some channel -> channel
          None ->
            channel = DirectChannel channelId lowUserId highUserId now
            _ = OrderedTable.write.tx table channelId channel
            channel
      None ->
        channelId = turbo.domain.ChannelId.fromText (Random.bytes 20 |> Bytes.base32Hex)
        channel = DirectChannel channelId lowUserId highUserId now
        _ = OrderedTable.write.tx table channelId channel
        _ = OrderedTable.write.tx byPair pair channelId
        channel

turbo.auth.requireUser.doc = {{

``turbo.auth.requireUser db`` resolves the current dev user from the request headers.

It accepts either `x-turbo-user-handle` or `Authorization: Bearer <handle>`.

Missing or unknown auth returns a descriptive error instead of failing the route.

*Also see:* {turbo.auth.devHandle}, {turbo.store.users.getByHandle}, {turbo.store.users.create}

}}
turbo.auth.requireUser : Database -> '{Route, Exception, unison_cloud_27_3_0.Storage, Remote} Either Text turbo.domain.User
turbo.auth.requireUser db = do
  match turbo.auth.devHandle () with
    None -> Left "missing dev auth"
    Some userHandle ->
      match turbo.store.users.getByHandle db userHandle () with
        None -> Left "unknown dev user handle"
        Some user -> Right user

turbo.store.users.tables.byId : Database -> OrderedTable turbo.domain.UserId turbo.domain.User
turbo.store.users.tables.byId db =
  OrderedTable.named db "turboUsersById_v1" Universal.ordering

turbo.store.users.tables.byHandle : Database -> OrderedTable Text turbo.domain.UserId
turbo.store.users.tables.byHandle db =
  OrderedTable.named db "turboUsersByHandle_v1" Universal.ordering

turbo.store.users.tables.byCreatedAt : Database -> OrderedTable (Instant, turbo.domain.UserId) turbo.domain.User
turbo.store.users.tables.byCreatedAt db =
  OrderedTable.named db "turboUsersByCreatedAt_v1" Universal.ordering

turbo.store.devices.tables.byId : Database -> OrderedTable turbo.domain.DeviceId turbo.domain.Device
turbo.store.devices.tables.byId db =
  OrderedTable.named db "turboDevicesById_v1" Universal.ordering

turbo.store.channels.tables.byId : Database -> OrderedTable turbo.domain.ChannelId turbo.domain.DirectChannel
turbo.store.channels.tables.byId db =
  OrderedTable.named db "turboDirectChannelsById_v1" Universal.ordering

turbo.store.channels.tables.byUserPair : Database -> OrderedTable (turbo.domain.UserId, turbo.domain.UserId) turbo.domain.ChannelId
turbo.store.channels.tables.byUserPair db =
  OrderedTable.named db "turboDirectChannelsByUserPair_v1" Universal.ordering
